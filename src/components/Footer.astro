---
const links = [
  { label: '私たちについて', href: '/about' },
  { label: 'お知らせ', href: '/news' },
  { label: '商品紹介', href: '/products' },
  { label: 'こだわり', href: '/feature' },
  { label: '法人のお客様', href: '/business' },
  { label: '個人のお客様', href: '/shop' },
  { label: 'お問い合わせ', href: '/contact' },
];
---
<footer class="ft">
  <div class="ft-wave">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#6F8F3A"/>
    </svg>
  </div>
  <div class="ft-body">
    <div class="ft-in">
      <div class="ft-brand">
        <a href="/" class="ft-logo">
          <svg width="48" height="48" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="19" fill="rgba(255,243,192,.2)" stroke="rgba(245,184,46,.4)" stroke-width="1.5"/>
            <ellipse cx="14" cy="24" rx="7" ry="9" fill="rgba(250,240,220,.8)" stroke="rgba(212,168,32,.4)" stroke-width="1"/>
            <ellipse cx="20" cy="22" rx="7.5" ry="9.5" fill="rgba(250,240,220,.8)" stroke="rgba(212,168,32,.4)" stroke-width="1"/>
            <ellipse cx="26" cy="24" rx="7" ry="9" fill="rgba(250,240,220,.8)" stroke="rgba(212,168,32,.4)" stroke-width="1"/>
          </svg>
          <div>
            <span class="ft-jp">小澤鶏卵</span>
            <span class="ft-en">KOZAWA KEIRAN</span>
          </div>
        </a>
        <p class="ft-copy">新鮮で安心なたまごを、<br/>毎日の食卓へ。</p>
        <a href="tel:0000-00-0000" class="ft-tel">0000-00-0000</a>
        <p class="ft-hrs">月〜土 8:00〜17:00（日祝休業）</p>
        <p class="ft-addr">〒000-0000 ○○県○○市○○町 0-0-0</p>
      </div>
      <nav class="ft-nav">
        <ul>
          {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </nav>
      <div class="ft-contact-box">
        <h3>お問い合わせ</h3>
        <p>ご注文・ご質問など、お気軽にお問い合わせください。</p>
        <a href="/contact" class="btn btn-primary" style="justify-content:center;width:100%">お問い合わせフォーム →</a>
        <a href="/business" class="btn btn-outline" style="justify-content:center;width:100%;margin-top:.75rem">法人のお客様はこちら</a>
      </div>
    </div>
    <div class="ft-btm">
      <p>&copy; {new Date().getFullYear()} 小澤鶏卵 All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.ft { margin-top:0; }
.ft-wave { line-height:0; background:#FFFAF0; }
.ft-wave svg { display:block; width:100%; height:60px; }
.ft-body { background:#6F8F3A; color:white; padding:3rem 0 1.5rem; }
.ft-in {
  max-width:1200px; margin:0 auto; padding:0 2rem;
  display:grid; grid-template-columns:1.3fr 1fr 1.2fr; gap:4rem; margin-bottom:2.5rem;
}
.ft-logo { display:flex; align-items:center; gap:.7rem; text-decoration:none; margin-bottom:.875rem; }
.ft-jp { display:block; font-family:'Noto Serif JP',serif; font-size:1.1rem; font-weight:700; color:white; letter-spacing:.06em; line-height:1.2; }
.ft-en { display:block; font-family:'Lato',sans-serif; font-size:.52rem; letter-spacing:.2em; color:rgba(255,255,255,.6); margin-top:1px; }
.ft-copy { font-size:.9rem; color:rgba(255,255,255,.8); line-height:1.8; margin-bottom:1rem; }
.ft-tel { display:block; font-family:'Lato',sans-serif; font-size:1.4rem; font-weight:300; color:#F5B82E; text-decoration:none; letter-spacing:.05em; margin-bottom:.2rem; }
.ft-hrs,.ft-addr { font-size:.75rem; color:rgba(255,255,255,.55); margin:.2rem 0 0; }
.ft-nav ul { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0; }
.ft-nav a { display:block; padding:.5rem 0; font-size:.875rem; font-weight:500; color:rgba(255,255,255,.8); text-decoration:none; border-bottom:1px solid rgba(255,255,255,.1); transition:color .15s,padding-left .2s; }
.ft-nav a:hover { color:#F5B82E; padding-left:.5rem; }
.ft-contact-box h3 { font-family:'Noto Serif JP',serif; font-size:1rem; font-weight:700; color:white; margin-bottom:.5rem; }
.ft-contact-box p { font-size:.8rem; color:rgba(255,255,255,.7); margin-bottom:1.25rem; line-height:1.7; }
.ft-btm { max-width:1200px; margin:0 auto; padding:1.5rem 2rem 0; border-top:1px solid rgba(255,255,255,.15); text-align:center; }
.ft-btm p { font-size:.75rem; color:rgba(255,255,255,.5); margin:0; }
@media (max-width:900px) { .ft-in { grid-template-columns:1fr 1fr; gap:2rem; } .ft-contact-box { grid-column:1/-1; } }
@media (max-width:600px) { .ft-in { grid-template-columns:1fr; } }
</style>
