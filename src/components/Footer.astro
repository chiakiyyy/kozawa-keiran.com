---
const linksRow1 = [
  { label: '私たちについて', href: '/about' },
  { label: 'こだわり',       href: '/feature' },
  { label: '商品紹介',       href: '/products' },
  { label: '出荷の流れ',     href: '/flow' },
  { label: 'お知らせ',       href: '/news' },
];
const linksRow2 = [
  { label: '法人のお客様',   href: '/business' },
  { label: '個人のお客様',   href: '/shop' },
];
---
<footer class="ft">
  <div class="ft-top">
    <div class="ft-in">
      <div class="ft-brand">
        <a href="/" class="ft-logo">
          <img src="/images/icon.png" alt="" aria-hidden="true" class="ft-logo-icon"/>
          <div>
            <span class="ft-jp">小澤鶏卵</span>
            <span class="ft-en">KOZAWA KEIRAN</span>
          </div>
        </a>
        <a href="tel:076-466-3815" class="ft-tel">076-466-3815</a>
        <p class="ft-hrs">月〜土 8:00〜17:00（日祝休業）<br/>〒939-2716 富山県富山市婦中町下轡田25-1</p>
      </div>

      <nav class="ft-nav">
        <ul class="ft-nav-row">
          {linksRow1.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
        <ul class="ft-nav-row">
          {linksRow2.map(l => <li><a href={l.href}>{l.label}</a></li>)}
          <li class="ft-nav-paren">（<a href="/contact">お問い合わせ</a>）</li>
        </ul>
      </nav>

      <div class="ft-contact">
        <a href="/contact" class="ft-btn-primary">お問い合わせフォーム →</a>
      </div>
    </div>
  </div>
  <div class="ft-btm">
    <p>&copy; {new Date().getFullYear()} 小澤鶏卵 All rights reserved.</p>
  </div>
</footer>

<style>
.ft { background: #ffffff; color: #BA7517; }
.ft-top { padding: 1.75rem 0 1.25rem; }
.ft-in {
  max-width: 1200px; margin: 0 auto; padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between; gap: 2rem;
  flex-wrap: wrap;
}
.ft-brand { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
.ft-logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; flex-shrink: 0; }
.ft-logo-icon { height: 38px; width: auto; display: block; object-fit: contain; }
.ft-jp { display: block; font-family: 'Zen Kaku Gothic New', sans-serif; font-size: .95rem; font-weight: 700; color: #BA7517; letter-spacing: .05em; line-height: 1.3; }
.ft-en { display: block; font-family: Manrope, sans-serif; font-size: .42rem; letter-spacing: .2em; color: rgba(186,117,23,0.6); margin-top: 2px; }
.ft-tel { font-family: Manrope, sans-serif; font-size: 1.15rem; font-weight: 700; color: #BA7517; text-decoration: none; letter-spacing: .03em; flex-shrink: 0; }
.ft-hrs { font-size: .68rem; color: rgba(186,117,23,0.75); margin: 0; line-height: 1.5; }

/* メニュー：横並び2行 */
.ft-nav { flex: 1; min-width: 280px; display: flex; flex-direction: column; gap: .4rem; }
.ft-nav-row {
  list-style: none; margin: 0; padding: 0;
  display: flex; flex-wrap: wrap; gap: .25rem 1.25rem; justify-content: center;
}
.ft-nav a {
  font-size: .78rem; color: rgba(186,117,23,0.85);
  text-decoration: none; padding: .25rem 0;
  transition: color .15s;
  white-space: nowrap;
}
.ft-nav a:hover { color: #BA7517; text-decoration: underline; }
.ft-nav-paren { font-size: .78rem; color: rgba(186,117,23,0.85); white-space: nowrap; }
.ft-nav-paren a { padding: 0; }

.ft-contact { flex-shrink: 0; }
.ft-btn-primary {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .55rem 1.25rem; border-radius: 999px;
  background: #BA7517; color: #FDF6E9;
  font-size: .78rem; font-weight: 700; letter-spacing: .03em;
  text-decoration: none; border: none; cursor: pointer;
  transition: opacity .15s; white-space: nowrap;
}
.ft-btn-primary:hover { opacity: .85; }

.ft-btm {
  border-top: 0.5px solid rgba(186,117,23,0.2);
  padding: .75rem 2rem; text-align: center;
}
.ft-btm p { font-size: .68rem; color: rgba(186,117,23,0.65); margin: 0; }

@media (max-width:900px) {
  .ft-in { flex-direction: column; align-items: stretch; text-align: center; gap: 1.25rem; }
  .ft-brand { justify-content: center; }
  .ft-nav-row { justify-content: center; }
  .ft-contact { display: flex; justify-content: center; }
}
@media (max-width:600px) {
  .ft-brand { flex-direction: column; gap: .75rem; text-align: center; }
}
</style>
