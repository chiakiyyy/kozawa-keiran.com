---
const links = [
  { label: '私たちについて', href: '/about' },
  { label: 'お知らせ',       href: '/news' },
  { label: '商品紹介',       href: '/products' },
  { label: 'こだわり',       href: '/feature' },
  { label: '出荷の流れ',     href: '/flow' },
  { label: '法人のお客様',   href: '/business' },
  { label: '個人のお客様',   href: '/shop' },
  { label: 'お問い合わせ',   href: '/contact' },
];
---
<footer class="ft">
  <div class="ft-top">
    <div class="ft-in">
      <div class="ft-brand">
        <a href="/" class="ft-logo">
          <svg width="36" height="44" viewBox="0 0 34 42" fill="none" aria-hidden="true">
            <ellipse cx="17" cy="26" rx="15" ry="16" fill="rgba(255,255,255,0.35)"/>
            <ellipse cx="17" cy="16" rx="10" ry="13" fill="rgba(255,255,255,0.5)"/>
          </svg>
          <div>
            <span class="ft-jp">小澤鶏卵</span>
            <span class="ft-en">KOZAWA KEIRAN</span>
          </div>
        </a>
        <p class="ft-copy">新鮮で安心なたまごを、<br/>毎日の食卓へ。</p>
        <a href="tel:076-466-3815" class="ft-tel">076-466-3815</a>
        <p class="ft-hrs">月〜土 8:00〜17:00（日祝休業）</p>
        <p class="ft-addr">〒939-2716 富山県富山市婦中町下轡田25-1</p>
      </div>

      <nav class="ft-nav">
        <p class="ft-nav-label">MENU</p>
        <ul>
          {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </nav>

      <div class="ft-contact">
        <p class="ft-nav-label">CONTACT</p>
        <p class="ft-contact-lead">ご注文・ご質問など<br/>お気軽にお問い合わせください。</p>
        <a href="/contact" class="ft-btn-primary" style="justify-content:center;width:100%;margin-bottom:.75rem">お問い合わせフォーム →</a>
        <a href="/business" class="ft-btn-outline" style="justify-content:center;width:100%">法人のお客様はこちら</a>
      </div>
    </div>
  </div>
  <div class="ft-btm">
    <p>&copy; {new Date().getFullYear()} 小澤鶏卵 All rights reserved.</p>
  </div>
</footer>

<style>
.ft { background: #f6b937; color: #3a2a00; }
.ft-top { padding: 2.75rem 0 2rem; }
.ft-in {
  max-width: 1200px; margin: 0 auto; padding: 0 2rem;
  display: grid; grid-template-columns: 1.4fr 1fr 1.3fr; gap: 3rem;
}
.ft-logo { display: flex; align-items: center; gap: .75rem; text-decoration: none; margin-bottom: 1rem; }
.ft-jp { display: block; font-family: 'Zen Kaku Gothic New', sans-serif; font-size: 1.05rem; font-weight: 700; color: #ffffff; letter-spacing: .05em; }
.ft-en { display: block; font-family: Manrope, sans-serif; font-size: .48rem; letter-spacing: .2em; color: rgba(255,255,255,0.65); margin-top: 2px; }
.ft-copy { font-size: .875rem; color: rgba(255,255,255,0.85); line-height: 1.8; margin-bottom: 1rem; }
.ft-tel { display: block; font-family: Manrope, sans-serif; font-size: 1.5rem; font-weight: 700; color: #ffffff; text-decoration: none; letter-spacing: .04em; margin-bottom: .25rem; }
.ft-hrs, .ft-addr { font-size: .72rem; color: rgba(255,255,255,0.7); margin: .2rem 0 0; line-height: 1.6; }
.ft-nav-label { font-family: Manrope, sans-serif; font-size: .6rem; letter-spacing: .18em; color: rgba(255,255,255,0.75); margin-bottom: .75rem; text-transform: uppercase; }
.ft-nav ul { list-style: none; margin: 0; padding: 0; }
.ft-nav a {
  display: block; padding: .38rem 0; font-size: .84rem; color: rgba(255,255,255,0.9);
  text-decoration: none; border-bottom: 0.5px solid rgba(255,255,255,0.2);
  transition: color .15s, padding-left .2s;
}
.ft-nav a:hover { color: #ffffff; padding-left: .4rem; }
.ft-contact-lead { font-size: .82rem; color: rgba(255,255,255,0.85); line-height: 1.7; margin-bottom: 1rem; }
/* footer専用ボタン */
.ft-btn-primary {
  display: flex; align-items: center; gap: .5rem;
  padding: .7rem 1.5rem; border-radius: 2px;
  background: #3a2a00; color: #f6b937;
  font-size: .84rem; font-weight: 600; letter-spacing: .04em;
  text-decoration: none; border: none; cursor: pointer;
  transition: opacity .15s;
}
.ft-btn-primary:hover { opacity: .85; }
.ft-btn-outline {
  display: flex; align-items: center; gap: .5rem;
  padding: .7rem 1.5rem; border-radius: 2px;
  background: transparent; color: #ffffff;
  font-size: .84rem; font-weight: 600; letter-spacing: .04em;
  text-decoration: none; border: 1.5px solid rgba(255,255,255,0.6); cursor: pointer;
  transition: background .15s, border-color .15s;
}
.ft-btn-outline:hover { background: rgba(255,255,255,0.12); border-color: #ffffff; }
.ft-btm {
  border-top: 0.5px solid rgba(255,255,255,0.2);
  padding: 1.1rem 2rem; text-align: center;
}
.ft-btm p { font-size: .72rem; color: rgba(255,255,255,0.7); margin: 0; }
@media (max-width:900px) { .ft-in { grid-template-columns: 1fr 1fr; gap: 2.5rem; } .ft-contact { grid-column: 1/-1; } }
@media (max-width:600px) { .ft-in { grid-template-columns: 1fr; gap: 2rem; } }
</style>
