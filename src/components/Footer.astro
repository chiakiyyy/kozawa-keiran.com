---
const navLinks = [
  { label: '私たちについて', href: '/company' },
  { label: '商品案内', href: '/products' },
  { label: 'こだわり', href: '/quality' },
  { label: 'よくある質問', href: '/qa' },
  { label: 'お知らせ', href: '/news' },
  { label: 'お問い合わせ', href: '/contact' },
];
---

<footer class="site-footer">
  <!-- Wave top -->
  <div class="footer-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#3D7A34"/>
    </svg>
  </div>

  <div class="footer-body">
    <div class="footer-inner">
      <!-- ロゴ・コピー -->
      <div class="footer-brand">
        <div class="footer-logo">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="26" cy="26" r="25" fill="rgba(255,248,192,0.15)" stroke="rgba(242,201,76,0.4)" stroke-width="1.5"/>
            <ellipse cx="26" cy="30" rx="11" ry="14" fill="rgba(250,245,236,0.9)" stroke="rgba(242,201,76,0.5)" stroke-width="1"/>
            <ellipse cx="26" cy="33" rx="6" ry="8" fill="#F2C94C" opacity="0.5"/>
            <circle cx="26" cy="18" r="6" fill="rgba(245,232,192,0.9)" stroke="rgba(200,160,96,0.5)" stroke-width="1"/>
            <ellipse cx="26" cy="22" rx="3.5" ry="1.8" fill="#F4A020" opacity="0.8"/>
            <ellipse cx="26" cy="13.5" rx="3.5" ry="2.2" fill="#E04040" opacity="0.8"/>
          </svg>
          <div>
            <p class="footer-logo-jp">小澤鶏卵</p>
            <p class="footer-logo-en">OZAWA KEIRAN</p>
          </div>
        </div>
        <p class="footer-copy">
          新鮮で安心なたまごを、<br />毎日の食卓へ。
        </p>
        <a href="tel:0000-00-0000" class="footer-tel">0000-00-0000</a>
        <p class="footer-hours">月〜土曜 8:00〜17:00（日祝休業）</p>
      </div>

      <!-- ナビ -->
      <nav class="footer-nav" aria-label="フッターナビゲーション">
        <ul>
          {navLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- イラスト -->
      <div class="footer-illust" aria-hidden="true">
        <svg viewBox="0 0 240 200" xmlns="http://www.w3.org/2000/svg">
          <!-- 大きな卵 -->
          <ellipse cx="120" cy="115" rx="70" ry="88" fill="rgba(250,245,236,0.15)" stroke="rgba(242,201,76,0.3)" stroke-width="1.5"/>
          <ellipse cx="120" cy="124" rx="38" ry="48" fill="#F2C94C" opacity="0.25"/>
          <!-- ニワトリ(左) -->
          <g transform="translate(40,150)">
            <ellipse cx="0" cy="0" rx="22" ry="16" fill="rgba(245,232,192,0.8)"/>
            <circle cx="17" cy="-11" r="12" fill="rgba(245,232,192,0.8)"/>
            <polygon points="23,-11 30,-7 23,-5" fill="#F4A020" opacity="0.8"/>
            <ellipse cx="15" cy="-20" rx="5" ry="3" fill="#E04040" opacity="0.7"/>
            <line x1="-4" y1="16" x2="-9" y2="34" stroke="#F4A020" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
            <line x1="7" y1="16" x2="2" y2="34" stroke="#F4A020" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
          </g>
          <!-- ニワトリ(右) -->
          <g transform="translate(200,155)">
            <ellipse cx="0" cy="0" rx="20" ry="14" fill="rgba(255,255,255,0.7)"/>
            <circle cx="-15" cy="-10" r="11" fill="rgba(255,255,255,0.7)"/>
            <polygon points="-21,-10 -29,-7 -21,-5" fill="#F4A020" opacity="0.8"/>
            <ellipse cx="-13" cy="-18" rx="5" ry="3" fill="#E04040" opacity="0.7"/>
            <line x1="-4" y1="14" x2="-9" y2="30" stroke="#F4A020" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
            <line x1="6" y1="14" x2="2" y2="30" stroke="#F4A020" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
          </g>
          <!-- ひよこ -->
          <g transform="translate(118,168)">
            <ellipse cx="0" cy="0" rx="14" ry="12" fill="rgba(255,220,80,0.7)"/>
            <circle cx="0" cy="-13" r="9" fill="rgba(255,220,80,0.7)"/>
            <polygon points="5,-13 10,-11 5,-9" fill="#F4A020" opacity="0.7"/>
            <line x1="-5" y1="12" x2="-7" y2="24" stroke="#F4A020" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
            <line x1="3" y1="12" x2="2" y2="24" stroke="#F4A020" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
          </g>
        </svg>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} 小澤鶏卵 All rights reserved.</p>
      <p class="footer-address">〒000-0000 ○○県○○市○○町 0-0-0</p>
    </div>
  </div>
</footer>

<style>
.site-footer { margin-top: 0; }
.footer-wave { display: block; line-height: 0; background-color: var(--color-yellow-pale); }
.footer-wave svg { display: block; width: 100%; height: 60px; }
.footer-body { background-color: #3D7A34; color: white; padding: 3.5rem 0 1.5rem; }
.footer-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 2rem;
  display: grid;
  grid-template-columns: 1.2fr 1fr 0.8fr;
  gap: 4rem;
  margin-bottom: 2.5rem;
}
.footer-logo {
  display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;
}
.footer-logo-jp {
  font-family: 'Zen Maru Gothic', sans-serif;
  font-size: 1.15rem; font-weight: 700;
  color: white; letter-spacing: 0.06em; margin: 0;
}
.footer-logo-en {
  font-family: 'Lato', sans-serif;
  font-size: 0.55rem; letter-spacing: 0.22em;
  color: rgba(255,255,255,0.6); margin: 0;
}
.footer-copy {
  font-size: 0.9rem; line-height: 1.8;
  color: rgba(255,255,255,0.8); margin-bottom: 1.25rem;
}
.footer-tel {
  display: block;
  font-family: 'Lato', sans-serif;
  font-size: 1.35rem; font-weight: 300;
  color: #F2C94C; text-decoration: none;
  letter-spacing: 0.05em; margin-bottom: 0.25rem;
}
.footer-hours { font-size: 0.75rem; color: rgba(255,255,255,0.55); margin: 0; }
.footer-nav ul {
  list-style: none; margin: 0; padding: 0;
  display: flex; flex-direction: column; gap: 0;
}
.footer-nav a {
  display: block; padding: 0.55rem 0;
  font-size: 0.875rem; font-weight: 500;
  color: rgba(255,255,255,0.8); text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  transition: color 0.15s, padding-left 0.2s;
}
.footer-nav a:hover { color: #F2C94C; padding-left: 0.5rem; }
.footer-illust { display: flex; align-items: flex-end; justify-content: center; }
.footer-illust svg { width: 200px; height: auto; }
.footer-bottom {
  max-width: 1200px; margin: 0 auto; padding: 1.5rem 2rem 0;
  border-top: 1px solid rgba(255,255,255,0.15);
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 0.5rem;
}
.footer-bottom p {
  font-size: 0.75rem; color: rgba(255,255,255,0.5); margin: 0;
}
.footer-address { font-size: 0.75rem; color: rgba(255,255,255,0.45); }
@media (max-width: 900px) {
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .footer-illust { display: none; }
}
@media (max-width: 600px) {
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom { flex-direction: column; text-align: center; }
}
</style>
