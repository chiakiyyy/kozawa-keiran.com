---
---

<footer class="site-footer">
  <!-- 山形の区切り -->
  <div class="footer-mountain" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 80 L0 60 Q180 0 360 40 Q540 80 720 30 Q900 0 1080 45 Q1260 80 1440 35 L1440 80 Z" fill="#2d6a18"/>
      <path d="M0 80 L0 70 Q200 20 400 55 Q600 80 800 45 Q1000 10 1200 55 Q1350 80 1440 50 L1440 80 Z" fill="#3d7a25"/>
      <path d="M0 80 L0 78 Q360 50 720 68 Q1080 80 1440 62 L1440 80 Z" fill="#4a8c2e"/>
    </svg>
  </div>

  <div class="footer-body">
    <div class="footer-inner">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="footer-egg" aria-hidden="true">
          <svg viewBox="0 0 64 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="32" cy="46" rx="22" ry="28" fill="#f1e16d" stroke="#e8d340" stroke-width="1.5"/>
            <ellipse cx="32" cy="49" rx="12" ry="15" fill="#f5c842" opacity="0.6"/>
            <ellipse cx="26" cy="40" rx="6" ry="4" fill="white" opacity="0.4" transform="rotate(-20,26,40)"/>
          </svg>
        </div>
        <p class="footer-brand-name">小澤鶏卵</p>
        <p class="footer-brand-en">OZAWA KEIRAN</p>
        <p class="footer-tagline">新鮮で安心なたまごを、<br />毎日の食卓へ</p>
        <a href="tel:0000-00-0000" class="footer-tel">0000-00-0000</a>
        <p class="footer-hours">月〜土 8:00〜17:00</p>
      </div>

      <!-- Nav columns -->
      <nav class="footer-nav" aria-label="フッターナビゲーション">
        <div class="footer-nav-col">
          <p class="footer-nav-heading">小澤鶏卵について</p>
          <ul>
            <li><a href="/company">会社概要</a></li>
            <li><a href="/quality">品質へのこだわり</a></li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-heading">商品・サービス</p>
          <ul>
            <li><a href="/products">商品案内</a></li>
            <li><a href="/products#delivery">定期納品サービス</a></li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-heading">サポート</p>
          <ul>
            <li><a href="/contact">お問い合わせ</a></li>
            <li><a href="/faq">よくある質問</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="copyright">&copy; {new Date().getFullYear()} 小澤鶏卵 All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer-mountain {
    display: block;
    line-height: 0;
    overflow: hidden;
    background-color: white;
  }
  .footer-mountain svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  .footer-body {
    background-color: #3d7a25;
    color: rgba(255,255,255,0.85);
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2rem 2.5rem;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 5rem;
  }

  .footer-brand { }

  .footer-egg {
    width: 52px;
    height: 64px;
    margin-bottom: 0.75rem;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
  }
  .footer-egg svg { width: 100%; height: 100%; }

  .footer-brand-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: white;
    letter-spacing: 0.08em;
    margin-bottom: 2px;
  }

  .footer-brand-en {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1rem;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    margin-bottom: 1.25rem;
  }

  .footer-tel {
    display: block;
    font-family: 'Lato', sans-serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--color-yellow);
    text-decoration: none;
    letter-spacing: 0.06em;
    margin-bottom: 0.2rem;
  }

  .footer-hours {
    font-size: 0.775rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-self: start;
    padding-top: 0.5rem;
  }

  .footer-nav-heading {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-yellow);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  .footer-nav ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-nav a {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .footer-nav a::before {
    content: '▶';
    font-size: 0.5rem;
    color: var(--color-yellow);
    opacity: 0.7;
  }
  .footer-nav a:hover { color: white; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 1.25rem 2rem;
    text-align: center;
    max-width: 1280px;
    margin: 0 auto;
  }

  .copyright {
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
