---
const nav = [
  { en: 'ABOUT',   ja: '私たちについて', href: '/about' },
  { en: 'NEWS',    ja: 'お知らせ',       href: '/news' },
  { en: 'LINE UP', ja: '商品紹介',       href: '/products' },
  { en: 'FEATURE', ja: 'こだわり',       href: '/feature' },
  { en: 'CONTACT', ja: 'お問い合わせ',   href: '/contact' },
];
const path = Astro.url.pathname;
---

<header class="hdr" id="hdr">
  <div class="hdr-in">
    <a href="/" class="hdr-logo">
      <svg width="32" height="38" viewBox="0 0 32 38" fill="none" aria-hidden="true">
        <ellipse cx="16" cy="22" rx="14" ry="15" fill="#FAC775"/>
        <ellipse cx="16" cy="13" rx="10" ry="12" fill="#EF9F27"/>
        <ellipse cx="12" cy="9"  rx="3.5" ry="2.8" fill="white" opacity="0.32"/>
      </svg>
      <div>
        <span class="hdr-jp">小澤鶏卵</span>
        <span class="hdr-en">KOZAWA KEIRAN · TOYAMA</span>
      </div>
    </a>

    <nav class="hdr-nav">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={path.startsWith(item.href) && item.href !== '/' ? 'act' : ''}>
              <span class="n-en">{item.en}</span>
              <span class="n-ja">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr-right">
      <a href="/business" class="hdr-biz">法人の方</a>
      <a href="/contact" class="btn btn-primary hdr-cta">お問い合わせ</a>
    </div>

    <button class="hdr-ham" id="hdr-ham" aria-label="メニュー" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="drw-ov" id="drw-ov"></div>
<nav class="drw" id="drw" aria-hidden="true">
  <div class="drw-head">
    <span class="drw-title">小澤鶏卵</span>
    <button id="drw-cl" aria-label="閉じる">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 3l14 14M17 3L3 17" stroke="#412402" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>
  </div>
  <ul>
    {nav.map(item => (
      <li>
        <a href={item.href}>
          <span class="d-ja">{item.ja}</span>
          <span class="d-en">{item.en}</span>
        </a>
      </li>
    ))}
    <li><a href="/business"><span class="d-ja">法人のお客様</span><span class="d-en">BUSINESS</span></a></li>
    <li><a href="/shop"><span class="d-ja">個人のお客様</span><span class="d-en">SHOP</span></a></li>
  </ul>
  <div class="drw-ft">
    <a href="tel:076-466-3815" class="drw-tel">076-466-3815</a>
    <p class="drw-hrs">月〜土 8:00〜17:00</p>
  </div>
</nav>

<style>
.hdr {
  position: fixed; top:0; left:0; right:0; z-index:200;
  background: rgba(255,255,255,0.96);
  border-bottom: 0.5px solid rgba(186,117,23,0.15);
  backdrop-filter: blur(12px);
  transition: box-shadow .3s;
}
.hdr.scrolled { box-shadow: 0 4px 24px rgba(186,117,23,0.08); }
.hdr-in {
  max-width: 1200px; margin:0 auto; padding:0 2rem;
  height: 72px; display:flex; align-items:center; gap:1.5rem;
}
.hdr-logo { display:flex; align-items:center; gap:10px; text-decoration:none; flex-shrink:0; }
.hdr-jp { display:block; font-family:'Noto Serif JP',serif; font-size:1.05rem; font-weight:700; color:#412402; letter-spacing:.06em; line-height:1.2; }
.hdr-en { display:block; font-family:'Lato',sans-serif; font-size:.5rem; font-weight:400; color:#888780; letter-spacing:.16em; margin-top:2px; }
.hdr-nav { flex:1; display:flex; justify-content:center; }
.hdr-nav ul { display:flex; gap:0; list-style:none; margin:0; padding:0; }
.hdr-nav a { display:flex; flex-direction:column; align-items:center; padding:.45rem 1rem; text-decoration:none; border-radius:var(--radius-sm); transition:background .15s; gap:2px; }
.hdr-nav a:hover, .hdr-nav a.act { background:rgba(186,117,23,0.08); }
.n-en { font-family:'Lato',sans-serif; font-size:.68rem; font-weight:700; letter-spacing:.1em; color:#412402; }
.n-ja { font-size:.58rem; color:#888780; letter-spacing:.04em; }
.hdr-right { display:flex; align-items:center; gap:.75rem; flex-shrink:0; }
.hdr-biz { font-size:.78rem; font-weight:700; color:#BA7517; text-decoration:none; letter-spacing:.04em; border: 1px solid rgba(186,117,23,0.3); padding:.45rem 1rem; border-radius:999px; transition:background .15s; }
.hdr-biz:hover { background:rgba(186,117,23,0.07); }
.hdr-cta { padding:.55rem 1.25rem; font-size:.78rem; }
.hdr-ham { display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:4px; flex-shrink:0; }
.hdr-ham span { display:block; width:22px; height:1.5px; background:#412402; border-radius:2px; transition:all .3s; }
.hdr-ham.open span:nth-child(1) { transform:translateY(6.5px) rotate(45deg); }
.hdr-ham.open span:nth-child(2) { opacity:0; }
.hdr-ham.open span:nth-child(3) { transform:translateY(-6.5px) rotate(-45deg); }
.drw-ov { display:none; position:fixed; inset:0; background:rgba(44,44,42,.4); z-index:300; backdrop-filter:blur(3px); }
.drw-ov.open { display:block; }
.drw { position:fixed; top:0; right:0; bottom:0; width:min(300px,86vw); background:white; z-index:400; border-left:0.5px solid rgba(186,117,23,0.2); transform:translateX(100%); transition:transform .32s cubic-bezier(.25,.46,.45,.94); display:flex; flex-direction:column; overflow-y:auto; }
.drw.open { transform:translateX(0); }
.drw-head { display:flex; align-items:center; justify-content:space-between; padding:1.25rem 1.5rem; border-bottom:0.5px solid rgba(186,117,23,0.15); }
.drw-title { font-family:'Noto Serif JP',serif; font-size:1rem; font-weight:700; color:#412402; }
.drw-head button { background:none; border:none; cursor:pointer; padding:4px; }
.drw ul { list-style:none; margin:0; padding:.5rem 0; flex:1; }
.drw li { border-bottom:0.5px solid rgba(186,117,23,0.1); }
.drw a { display:flex; align-items:center; justify-content:space-between; padding:.9rem 1.5rem; text-decoration:none; transition:background .15s; }
.drw a:hover { background:rgba(186,117,23,0.05); }
.d-ja { font-size:.92rem; font-weight:700; color:#412402; }
.d-en { font-family:'Lato',sans-serif; font-size:.6rem; letter-spacing:.12em; color:#BA7517; }
.drw-ft { padding:1.25rem 1.5rem; border-top:0.5px solid rgba(186,117,23,0.15); background:#FAEEDA; }
.drw-tel { display:block; font-family:'Lato',sans-serif; font-size:1.4rem; font-weight:300; color:#412402; text-decoration:none; letter-spacing:.04em; margin-bottom:.25rem; }
.drw-hrs { font-size:.75rem; color:#888780; margin:0; }
@media (max-width:1024px) { .hdr-nav,.hdr-right { display:none; } .hdr-ham { display:flex; } }
@media (max-width:640px) { .hdr-in { padding:0 1.25rem; height:64px; } }
</style>

<script>
const hdr = document.getElementById('hdr')!;
const ham = document.getElementById('hdr-ham')!;
const drw = document.getElementById('drw')!;
const ov  = document.getElementById('drw-ov')!;
const cl  = document.getElementById('drw-cl')!;
window.addEventListener('scroll', () => hdr.classList.toggle('scrolled', scrollY > 40), {passive:true});
const open  = () => { drw.classList.add('open'); ov.classList.add('open'); ham.classList.add('open'); ham.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; };
const close = () => { drw.classList.remove('open'); ov.classList.remove('open'); ham.classList.remove('open'); ham.setAttribute('aria-expanded','false'); document.body.style.overflow=''; };
ham.addEventListener('click', () => drw.classList.contains('open') ? close() : open());
cl.addEventListener('click', close);
ov.addEventListener('click', close);
drw.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
