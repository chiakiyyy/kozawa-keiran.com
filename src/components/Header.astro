---
const nav = [
  { en: 'ABOUT',   ja: '私たちについて', href: '/about' },
  { en: 'NEWS',    ja: 'お知らせ',       href: '/news' },
  { en: 'LINE UP', ja: '商品紹介',       href: '/products' },
  { en: 'FEATURE', ja: 'こだわり',       href: '/feature' },
  { en: 'CONTACT', ja: 'お問い合わせ',   href: '/contact' },
];
const path = Astro.url.pathname;
---
<header class="hdr" id="hdr">
  <div class="hdr-in">
    <a href="/" class="hdr-logo">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
        <circle cx="18" cy="18" r="17" fill="#F7F5F1" stroke="#DDD6CC" stroke-width="1"/>
        <ellipse cx="18" cy="21" rx="9" ry="10" fill="#EDE5D0" stroke="#D9B55A" stroke-width="0.8"/>
        <ellipse cx="18" cy="15" rx="6" ry="7.5" fill="#E8D9B8" stroke="#D9B55A" stroke-width="0.8"/>
        <ellipse cx="15.5" cy="12.5" rx="2" ry="1.5" fill="white" opacity="0.5"/>
      </svg>
      <div>
        <span class="hdr-jp">小澤鶏卵</span>
        <span class="hdr-en">KOZAWA KEIRAN</span>
      </div>
    </a>

    <nav class="hdr-nav">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={path.startsWith(item.href) && item.href !== '/' ? 'act' : ''}>
              {item.ja}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr-right">
      <a href="/business" class="hdr-biz">法人の方</a>
      <a href="/contact" class="hdr-cta-btn">お問い合わせ</a>
    </div>

    <button class="hdr-ham" id="hdr-ham" aria-label="メニュー" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="drw-ov" id="drw-ov"></div>
<nav class="drw" id="drw" aria-hidden="true">
  <div class="drw-head">
    <span class="drw-title">小澤鶏卵</span>
    <button id="drw-cl" aria-label="閉じる">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 2l14 14M16 2L2 16" stroke="#2B2A28" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
  </div>
  <ul>
    {nav.map(item => (
      <li><a href={item.href}><span>{item.ja}</span><span class="d-en">{item.en}</span></a></li>
    ))}
    <li><a href="/business"><span>法人のお客様</span><span class="d-en">BUSINESS</span></a></li>
    <li><a href="/shop"><span>個人のお客様</span><span class="d-en">SHOP</span></a></li>
  </ul>
  <div class="drw-ft">
    <a href="tel:076-466-3815" class="drw-tel">076-466-3815</a>
    <p class="drw-hrs">月〜土 8:00〜17:00</p>
  </div>
</nav>

<style>
.hdr {
  position:fixed; top:0; left:0; right:0; z-index:200;
  background:rgba(247,245,241,0.97);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(12px);
  transition:box-shadow .3s;
}
.hdr.scrolled { box-shadow:0 2px 20px rgba(43,42,40,0.06); }
.hdr-in {
  max-width:1200px; margin:0 auto; padding:0 2.5rem;
  height:72px; display:flex; align-items:center; gap:2rem;
}
.hdr-logo { display:flex; align-items:center; gap:10px; text-decoration:none; flex-shrink:0; }
.hdr-jp { display:block; font-family:'Noto Serif JP',serif; font-size:1rem; font-weight:700; color:var(--heading); letter-spacing:.08em; line-height:1.2; }
.hdr-en { display:block; font-family:'Lato',sans-serif; font-size:.48rem; font-weight:400; color:var(--light); letter-spacing:.2em; margin-top:3px; }
.hdr-nav { flex:1; display:flex; justify-content:center; }
.hdr-nav ul { display:flex; gap:0; list-style:none; margin:0; padding:0; }
.hdr-nav a { display:block; padding:.5rem 1.1rem; text-decoration:none; font-size:.82rem; color:var(--body); letter-spacing:.04em; transition:color .15s; border-bottom:1.5px solid transparent; }
.hdr-nav a:hover,.hdr-nav a.act { color:var(--heading); border-bottom-color:var(--gold); }
.hdr-right { display:flex; align-items:center; gap:.75rem; flex-shrink:0; }
.hdr-biz { font-size:.78rem; color:var(--gray); text-decoration:none; letter-spacing:.04em; padding:.4rem .9rem; border:1px solid var(--border); border-radius:var(--radius-sm); transition:all .15s; }
.hdr-biz:hover { border-color:var(--gray); background:var(--bg-sub); }
.hdr-cta-btn { background:var(--gold); color:#fff; font-size:.78rem; font-weight:500; padding:.5rem 1.25rem; border-radius:var(--radius-sm); text-decoration:none; letter-spacing:.04em; transition:background .15s; }
.hdr-cta-btn:hover { background:var(--gold-dk); }
.hdr-ham { display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:4px; }
.hdr-ham span { display:block; width:20px; height:1px; background:var(--heading); transition:all .3s; }
.hdr-ham.open span:nth-child(1) { transform:translateY(6px) rotate(45deg); }
.hdr-ham.open span:nth-child(2) { opacity:0; }
.hdr-ham.open span:nth-child(3) { transform:translateY(-6px) rotate(-45deg); }
.drw-ov { display:none; position:fixed; inset:0; background:rgba(43,42,40,.35); z-index:300; backdrop-filter:blur(2px); }
.drw-ov.open { display:block; }
.drw { position:fixed; top:0; right:0; bottom:0; width:min(300px,88vw); background:var(--bg-white); z-index:400; border-left:1px solid var(--border); transform:translateX(100%); transition:transform .3s cubic-bezier(.25,.46,.45,.94); display:flex; flex-direction:column; overflow-y:auto; }
.drw.open { transform:translateX(0); }
.drw-head { display:flex; align-items:center; justify-content:space-between; padding:1.25rem 1.5rem; border-bottom:1px solid var(--border); }
.drw-title { font-family:'Noto Serif JP',serif; font-size:.95rem; font-weight:700; color:var(--heading); }
.drw-head button { background:none; border:none; cursor:pointer; padding:4px; }
.drw ul { list-style:none; margin:0; padding:.5rem 0; flex:1; }
.drw li { border-bottom:1px solid var(--border); }
.drw a { display:flex; align-items:center; justify-content:space-between; padding:.9rem 1.5rem; text-decoration:none; transition:background .15s; }
.drw a:hover { background:var(--bg-sub); }
.drw a span:first-child { font-size:.9rem; color:var(--heading); }
.d-en { font-family:'Lato',sans-serif; font-size:.58rem; letter-spacing:.14em; color:var(--gold); }
.drw-ft { padding:1.25rem 1.5rem; border-top:1px solid var(--border); background:var(--bg-sub); }
.drw-tel { display:block; font-family:'Lato',sans-serif; font-size:1.35rem; font-weight:300; color:var(--heading); text-decoration:none; letter-spacing:.04em; margin-bottom:.25rem; }
.drw-hrs { font-size:.73rem; color:var(--light); margin:0; }
@media (max-width:1024px) { .hdr-nav,.hdr-right { display:none; } .hdr-ham { display:flex; } }
@media (max-width:640px) { .hdr-in { padding:0 1.25rem; height:64px; } }
</style>

<script>
const hdr = document.getElementById('hdr')!;
const ham = document.getElementById('hdr-ham')!;
const drw = document.getElementById('drw')!;
const ov  = document.getElementById('drw-ov')!;
const cl  = document.getElementById('drw-cl')!;
window.addEventListener('scroll', () => hdr.classList.toggle('scrolled', scrollY > 40), {passive:true});
const open  = () => { drw.classList.add('open'); ov.classList.add('open'); ham.classList.add('open'); ham.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; };
const close = () => { drw.classList.remove('open'); ov.classList.remove('open'); ham.classList.remove('open'); ham.setAttribute('aria-expanded','false'); document.body.style.overflow=''; };
ham.addEventListener('click', () => drw.classList.contains('open') ? close() : open());
cl.addEventListener('click', close);
ov.addEventListener('click', close);
drw.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
