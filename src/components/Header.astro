---
const navItems = [
  { label: '私たちについて', en: 'ABOUT', href: '/company' },
  { label: '商品案内', en: 'PRODUCTS', href: '/products' },
  { label: 'こだわり', en: 'QUALITY', href: '/quality' },
  { label: 'よくある質問', en: 'Q&A', href: '/qa' },
  { label: 'お知らせ', en: 'NEWS', href: '/news' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <!-- ロゴ：鶏のイラスト＋テキスト -->
      <div class="logo-icon" aria-hidden="true">
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="22" r="21" fill="#FFF8C0" stroke="#F2C94C" stroke-width="1.5"/>
          <!-- 卵 -->
          <ellipse cx="22" cy="25" rx="10" ry="13" fill="#FAF5EC" stroke="#D4A017" stroke-width="1"/>
          <ellipse cx="22" cy="27" rx="5.5" ry="7" fill="#F2C94C" opacity="0.6"/>
          <!-- ニワトリ風 -->
          <circle cx="22" cy="14" r="5.5" fill="#F5E8C0" stroke="#C8A060" stroke-width="1"/>
          <ellipse cx="22" cy="18" rx="3" ry="1.5" fill="#F4A020"/>
          <ellipse cx="22" cy="10.5" rx="3" ry="2" fill="#E04040"/>
        </svg>
      </div>
      <div class="logo-text">
        <span class="logo-jp">小澤鶏卵</span>
        <span class="logo-en">OZAWA KEIRAN</span>
      </div>
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション">
      <ul>
        {navItems.map(item => (
          <li>
            <a href={item.href} class={currentPath.startsWith(item.href) ? 'active' : ''}>
              <span class="nav-jp">{item.label}</span>
              <span class="nav-en">{item.en}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/contact" class="header-contact-btn">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M1 5l7 5 7-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      お問い合わせ
    </a>

    <button class="hamburger" id="hamburger" aria-label="メニュー" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-overlay" id="mobile-overlay"></div>
  <nav class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <span class="logo-jp" style="font-size:1.15rem;color:#3A2A1A;letter-spacing:.08em">小澤鶏卵</span>
      <button id="drawer-close" aria-label="閉じる">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M4 4l14 14M18 4L4 18" stroke="#3A2A1A" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <ul>
      {navItems.map(item => (
        <li><a href={item.href}><span>{item.label}</span><span class="drawer-en">{item.en}</span></a></li>
      ))}
      <li><a href="/contact" class="drawer-contact">お問い合わせ</a></li>
    </ul>
    <div class="drawer-footer">
      <a href="tel:0000-00-0000" class="drawer-tel">0000-00-0000</a>
      <p>月〜土 8:00〜17:00</p>
    </div>
  </nav>
</header>

<style>
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  background-color: rgba(255,252,232,0.95);
  backdrop-filter: blur(10px);
  border-bottom: 2px solid #F2C94C;
  transition: box-shadow 0.3s;
}
.site-header.scrolled {
  box-shadow: 0 4px 20px rgba(90,154,80,0.12);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  height: 72px;
  display: flex;
  align-items: center;
  gap: 1.5rem;
}
.site-logo {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-text { display: flex; flex-direction: column; line-height: 1.2; }
.logo-jp {
  font-family: 'Zen Maru Gothic', sans-serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: #3A2A1A;
  letter-spacing: 0.06em;
}
.logo-en {
  font-family: 'Lato', sans-serif;
  font-size: 0.55rem;
  font-weight: 400;
  color: #7A6040;
  letter-spacing: 0.22em;
  margin-top: 1px;
}
.site-nav { flex: 1; display: flex; justify-content: center; }
.site-nav ul {
  display: flex;
  gap: 0;
  list-style: none;
  margin: 0; padding: 0;
}
.site-nav a {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0.4rem 0.9rem;
  text-decoration: none;
  border-radius: 8px;
  transition: background-color 0.15s;
  gap: 1px;
}
.site-nav a:hover, .site-nav a.active {
  background-color: rgba(242,201,76,0.18);
}
.nav-jp {
  font-size: 0.8rem;
  font-weight: 700;
  color: #3A2A1A;
  letter-spacing: 0.04em;
}
.nav-en {
  font-family: 'Lato', sans-serif;
  font-size: 0.55rem;
  letter-spacing: 0.18em;
  color: #5A9A50;
}
.header-contact-btn {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.55rem 1.25rem;
  background-color: #5A9A50;
  color: white;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  border-radius: 999px;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background-color 0.2s;
}
.header-contact-btn:hover { background-color: #3D7A34; }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  flex-shrink: 0;
}
.hamburger span {
  display: block;
  width: 24px;
  height: 2px;
  background: #3A2A1A;
  border-radius: 2px;
  transition: all 0.3s;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Overlay */
.mobile-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(58,42,26,0.45);
  z-index: 300;
  backdrop-filter: blur(2px);
}
.mobile-overlay.open { display: block; }

/* Drawer */
.mobile-drawer {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: min(300px, 82vw);
  background: #FFFCE8;
  z-index: 400;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
  display: flex;
  flex-direction: column;
  border-left: 2px solid #F2C94C;
}
.mobile-drawer.open { transform: translateX(0); }
.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid rgba(242,201,76,0.3);
}
.drawer-header button {
  background: none; border: none; cursor: pointer; padding: 4px;
}
.mobile-drawer ul {
  list-style: none; margin: 0; padding: 0.75rem 0; flex: 1;
}
.mobile-drawer li { border-bottom: 1px solid rgba(242,201,76,0.15); }
.mobile-drawer a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.9rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 700;
  color: #3A2A1A;
  text-decoration: none;
  transition: background-color 0.15s;
}
.mobile-drawer a:hover { background-color: rgba(242,201,76,0.15); }
.drawer-en {
  font-family: 'Lato', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  color: #5A9A50;
}
.drawer-contact {
  background-color: #5A9A50 !important;
  color: white !important;
  border-radius: 0;
  margin: 0.75rem 1rem;
  border-radius: 8px;
  justify-content: center !important;
}
.drawer-footer {
  padding: 1.25rem 1.5rem;
  border-top: 1px solid rgba(242,201,76,0.3);
  background-color: rgba(242,201,76,0.08);
}
.drawer-tel {
  display: block;
  font-family: 'Lato', sans-serif;
  font-size: 1.2rem;
  font-weight: 300;
  color: #3A2A1A;
  text-decoration: none;
  letter-spacing: 0.05em;
  margin-bottom: 0.2rem;
}
.drawer-footer p {
  font-size: 0.75rem;
  color: #7A6040;
  margin: 0;
}

@media (max-width: 1024px) {
  .site-nav { display: none; }
  .header-contact-btn { display: none; }
  .hamburger { display: flex; }
}
@media (max-width: 640px) {
  .header-inner { padding: 0 1rem; height: 62px; }
}
</style>

<script>
const header = document.getElementById('site-header')!;
const hamburger = document.getElementById('hamburger')!;
const drawer = document.getElementById('mobile-drawer')!;
const overlay = document.getElementById('mobile-overlay')!;
const closeBtn = document.getElementById('drawer-close')!;

window.addEventListener('scroll', () => {
  header.classList.toggle('scrolled', window.scrollY > 40);
}, { passive: true });

const open = () => {
  drawer.classList.add('open');
  overlay.classList.add('open');
  hamburger.classList.add('open');
  hamburger.setAttribute('aria-expanded', 'true');
  document.body.style.overflow = 'hidden';
};
const close = () => {
  drawer.classList.remove('open');
  overlay.classList.remove('open');
  hamburger.classList.remove('open');
  hamburger.setAttribute('aria-expanded', 'false');
  document.body.style.overflow = '';
};
hamburger.addEventListener('click', () => drawer.classList.contains('open') ? close() : open());
closeBtn.addEventListener('click', close);
overlay.addEventListener('click', close);
drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
