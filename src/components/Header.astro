---
const nav = [
  { en: 'ABOUT', ja: '私たちについて', href: '/about' },
  { en: 'NEWS', ja: 'お知らせ', href: '/news' },
  { en: 'LINE UP', ja: '商品紹介', href: '/products' },
  { en: 'FEATURE', ja: 'こだわり', href: '/feature' },
  { en: 'CONTACT', ja: 'お問い合わせ', href: '/contact' },
];
const path = Astro.url.pathname;
---

<header class="hdr" id="hdr">
  <div class="hdr-in">
    <!-- Logo -->
    <a href="/" class="hdr-logo">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <circle cx="20" cy="20" r="19" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1.5"/>
        <!-- 3つの卵 -->
        <ellipse cx="14" cy="24" rx="7" ry="9" fill="#FAF0DC" stroke="#D4A820" stroke-width="1"/>
        <ellipse cx="20" cy="22" rx="7.5" ry="9.5" fill="#FAF0DC" stroke="#D4A820" stroke-width="1"/>
        <ellipse cx="26" cy="24" rx="7" ry="9" fill="#FAF0DC" stroke="#D4A820" stroke-width="1"/>
        <ellipse cx="20" cy="17" rx="4" ry="5" fill="#F5B82E" opacity="0.5"/>
      </svg>
      <div>
        <span class="hdr-logo-jp">小澤鶏卵</span>
        <span class="hdr-logo-en">KOZAWA KEIRAN</span>
      </div>
    </a>

    <!-- Nav -->
    <nav class="hdr-nav">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={path.startsWith(item.href) && item.href !== '/' ? 'act' : ''}>
              <span class="nav-en">{item.en}</span>
              <span class="nav-ja">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA -->
    <a href="/contact" class="hdr-cta btn btn-primary">
      お問い合わせ
    </a>

    <!-- Hamburger -->
    <button class="hdr-ham" id="hdr-ham" aria-label="メニュー" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div class="drw-ov" id="drw-ov"></div>
<nav class="drw" id="drw" aria-hidden="true">
  <div class="drw-head">
    <span style="font-family:'Noto Serif JP',serif;font-size:1.1rem;font-weight:700;color:#3B321F;letter-spacing:.06em">小澤鶏卵</span>
    <button id="drw-cl" aria-label="閉じる">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 4l14 14M18 4L4 18" stroke="#3B321F" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>
  </div>
  <ul>
    {nav.map(item => (
      <li>
        <a href={item.href}>
          <span class="d-en">{item.en}</span>
          <span class="d-ja">{item.ja}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="drw-ft">
    <a href="/business" class="btn btn-green" style="justify-content:center">法人のお客様はこちら</a>
    <a href="tel:076-466-3815" class="drw-tel">076-466-3815</a>
    <p style="font-size:.75rem;color:#7A6A4A;margin:0">月〜土 8:00〜17:00</p>
  </div>
</nav>

<style>
.hdr {
  position: fixed; top:0; left:0; right:0; z-index:200;
  background: rgba(255,250,240,0.97);
  border-bottom: 2px solid #F5B82E;
  backdrop-filter: blur(10px);
  transition: box-shadow .3s;
}
.hdr.scrolled { box-shadow: 0 4px 20px rgba(59,50,31,.1); }
.hdr-in {
  max-width: 1200px; margin:0 auto; padding:0 2rem;
  height: 70px; display:flex; align-items:center; gap:1.5rem;
}
.hdr-logo {
  display:flex; align-items:center; gap:.6rem; text-decoration:none; flex-shrink:0;
}
.hdr-logo-jp {
  display:block; font-family:'Noto Serif JP',serif; font-size:1.1rem; font-weight:700;
  color:#3B321F; letter-spacing:.06em; line-height:1.2;
}
.hdr-logo-en {
  display:block; font-family:'Lato',sans-serif; font-size:.52rem; font-weight:400;
  color:#7A6A4A; letter-spacing:.2em; margin-top:1px;
}
.hdr-nav { flex:1; display:flex; justify-content:center; }
.hdr-nav ul { display:flex; gap:0; list-style:none; margin:0; padding:0; }
.hdr-nav a {
  display:flex; flex-direction:column; align-items:center;
  padding:.4rem .85rem; text-decoration:none; border-radius:8px;
  transition:background .15s; gap:2px;
}
.hdr-nav a:hover, .hdr-nav a.act { background:rgba(245,184,46,.15); }
.nav-en { font-family:'Lato',sans-serif; font-size:.72rem; font-weight:700; letter-spacing:.12em; color:#3B321F; }
.nav-ja { font-size:.6rem; color:#7A6A4A; letter-spacing:.06em; }
.hdr-cta { padding:.5rem 1.25rem; font-size:.78rem; }
.hdr-ham {
  display:none; flex-direction:column; gap:5px;
  background:none; border:none; cursor:pointer; padding:4px; flex-shrink:0;
}
.hdr-ham span { display:block; width:24px; height:2px; background:#3B321F; border-radius:2px; transition:all .3s; }
.hdr-ham.open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
.hdr-ham.open span:nth-child(2) { opacity:0; }
.hdr-ham.open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }
/* Overlay */
.drw-ov {
  display:none; position:fixed; inset:0;
  background:rgba(59,50,31,.45); z-index:300; backdrop-filter:blur(2px);
}
.drw-ov.open { display:block; }
/* Drawer */
.drw {
  position:fixed; top:0; right:0; bottom:0; width:min(300px,84vw);
  background:#FFFAF0; z-index:400; border-left:2px solid #F5B82E;
  transform:translateX(100%); transition:transform .35s cubic-bezier(.25,.46,.45,.94);
  display:flex; flex-direction:column; overflow-y:auto;
}
.drw.open { transform:translateX(0); }
.drw-head {
  display:flex; align-items:center; justify-content:space-between;
  padding:1.25rem 1.5rem; border-bottom:1px solid rgba(245,184,46,.25);
}
.drw-head button { background:none; border:none; cursor:pointer; padding:4px; }
.drw ul { list-style:none; margin:0; padding:.75rem 0; flex:1; }
.drw li { border-bottom:1px solid rgba(245,184,46,.15); }
.drw a {
  display:flex; align-items:center; justify-content:space-between;
  padding:.9rem 1.5rem; text-decoration:none; transition:background .15s;
}
.drw a:hover { background:rgba(245,184,46,.1); }
.d-en { font-family:'Lato',sans-serif; font-size:.7rem; font-weight:700; letter-spacing:.15em; color:#6F8F3A; }
.d-ja { font-size:.9rem; font-weight:700; color:#3B321F; }
.drw-ft { padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:.75rem; border-top:1px solid rgba(245,184,46,.2); background:rgba(255,243,192,.2); }
.drw-tel { font-family:'Lato',sans-serif; font-size:1.3rem; font-weight:300; color:#3B321F; text-decoration:none; letter-spacing:.05em; }
@media (max-width:1024px) { .hdr-nav,.hdr-cta { display:none; } .hdr-ham { display:flex; } }
@media (max-width:640px) { .hdr-in { padding:0 1rem; height:62px; } }
</style>

<script>
const hdr = document.getElementById('hdr')!;
const ham = document.getElementById('hdr-ham')!;
const drw = document.getElementById('drw')!;
const ov = document.getElementById('drw-ov')!;
const cl = document.getElementById('drw-cl')!;
window.addEventListener('scroll', () => hdr.classList.toggle('scrolled', scrollY > 40), {passive:true});
const open = () => { drw.classList.add('open'); ov.classList.add('open'); ham.classList.add('open'); ham.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; };
const close = () => { drw.classList.remove('open'); ov.classList.remove('open'); ham.classList.remove('open'); ham.setAttribute('aria-expanded','false'); document.body.style.overflow=''; };
ham.addEventListener('click', () => drw.classList.contains('open') ? close() : open());
cl.addEventListener('click', close);
ov.addEventListener('click', close);
drw.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
