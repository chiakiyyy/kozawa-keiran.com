---
const nav = [
  { en: 'ABOUT',   ja: '私たちについて', href: '/about' },
  { en: 'NEWS',    ja: 'お知らせ',       href: '/news' },
  { en: 'LINE UP', ja: '商品紹介',       href: '/products' },
  { en: 'FEATURE', ja: 'こだわり',       href: '/feature' },
  { en: 'CONTACT', ja: 'お問い合わせ',   href: '/contact' },
];
const path = Astro.url.pathname;
---

<header class="hdr" id="hdr">
  <div class="hdr-in">
    <a href="/" class="hdr-logo">
      <img src="/images/logo.png" alt="小澤鶏卵 KOZAWA KEIRAN" class="hdr-logo-img"/>
    </a>

    <nav class="hdr-nav" aria-label="メインナビゲーション">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={path.startsWith(item.href) ? 'act' : ''}>
              <span class="nav-en">{item.en}</span>
              <span class="nav-ja">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr-right">
      <a href="/business" class="hdr-biz">
        <span class="hdr-biz-dot"></span>法人のお客様
      </a>
      <a href="/contact" class="btn btn-primary hdr-cta">お問い合わせ</a>
    </div>

    <button class="hdr-ham" id="hdr-ham" aria-label="メニューを開く" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="drw-ov" id="drw-ov"></div>
<nav class="drw" id="drw" aria-label="ドロワーメニュー" aria-hidden="true">
  <div class="drw-head">
    <a href="/" class="drw-logo">
      <img src="/images/logo.png" alt="小澤鶏卵" style="height:36px;width:auto;"/>
    </a>
    <button id="drw-cl" aria-label="メニューを閉じる">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
        <path d="M3 3l14 14M17 3L3 17" stroke="#1E1E1C" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <ul>
    {nav.map(item => (
      <li>
        <a href={item.href}>
          <span class="d-en">{item.en}</span>
          <span class="d-ja">{item.ja}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="drw-ft">
    <a href="/business" class="btn btn-primary" style="justify-content:center">法人のお客様はこちら</a>
    <a href="tel:076-466-3815" class="drw-tel">076-466-3815</a>
    <p class="drw-hours">月〜土 8:00〜17:00</p>
  </div>
</nav>

<style>
.hdr {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  background: rgba(255,255,255,0.95);
  border-bottom: 0.5px solid rgba(44,44,42,0.08);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition: box-shadow .3s;
}
.hdr.scrolled { box-shadow: 0 4px 32px rgba(44,44,42,0.07); }
.hdr-in {
  max-width: 1200px; margin: 0 auto; padding: 0 2.5rem;
  height: 72px; display: flex; align-items: center; gap: 2rem;
}
.hdr-logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}
.hdr-logo-img {
  height: 44px;
  width: auto;
  display: block;
  object-fit: contain;
}
/* ナビ */
.hdr-nav { flex: 1; display: flex; justify-content: center; }
.hdr-nav ul { display: flex; list-style: none; margin: 0; padding: 0; gap: .25rem; }
.hdr-nav a {
  display: flex; flex-direction: column; align-items: center;
  padding: .5rem 1rem; text-decoration: none;
  border-radius: 10px; transition: background .18s; gap: 2px; position: relative;
}
.hdr-nav a::after {
  content: ''; position: absolute; bottom: 6px; left: 50%; transform: translateX(-50%);
  width: 0; height: 1.5px; background: var(--amber);
  border-radius: 2px; transition: width .22s;
}
.hdr-nav a:hover::after,
.hdr-nav a.act::after { width: 18px; }
.hdr-nav a:hover, .hdr-nav a.act { background: #FFF8EE; }
.nav-en { font-family: 'Lato', sans-serif; font-size: .66rem; font-weight: 700; letter-spacing: .13em; color: #1E1E1C; }
.nav-ja { font-size: .56rem; color: #9B9994; letter-spacing: .05em; }
/* 右側 */
.hdr-right { display: flex; align-items: center; gap: 1.25rem; flex-shrink: 0; }
.hdr-biz {
  display: flex; align-items: center; gap: .4rem;
  font-size: .78rem; color: #6B6A66; text-decoration: none; white-space: nowrap;
  transition: color .18s;
}
.hdr-biz:hover { color: var(--amber); }
.hdr-biz-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--amber-lt); flex-shrink: 0;
}
.hdr-cta { padding: .55rem 1.4rem; font-size: .78rem; }
/* ハンバーガー */
.hdr-ham {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px; flex-shrink: 0;
}
.hdr-ham span {
  display: block; width: 22px; height: 1.5px;
  background: #1E1E1C; border-radius: 2px; transition: all .3s;
}
.hdr-ham.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hdr-ham.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hdr-ham.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
/* ドロワー */
.drw-ov {
  display: none; position: fixed; inset: 0;
  background: rgba(30,30,28,0.45); z-index: 300;
  backdrop-filter: blur(3px);
}
.drw-ov.open { display: block; }
.drw {
  position: fixed; top: 0; right: 0; bottom: 0; width: min(300px,88vw);
  background: white; z-index: 400;
  border-left: 0.5px solid rgba(44,44,42,0.08);
  transform: translateX(100%); transition: transform .38s cubic-bezier(.25,.46,.45,.94);
  display: flex; flex-direction: column; overflow-y: auto;
}
.drw.open { transform: translateX(0); }
.drw-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 1.5rem; border-bottom: 0.5px solid rgba(44,44,42,0.08);
}
.drw-logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
.drw-head button {
  background: none; border: none; cursor: pointer; padding: 6px;
  border-radius: 8px; transition: background .15s;
}
.drw-head button:hover { background: #F4F2EB; }
.drw ul { list-style: none; margin: 0; padding: .5rem 0; flex: 1; }
.drw li { border-bottom: 0.5px solid rgba(44,44,42,0.05); }
.drw a {
  display: flex; align-items: center; justify-content: space-between;
  padding: .95rem 1.5rem; text-decoration: none; transition: background .15s;
}
.drw a:hover { background: #FAFAF7; }
.d-en { font-family: 'Lato', sans-serif; font-size: .6rem; font-weight: 700; letter-spacing: .18em; color: var(--amber); }
.d-ja { font-size: .88rem; font-weight: 500; color: #1E1E1C; }
.drw-ft {
  padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: .75rem;
  border-top: 0.5px solid rgba(44,44,42,0.08); background: #FAFAF7;
}
.drw-tel {
  font-family: 'Lato', sans-serif; font-size: 1.4rem; font-weight: 300;
  color: #1E1E1C; text-decoration: none; letter-spacing: .04em; text-align: center;
  transition: color .18s;
}
.drw-tel:hover { color: var(--amber); }
.drw-hours { font-size: .72rem; color: #9B9994; text-align: center; margin: 0; }

@media (max-width:1024px) { .hdr-nav, .hdr-right { display: none; } .hdr-ham { display: flex; } }
@media (max-width:640px) { .hdr-in { padding: 0 1.25rem; height: 64px; } }
</style>

<script>
const hdr = document.getElementById('hdr')!;
const ham = document.getElementById('hdr-ham')!;
const drw = document.getElementById('drw')!;
const ov  = document.getElementById('drw-ov')!;
const cl  = document.getElementById('drw-cl')!;

window.addEventListener('scroll', () => {
  hdr.classList.toggle('scrolled', scrollY > 40);
}, { passive: true });

const open  = () => {
  drw.classList.add('open'); ov.classList.add('open');
  ham.classList.add('open'); ham.setAttribute('aria-expanded', 'true');
  drw.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
};
const close = () => {
  drw.classList.remove('open'); ov.classList.remove('open');
  ham.classList.remove('open'); ham.setAttribute('aria-expanded', 'false');
  drw.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
};
ham.addEventListener('click', () => drw.classList.contains('open') ? close() : open());
cl.addEventListener('click', close);
ov.addEventListener('click', close);
drw.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
