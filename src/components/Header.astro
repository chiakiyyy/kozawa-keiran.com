---
const nav = [
  { en: 'ABOUT',   ja: '私たちについて', href: '/about' },
  { en: 'NEWS',    ja: 'お知らせ',       href: '/news' },
  { en: 'LINE UP', ja: '商品紹介',       href: '/products' },
  { en: 'FEATURE', ja: 'こだわり',       href: '/feature' },
  { en: 'FLOW',    ja: '出荷の流れ',     href: '/flow' },
];
const path = Astro.url.pathname;
---

<header class="hdr" id="hdr">
  <div class="hdr-in">
    <a href="/" class="hdr-logo">
      <img src="/images/icon.png" alt="" aria-hidden="true" class="hdr-logo-icon"/>
      <div>
        <span class="logo-jp">小澤鶏卵</span>
        <span class="logo-en">KOZAWA KEIRAN</span>
      </div>
    </a>

    <nav class="hdr-nav" aria-label="メインナビゲーション">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={path.startsWith(item.href) ? 'act' : ''}>
              <span class="nav-en">{item.en}</span>
              <span class="nav-ja">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr-contact">
      <a href="tel:076-466-3815" class="hdr-contact-btn">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 3.5C3 3.5 4.5 2 6 2c.5 0 1 .3 1.3.8l1.4 2.4c.3.5.2 1.1-.2 1.5L7.2 8c.8 1.5 2 2.8 3.5 3.6l1.3-1.3c.4-.4 1-.5 1.5-.2l2.4 1.4c.5.3.8.8.8 1.3 0 1.5-1.5 3-1.5 3C6 18 2 10 3 3.5z"/>
        </svg>
        <span class="hdr-contact-num">076-466-3815</span>
      </a>
      <a href="https://line.me/ti/p/@215bpskd" target="_blank" rel="noopener" class="hdr-contact-btn hdr-contact-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.070 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
        </svg>
        <span class="hdr-contact-label">LINE</span>
      </a>
      <a href="/contact" class="hdr-contact-btn hdr-contact-icon">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="16" height="12" rx="2"/>
          <path d="M2 7l8 5 8-5"/>
        </svg>
        <span class="hdr-contact-label">メール</span>
      </a>
    </div>

    <button class="hdr-ham" id="hdr-ham" aria-label="メニューを開く" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="drw-ov" id="drw-ov"></div>
<nav class="drw" id="drw" aria-label="ドロワーメニュー" aria-hidden="true">
  <div class="drw-head">
    <a href="/" class="drw-logo">
      <img src="/images/icon.png" alt="" aria-hidden="true" style="height:36px;width:auto;"/>
      <span class="logo-jp" style="font-size:.95rem;letter-spacing:.14em;">小澤鶏卵</span>
    </a>
    <button id="drw-cl" aria-label="メニューを閉じる">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
        <path d="M3 3l14 14M17 3L3 17" stroke="#1E1E1C" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <ul>
    {nav.map(item => (
      <li>
        <a href={item.href}>
          <span class="d-en">{item.en}</span>
          <span class="d-ja">{item.ja}</span>
        </a>
      </li>
    ))}
    <li><a href="/flow"><span class="d-en">FLOW</span><span class="d-ja">出荷の流れ</span></a></li>
    <li><a href="/contact"><span class="d-en">CONTACT</span><span class="d-ja">お問い合わせ</span></a></li>
    <li><a href="/business"><span class="d-en">BUSINESS</span><span class="d-ja">法人のお客様</span></a></li>
  </ul>
  <div class="drw-ft">
    <a href="tel:076-466-3815" class="drw-tel">076-466-3815</a>
    <p class="drw-hours">月〜土 8:00〜17:00</p>
  </div>
</nav>

<style>
.hdr {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  background: rgba(255,255,255,0.95);
  border-bottom: 0.5px solid rgba(44,44,42,0.08);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition: box-shadow .3s;
}
.hdr.scrolled { box-shadow: 0 4px 32px rgba(44,44,42,0.07); }
.hdr-in {
  max-width: 1450px; margin: 0 auto; padding: 0 2.5rem;
  height: 76px; display: flex; align-items: center; gap: 1rem;
}
.hdr-logo {
  display: flex; align-items: center; gap: .7rem;
  text-decoration: none; flex-shrink: 0;
}
.hdr-logo-icon { height: 44px; width: auto; display: block; object-fit: contain; }
.logo-jp {
  display: block; font-family: 'Zen Kaku Gothic New', sans-serif;
  font-size: 1.05rem; font-weight: 400; color: #2C2A24; letter-spacing: .18em; line-height: 1.2;
}
.logo-en {
  display: block; font-family: Manrope, sans-serif;
  font-size: .46rem; letter-spacing: .28em; color: #9B9994; margin-top: 4px;
}
/* ナビ */
.hdr-nav { flex: 1; display: flex; justify-content: flex-end; }
.hdr-nav ul { display: flex; list-style: none; margin: 0; padding: 0; gap: .35rem; }
.hdr-nav a {
  display: flex; flex-direction: column; align-items: center;
  padding: .6rem 1.1rem; text-decoration: none;
  border-radius: 10px; transition: background .18s; gap: 3px; position: relative;
}
.hdr-nav a::after {
  content: ''; position: absolute; bottom: 6px; left: 50%; transform: translateX(-50%);
  width: 0; height: 1.5px; background: #f6b937;
  border-radius: 2px; transition: width .22s;
}
.hdr-nav a:hover::after, .hdr-nav a.act::after { width: 18px; }
.hdr-nav a:hover, .hdr-nav a.act { background: #FFF8EE; }
.nav-en { font-family: Manrope, sans-serif; font-size: .78rem; font-weight: 700; letter-spacing: .1em; color: #1E1E1C; }
.nav-ja { font-size: .64rem; color: #9B9994; letter-spacing: .04em; }
/* コンタクトボタン群 */
.hdr-contact { display: flex; align-items: center; gap: .5rem; flex-shrink: 0; margin-left: .5rem; }
.hdr-contact-btn {
  display: inline-flex; align-items: center; gap: .4rem;
  padding: .45rem .9rem;
  background: transparent; color: #BA7517; border: 1.5px solid #BA7517;
  border-radius: 6px; text-decoration: none;
  font-family: Manrope, sans-serif; font-size: .78rem; font-weight: 700;
  letter-spacing: .03em; white-space: nowrap;
  transition: opacity .18s;
}
.hdr-contact-btn:hover { background: #FFF8EE; }
.hdr-contact-num { font-size: .82rem; letter-spacing: .06em; }
.hdr-contact-icon { padding: .45rem .75rem; }
.hdr-contact-label { font-size: .72rem; }
/* ハンバーガー */
.hdr-ham {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px; flex-shrink: 0;
}
.hdr-ham span { display: block; width: 22px; height: 1.5px; background: #1E1E1C; border-radius: 2px; transition: all .3s; }
.hdr-ham.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hdr-ham.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hdr-ham.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
/* ドロワー */
.drw-ov {
  display: none; position: fixed; inset: 0;
  background: rgba(30,30,28,0.45); z-index: 300; backdrop-filter: blur(3px);
}
.drw-ov.open { display: block; }
.drw {
  position: fixed; top: 0; right: 0; bottom: 0; width: min(300px,88vw);
  background: white; z-index: 400;
  border-left: 0.5px solid rgba(44,44,42,0.08);
  transform: translateX(100%); transition: transform .38s cubic-bezier(.25,.46,.45,.94);
  display: flex; flex-direction: column; overflow-y: auto;
}
.drw.open { transform: translateX(0); }
.drw-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 1.5rem; border-bottom: 0.5px solid rgba(44,44,42,0.08);
}
.drw-logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
.drw-head button { background: none; border: none; cursor: pointer; padding: 6px; border-radius: 8px; transition: background .15s; }
.drw-head button:hover { background: #F4F2EB; }
.drw ul { list-style: none; margin: 0; padding: .5rem 0; flex: 1; }
.drw li { border-bottom: 0.5px solid rgba(44,44,42,0.05); }
.drw a { display: flex; align-items: center; justify-content: space-between; padding: .95rem 1.5rem; text-decoration: none; transition: background .15s; }
.drw a:hover { background: #FAFAF7; }
.d-en { font-family: Manrope, sans-serif; font-size: .6rem; font-weight: 700; letter-spacing: .18em; color: #f6b937; }
.d-ja { font-size: .88rem; font-weight: 500; color: #1E1E1C; }
.drw-ft {
  padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: .75rem;
  border-top: 0.5px solid rgba(44,44,42,0.08); background: #FAFAF7;
}
.drw-tel { font-family: Manrope, sans-serif; font-size: 1.4rem; font-weight: 700; color: #1E1E1C; text-decoration: none; letter-spacing: .04em; text-align: center; transition: color .18s; }
.drw-tel:hover { color: #f6b937; }
.drw-hours { font-size: .72rem; color: #9B9994; text-align: center; margin: 0; }

@media (max-width:1100px) {
  .hdr-contact-num { display: none; }
  .hdr-contact-btn { padding: .45rem .65rem; }
}
@media (max-width:1024px) { .hdr-nav, .hdr-contact { display: none; } .hdr-ham { display: flex; } }
@media (max-width:640px) { .hdr-in { padding: 0 1.25rem; height: 64px; } }
</style>

<script>
const hdr = document.getElementById('hdr')!;
const ham = document.getElementById('hdr-ham')!;
const drw = document.getElementById('drw')!;
const ov  = document.getElementById('drw-ov')!;
const cl  = document.getElementById('drw-cl')!;

window.addEventListener('scroll', () => {
  hdr.classList.toggle('scrolled', scrollY > 40);
}, { passive: true });

const open  = () => {
  drw.classList.add('open'); ov.classList.add('open');
  ham.classList.add('open'); ham.setAttribute('aria-expanded', 'true');
  drw.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
};
const close = () => {
  drw.classList.remove('open'); ov.classList.remove('open');
  ham.classList.remove('open'); ham.setAttribute('aria-expanded', 'false');
  drw.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
};
ham.addEventListener('click', () => drw.classList.contains('open') ? close() : open());
cl.addEventListener('click', close);
ov.addEventListener('click', close);
drw.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
