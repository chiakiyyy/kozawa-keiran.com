---
const nav = [
  { en: 'ABOUT',   ja: '私たちについて', href: '/about' },
  { en: 'NEWS',    ja: 'お知らせ',       href: '/news' },
  { en: 'LINE UP', ja: '商品紹介',       href: '/products' },
  { en: 'FEATURE', ja: 'こだわり',       href: '/feature' },
  { en: 'CONTACT', ja: 'お問い合わせ',   href: '/contact' },
];
const path = Astro.url.pathname;
---

<header class="hdr" id="hdr">
  <div class="hdr-in">
    <a href="/" class="hdr-logo">
      <svg width="34" height="40" viewBox="0 0 34 42" fill="none" aria-hidden="true">
        <ellipse cx="17" cy="26" rx="15" ry="16" fill="#FAC775"/>
        <ellipse cx="17" cy="16" rx="10" ry="13" fill="#EF9F27"/>
        <ellipse cx="13" cy="10" rx="4" ry="3" fill="white" opacity="0.3"/>
      </svg>
      <div>
        <span class="logo-jp">小澤鶏卵</span>
        <span class="logo-en">KOZAWA KEIRAN</span>
      </div>
    </a>

    <nav class="hdr-nav">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={path.startsWith(item.href) ? 'act' : ''}>
              <span class="nav-en">{item.en}</span>
              <span class="nav-ja">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr-right">
      <a href="/business" class="hdr-biz">法人のお客様</a>
      <a href="/contact" class="btn btn-primary hdr-cta">お問い合わせ</a>
    </div>

    <button class="hdr-ham" id="hdr-ham" aria-label="メニュー" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="drw-ov" id="drw-ov"></div>
<nav class="drw" id="drw" aria-hidden="true">
  <div class="drw-head">
    <span class="logo-jp" style="font-size:1rem">小澤鶏卵</span>
    <button id="drw-cl" aria-label="閉じる">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 3l14 14M17 3L3 17" stroke="#2C2C2A" stroke-width="1.6" stroke-linecap="round"/></svg>
    </button>
  </div>
  <ul>
    {nav.map(item => (
      <li>
        <a href={item.href}>
          <span class="d-en">{item.en}</span>
          <span class="d-ja">{item.ja}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="drw-ft">
    <a href="/business" class="btn btn-primary" style="justify-content:center">法人のお客様はこちら</a>
    <a href="tel:076-466-3815" class="drw-tel">076-466-3815</a>
    <p style="font-size:.72rem;color:#888780;margin:0">月〜土 8:00〜17:00</p>
  </div>
</nav>

<style>
.hdr {
  position: fixed; top:0; left:0; right:0; z-index:200;
  background: rgba(255,255,255,0.96);
  border-bottom: 0.5px solid rgba(44,44,42,0.1);
  backdrop-filter: blur(12px);
  transition: box-shadow .3s;
}
.hdr.scrolled { box-shadow: 0 4px 24px rgba(44,44,42,0.08); }
.hdr-in {
  max-width: 1200px; margin: 0 auto; padding: 0 2rem;
  height: 72px; display: flex; align-items: center; gap: 2rem;
}
.hdr-logo {
  display: flex; align-items: center; gap: .75rem;
  text-decoration: none; flex-shrink: 0;
}
.logo-jp {
  display: block; font-family: 'Noto Serif JP', serif;
  font-size: 1.05rem; font-weight: 700; color: #2C2C2A;
  letter-spacing: .05em; line-height: 1.2;
}
.logo-en {
  display: block; font-family: 'Lato', sans-serif;
  font-size: .48rem; letter-spacing: .2em; color: #888780; margin-top: 2px;
}
.hdr-nav { flex: 1; display: flex; justify-content: center; }
.hdr-nav ul { display: flex; list-style: none; margin: 0; padding: 0; }
.hdr-nav a {
  display: flex; flex-direction: column; align-items: center;
  padding: .4rem .9rem; text-decoration: none;
  border-radius: var(--radius-sm); transition: background .15s; gap: 2px;
}
.hdr-nav a:hover, .hdr-nav a.act { background: #FAEEDA; }
.nav-en { font-family: 'Lato', sans-serif; font-size: .68rem; font-weight: 700; letter-spacing: .12em; color: #2C2C2A; }
.nav-ja { font-size: .58rem; color: #888780; letter-spacing: .05em; }
.hdr-right { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
.hdr-biz { font-size: .78rem; color: #5F5E5A; text-decoration: none; white-space: nowrap; }
.hdr-biz:hover { color: #BA7517; }
.hdr-cta { padding: .55rem 1.25rem; font-size: .78rem; }
.hdr-ham {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px; flex-shrink: 0;
}
.hdr-ham span { display: block; width: 22px; height: 1.5px; background: #2C2C2A; border-radius: 2px; transition: all .3s; }
.hdr-ham.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hdr-ham.open span:nth-child(2) { opacity: 0; }
.hdr-ham.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.drw-ov {
  display: none; position: fixed; inset: 0;
  background: rgba(44,44,42,0.4); z-index: 300; backdrop-filter: blur(2px);
}
.drw-ov.open { display: block; }
.drw {
  position: fixed; top: 0; right: 0; bottom: 0; width: min(300px,86vw);
  background: white; z-index: 400; border-left: 0.5px solid rgba(44,44,42,0.1);
  transform: translateX(100%); transition: transform .35s cubic-bezier(.25,.46,.45,.94);
  display: flex; flex-direction: column; overflow-y: auto;
}
.drw.open { transform: translateX(0); }
.drw-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 1.5rem; border-bottom: 0.5px solid rgba(44,44,42,0.1);
}
.drw-head button { background: none; border: none; cursor: pointer; padding: 4px; }
.drw ul { list-style: none; margin: 0; padding: .5rem 0; flex: 1; }
.drw li { border-bottom: 0.5px solid rgba(44,44,42,0.06); }
.drw a {
  display: flex; align-items: center; justify-content: space-between;
  padding: .875rem 1.5rem; text-decoration: none; transition: background .15s;
}
.drw a:hover { background: #FAFAF8; }
.d-en { font-family: 'Lato', sans-serif; font-size: .65rem; font-weight: 700; letter-spacing: .15em; color: #BA7517; }
.d-ja { font-size: .88rem; font-weight: 500; color: #2C2C2A; }
.drw-ft { padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: .75rem; border-top: 0.5px solid rgba(44,44,42,0.08); background: #FAFAF8; }
.drw-tel { font-family: 'Lato', sans-serif; font-size: 1.3rem; font-weight: 300; color: #2C2C2A; text-decoration: none; letter-spacing: .04em; }
@media (max-width:1024px) { .hdr-nav, .hdr-right { display: none; } .hdr-ham { display: flex; } }
@media (max-width:640px) { .hdr-in { padding: 0 1rem; height: 64px; } }
</style>

<script>
const hdr = document.getElementById('hdr')!;
const ham = document.getElementById('hdr-ham')!;
const drw = document.getElementById('drw')!;
const ov  = document.getElementById('drw-ov')!;
const cl  = document.getElementById('drw-cl')!;
window.addEventListener('scroll', () => hdr.classList.toggle('scrolled', scrollY > 40), {passive:true});
const open  = () => { drw.classList.add('open'); ov.classList.add('open'); ham.classList.add('open'); ham.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; };
const close = () => { drw.classList.remove('open'); ov.classList.remove('open'); ham.classList.remove('open'); ham.setAttribute('aria-expanded','false'); document.body.style.overflow=''; };
ham.addEventListener('click', () => drw.classList.contains('open') ? close() : open());
cl.addEventListener('click', close);
ov.addEventListener('click', close);
drw.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
