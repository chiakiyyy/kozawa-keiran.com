---
const navItems = [
  { label: '小澤鶏卵について', href: '/#about' },
  { label: '商品案内', href: '/products' },
  { label: '品質へのこだわり', href: '/quality' },
  { label: '会社概要', href: '/company' },
  { label: 'お問い合わせ', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo" aria-label="小澤鶏卵 ホームへ">
      <span class="logo-main">小澤鶏卵</span>
      <span class="logo-sub">OZAWA KEIRAN</span>
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={currentPath === item.href ? 'active' : ''}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {navItems.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(250, 247, 242, 0.96);
    backdrop-filter: blur(4px);
    border-bottom: 1px solid rgba(61, 43, 31, 0.08);
    transition: box-shadow 0.2s ease;
  }

  .site-header.scrolled {
    box-shadow: 0 2px 16px rgba(61, 43, 31, 0.08);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-main {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-dark-brown);
    letter-spacing: 0.05em;
  }

  .logo-sub {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 300;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    margin-top: 1px;
  }

  .site-nav ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 2px;
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-egg-yellow);
    transition: width 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--color-dark-brown);
  }

  .site-nav a:hover::after,
  .site-nav a.active::after {
    width: 100%;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 1px;
    background-color: var(--color-dark-brown);
    transition: all 0.3s ease;
  }

  .hamburger.open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-nav {
    display: none;
    background-color: var(--color-ivory);
    border-top: 1px solid rgba(61, 43, 31, 0.08);
    padding: 1rem 2rem 1.5rem;
  }

  .mobile-nav.open {
    display: block;
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav li {
    border-bottom: 1px solid rgba(61, 43, 31, 0.06);
  }

  .mobile-nav a {
    display: block;
    padding: 0.875rem 0;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  @media (max-width: 900px) {
    .site-nav {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    mobileNav?.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });
</script>
