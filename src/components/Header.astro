---
const navItems = [
  { label: '小澤鶏卵について', href: '/#about' },
  { label: '商品案内', href: '/products' },
  { label: '品質へのこだわり', href: '/quality' },
  { label: '会社概要', href: '/company' },
  { label: 'お問い合わせ', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isTop = currentPath === '/';
---

<header class={`site-header ${isTop ? 'is-top' : 'is-page'}`} id="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo" aria-label="小澤鶏卵 ホームへ">
      <span class="logo-jp">小澤鶏卵</span>
      <span class="logo-en">OZAWA KEIRAN</span>
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={currentPath === item.href ? 'active' : ''}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/contact" class="header-cta">お問い合わせ</a>

    <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>
  <nav class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
    <div class="mobile-drawer-header">
      <span class="mobile-logo-jp">小澤鶏卵</span>
      <button class="mobile-close" id="mobile-close" aria-label="メニューを閉じる">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M3 3l14 14M17 3L3 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <ul>
      {navItems.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
    <div class="mobile-drawer-footer">
      <a href="tel:0000-00-0000" class="mobile-tel">0000-00-0000</a>
      <p class="mobile-hours">月〜土 8:00〜17:00</p>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    transition: background-color 0.35s ease, box-shadow 0.35s ease;
  }

  /* トップページ: 最初は透明 */
  .site-header.is-top {
    background-color: transparent;
  }

  /* トップ以外のページ: 常に白背景 */
  .site-header.is-page {
    background-color: rgba(250, 247, 242, 0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(61, 43, 31, 0.07);
  }

  /* スクロール後 */
  .site-header.scrolled {
    background-color: rgba(250, 247, 242, 0.97) !important;
    backdrop-filter: blur(8px);
    box-shadow: 0 1px 24px rgba(61, 43, 31, 0.07);
    border-bottom: 1px solid rgba(61, 43, 31, 0.07);
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .site-logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }
  .site-logo:hover { opacity: 0.75; }

  .logo-jp {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--color-dark-brown);
    letter-spacing: 0.08em;
    transition: color 0.35s ease;
  }

  .logo-en {
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 300;
    color: var(--color-text-muted);
    letter-spacing: 0.22em;
    margin-top: 2px;
    transition: color 0.35s ease;
  }

  /* トップ・未スクロール時はロゴを白に */
  .site-header.is-top:not(.scrolled) .logo-jp {
    color: var(--color-ivory);
  }
  .site-header.is-top:not(.scrolled) .logo-en {
    color: rgba(250, 247, 242, 0.6);
  }

  /* Nav */
  .site-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .site-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav a {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.75rem;
    position: relative;
    transition: color 0.2s ease;
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 1px;
    background-color: var(--color-egg-yellow);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--color-dark-brown);
  }

  .site-nav a:hover::after,
  .site-nav a.active::after {
    transform: scaleX(1);
  }

  /* トップ未スクロール: ナビも白 */
  .site-header.is-top:not(.scrolled) .site-nav a {
    color: rgba(250, 247, 242, 0.75);
  }
  .site-header.is-top:not(.scrolled) .site-nav a:hover {
    color: var(--color-ivory);
  }

  /* CTA button */
  .header-cta {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--color-dark-brown);
    color: var(--color-dark-brown);
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .header-cta:hover {
    background-color: var(--color-dark-brown);
    color: var(--color-ivory);
  }

  /* トップ未スクロール: CTAも白枠 */
  .site-header.is-top:not(.scrolled) .header-cta {
    border-color: rgba(250, 247, 242, 0.6);
    color: var(--color-ivory);
  }
  .site-header.is-top:not(.scrolled) .header-cta:hover {
    background-color: rgba(250, 247, 242, 0.15);
    border-color: var(--color-ivory);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }

  .hamburger span {
    display: block;
    width: 26px;
    height: 1px;
    background-color: var(--color-dark-brown);
    transition: all 0.3s ease;
  }

  .site-header.is-top:not(.scrolled) .hamburger span {
    background-color: var(--color-ivory);
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile Overlay */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background-color: rgba(30, 21, 14, 0.5);
    z-index: 300;
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.open {
    display: block;
    opacity: 1;
  }

  /* Mobile Drawer */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background-color: var(--color-ivory);
    z-index: 400;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .mobile-drawer.open {
    transform: translateX(0);
  }

  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid rgba(61, 43, 31, 0.08);
  }

  .mobile-logo-jp {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-dark-brown);
    letter-spacing: 0.08em;
  }

  .mobile-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 4px;
  }

  .mobile-drawer ul {
    list-style: none;
    margin: 0;
    padding: 1rem 0;
    flex: 1;
  }

  .mobile-drawer li {
    border-bottom: 1px solid rgba(61, 43, 31, 0.05);
  }

  .mobile-drawer a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.75rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: background-color 0.15s, padding-left 0.2s;
  }

  .mobile-drawer a::after {
    content: '→';
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-4px);
  }

  .mobile-drawer a:hover {
    background-color: rgba(61, 43, 31, 0.03);
    padding-left: 2rem;
  }

  .mobile-drawer a:hover::after {
    opacity: 1;
    transform: translateX(0);
  }

  .mobile-drawer-footer {
    padding: 1.5rem 1.75rem;
    border-top: 1px solid rgba(61, 43, 31, 0.08);
    background-color: var(--color-cream);
  }

  .mobile-tel {
    display: block;
    font-family: 'Lato', sans-serif;
    font-size: 1.35rem;
    font-weight: 300;
    color: var(--color-dark-brown);
    text-decoration: none;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .mobile-hours {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .site-nav { display: none; }
    .header-cta { display: none; }
    .hamburger { display: flex; }
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 0 1.25rem;
      height: 64px;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header') as HTMLElement;
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const drawer = document.getElementById('mobile-drawer') as HTMLElement;
  const overlay = document.getElementById('mobile-overlay') as HTMLElement;
  const closeBtn = document.getElementById('mobile-close') as HTMLButtonElement;

  // Scroll: transparent → solid
  const handleScroll = () => {
    if (window.scrollY > 60) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Drawer open/close
  const openDrawer = () => {
    drawer.classList.add('open');
    overlay.classList.add('open');
    hamburger.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeDrawer = () => {
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    hamburger.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  hamburger.addEventListener('click', () => {
    drawer.classList.contains('open') ? closeDrawer() : openDrawer();
  });

  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  // Close drawer on nav link click
  drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));
</script>
