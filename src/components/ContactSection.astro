---
interface Props {
  title?: string;
  lead?: string;
}
const {
  title = 'ご注文・ご相談はお気軽に',
  lead = 'まずはお電話・LINE・フォームのいずれかでお気軽にご連絡ください',
} = Astro.props;
---
<section class="cta-sec">
  <div class="container" style="text-align:center">
    <span class="sec-label" style="justify-content:center;display:flex;">CONTACT</span>
    <h2 class="sec-title" style="margin:.5rem 0 1rem">{title}</h2>
    <p style="color:var(--muted);font-size:.9rem;margin-bottom:3rem">{lead}</p>
    <div class="contact-methods">
      <div class="method-card">
        <div class="method-icon">
          <svg width="26" height="26" viewBox="0 0 20 20" fill="none" stroke="#BA7517" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3.5C3 3.5 4.5 2 6 2c.5 0 1 .3 1.3.8l1.4 2.4c.3.5.2 1.1-.2 1.5L7.2 8c.8 1.5 2 2.8 3.5 3.6l1.3-1.3c.4-.4 1-.5 1.5-.2l2.4 1.4c.5.3.8.8.8 1.3 0 1.5-1.5 3-1.5 3C6 18 2 10 3 3.5z"/>
          </svg>
        </div>
        <h3>お電話</h3>
        <a href="tel:076-466-3815" class="method-tel">076-466-3815</a>
        <p>月〜土 8:00〜17:00</p>
        <a href="tel:076-466-3815" class="method-btn">電話をかける</a>
      </div>
      <div class="method-card method-card--line">
        <div class="method-icon method-icon--line">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="white">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.070 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
        </div>
        <h3>LINE</h3>
        <p class="method-line-id">@215bpskd</p>
        <p>お気軽にメッセージください</p>
        <a href="https://line.me/ti/p/@215bpskd" target="_blank" rel="noopener" class="method-btn method-btn--line">LINEで相談する</a>
      </div>
      <div class="method-card">
        <div class="method-icon">
          <svg width="26" height="26" viewBox="0 0 20 20" fill="none" stroke="#BA7517" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="16" height="12" rx="2"/>
            <path d="M2 7l8 5 8-5"/>
          </svg>
        </div>
        <h3>お問い合わせフォーム</h3>
        <p class="method-email">info@kozawa-keiran.com</p>
        <p>24時間受付・翌営業日返信</p>
        <a href="/contact" class="method-btn">フォームを開く</a>
      </div>
    </div>
  </div>
</section>
<style>
.cta-sec { background:#FDF6E9; padding:6rem 0; border-top:1px solid rgba(186,117,23,0.1); }
.contact-methods { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; max-width:980px; margin:0 auto; }
.method-card { background:white; border-radius:16px; padding:2.5rem 1.75rem; text-align:center; box-shadow:0 4px 20px rgba(59,50,31,.08); border-top:3px solid #BA7517; display:flex; flex-direction:column; align-items:center; }
.method-card--line { border-top-color:#06C755; }
.method-icon { width:60px; height:60px; background:#FDF6E9; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; }
.method-icon--line { background:#06C755; }
.method-card h3 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:1rem; font-weight:700; color:#2C2A24; margin-bottom:.625rem; }
.method-tel { display:block; font-family:Manrope,sans-serif; font-size:1.6rem; font-weight:700; color:#2C2A24; text-decoration:none; letter-spacing:.04em; margin-bottom:.35rem; }
.method-line-id { font-family:Manrope,sans-serif; font-size:1.3rem; font-weight:700; color:#06C755; margin:0 0 .35rem; }
.method-email { display:block; font-size:.85rem; color:#BA7517; text-decoration:none; margin-bottom:.35rem; word-break:break-all; }
.method-card p { font-size:.78rem; color:#6B6860; margin:0 0 1.25rem; }
.method-btn {
  display:inline-flex; align-items:center; justify-content:center; width:100%;
  padding:.75rem 1rem; border-radius:8px; text-decoration:none;
  font-size:.85rem; font-weight:700; letter-spacing:.02em;
  background:#BA7517; color:white; margin-top:auto; transition:opacity .15s;
}
.method-btn:hover { opacity:.85; }
.method-btn--line { background:#06C755; }
@media (max-width:900px) {
  .contact-methods { grid-template-columns:1fr; max-width:420px; }
}
</style>
