---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LineButton from '../components/LineButton.astro';

const LINE_URL = 'https://line.me/ti/p/@215bpskd';
const SITE_URL = 'https://kozawa-keiran.com';
const OG_IMG   = `${SITE_URL}/images/shop/og-shop.jpg`;

const worries = [
  { pos:'0%',    text:'子どもに安心できる\n食材を選びたい' },
  { pos:'33.3%', text:'毎日の朝食を\nちゃんとしたい' },
  { pos:'66.6%', text:'スーパーの卵との\n違いを知りたい' },
  { pos:'100%',  text:'離乳食や幼児食に\n使う卵を選びたい' },
];

const points = [
  { num:'01', title:'富山の自然',       body:'澄んだ水と空気、豊かな自然環境に恵まれた富山で、健康な鶏を育てています。', img:'/images/shop/point1.jpg' },
  { num:'02', title:'平飼いで育った鶏', body:'のびのびと平飼いで育つ環境だから、自然な形で健康な鶏に育ちます。',         img:'/images/feature/feature-chicken.jpg' },
  { num:'03', title:'健康的な餌',       body:'鶏の健康を第一に考えた餌を与え、安全第一に考えています。',                 img:'/images/shop/point3.jpg' },
  { num:'04', title:'チルド配送',       body:'採れたての鮮度をチルド（冷蔵）でそのままお届けしています。',                img:'/images/shop/point4.jpg' },
  { num:'05', title:'生産者の顔が見える', body:'家族に食べさせたい卵を、責任をもってお届けしています。',                  img:'/images/shop/point5.jpg' },
];

const nutrients = [
  { icon:'💪', title:'良質なたんぱく質',       body:'体をつくる土台となるたんぱく質をバランスよく含んでいます。' },
  { icon:'🧠', title:'コリン・レシチン',       body:'卵黄に含まれるコリンやレシチンは、学習や記憶に関わる栄養素です。' },
  { icon:'🌱', title:'成長期の体づくりをサポート', body:'成長期の子どもに必要な栄養を、毎日の食事で手軽にとれます。' },
  { icon:'🍼', title:'離乳食・幼児食にも使いやすい', body:'やさしい味わいで、いろいろな料理に使いやすい食材です。' },
  { icon:'😋', title:'シンプルでもおいしい',   body:'素材が良いから、シンプルな料理でもおいしく食べられます。' },
  { icon:'✨', title:'食への興味・関心につながる', body:'おいしい体験が、子どもの食への興味や「食べる力」を育みます。' },
];

const products = [
  {
    id:'egg20', badge:null, img:'/images/shop/product1.jpg',
    name:'平飼い卵 20個', price:'2,980円（税込・送料込み）',
    lead:'まずはシンプルに、鮮度そのものの\nおいしさを確かめてください。',
    contents: null,
  },
  {
    id:'egg-soy', badge:null, img:'/images/shop/product2.jpg',
    name:'平飼い卵 20個\n＋卵かけご飯醤油', price:'3,500円（税込・送料込み）',
    lead:'卵かけご飯専用の醤油がついた、\n卵の美味しさが引き立つセットです。',
    contents: null,
  },
  {
    id:'morning', badge:'おすすめ', img:'/images/shop/product3.jpg',
    name:'富山の朝ごはんセット', price:'5,000円（税込・送料込み）',
    lead:'富山のおいしいものを詰め合わせた、特別な朝ごはん体験セットです。',
    contents: ['平飼い卵 20個（10個×2パック）','卵かけご飯醤油 1本（150ml）','富山県産米 富富富 2合（300g）','富山の味 お漬物・味噌汁の素（例）'],
  },
];

const reviews = [
  { name:'S.さん（富山市・30代・お子さま2人）', img:'/images/shop/review1.jpg', text:'子どもが「この卵おいしい！」と言って食べてくれます。卵かけご飯が食卓の楽しみになりました！', stars:5 },
  { name:'K.さん（高岡市・40代・お子さま1人）', img:'/images/shop/review2.jpg', text:'卵かけご飯が大好きになって、朝ごはんが楽しみになりました！黄身の濃さが全然違います。', stars:5 },
  { name:'M.さん（射水市・30代・お子さま1人）', img:'/images/shop/review3.jpg', text:'離乳食にも安心して使えるので、本当に助かっています。生産者さんの顔が見えるのも安心。', stars:5 },
];

const faqs = [
  { q:'配送料について教えてください',       a:'商品価格に送料を含んでいます。別途送料はかかりません。' },
  { q:'お支払い方法はありますか？',         a:'クレジットカード（Square決済）をご利用いただけます。LINEでのご相談後にご案内します。' },
  { q:'定期便はいつでも停止できますか？',   a:'はい、いつでも停止・再開できます。縛りや解約手数料は一切ありません。' },
  { q:'卵は生で食べても大丈夫ですか？',     a:'新鮮な状態でお届けしていますが、適切な保管・加熱をお勧めします。' },
  { q:'卵が割れていた場合はどうすればいいですか？', a:'お届け時に割れがあった場合は、写真をLINEにお送りください。すぐに対応いたします。' },
  { q:'離乳食に使っても大丈夫ですか？',     a:'赤ちゃんの月齢や体調、アレルギーに配慮し、必要に応じて医師や専門家にご相談のうえご使用ください。' },
];

const jsonLd = {
  "@context":"https://schema.org","@type":"Product",
  "name":"小澤鶏卵場 富山の平飼い朝どれ卵",
  "description":"富山の自然で育った平飼い卵。子どもにも安心して食べさせたい朝食を提案。",
  "brand":{"@type":"Brand","name":"小澤鶏卵場"},
  "offers":{"@type":"Offer","price":"2980","priceCurrency":"JPY","availability":"https://schema.org/InStock","url":`${SITE_URL}/shop/`}
};
---
<Layout
  title="子どもに食べさせたい卵があります｜富山の平飼い卵・小澤鶏卵場"
  description="富山の自然で育った平飼い卵を家族の朝ごはんに。チルド配送・生産者直送・定期便あり。30〜40代の子育て家族に選ばれる小澤鶏卵場の卵をLINEでご注文・ご相談ください。"
>
  <meta slot="head" property="og:title"       content="子どもに食べさせたい卵があります｜小澤鶏卵場"/>
  <meta slot="head" property="og:description" content="富山の平飼い・朝どれ卵。家族の朝ごはんに。チルド配送・縛りなし定期便。"/>
  <meta slot="head" property="og:image"       content={OG_IMG}/>
  <meta slot="head" property="og:url"         content={`${SITE_URL}/shop/`}/>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <!-- LP専用ヘッダーナビ -->
  <Header/>
  <div class="lp-subnav">
    <div class="lp-subnav-in">
      <a href="#reasons">こだわり</a>
      <a href="#health">健康のこと</a>
      <a href="#products">商品一覧</a>
      <a href="#morning-set">朝ごはんセット</a>
      <a href="#subscription">定期便</a>
      <a href="#reviews">お客様の声</a>
      <a href="#faq">よくある質問</a>
    </div>
    <a href={LINE_URL} target="_blank" rel="noopener" class="lp-subnav-cta">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.07 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
      LINEで注文・相談する
    </a>
  </div>

  <main>

    <!-- ① HERO -->
    <section id="hero" class="lp-hero">
      <div class="lp-hero-inner">
        <div class="lp-hero-text">
          <span class="lp-brand-label">小澤鶏卵場<br/><small>富山の平飼い卵</small></span>
          <h1>子どもに<br/>食べさせたい<br/>卵があります。</h1>
          <p>富山の自然で育った平飼い卵を、<br/>家族の朝ごはんに。</p>
          <a href={LINE_URL} target="_blank" rel="noopener" class="lp-line-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.07 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            LINEで注文・相談する
          </a>
        </div>
        <div class="lp-hero-photo">
          <img src="/images/shop/hero-family.jpg" alt="家族の朝ごはん" loading="eager"/>
          <div class="lp-hero-photo-fade"></div>
        </div>
      </div>
      <div class="lp-hero-deco-leaf lp-hero-deco-leaf--l">🌿</div>
      <div class="lp-hero-deco-leaf lp-hero-deco-leaf--r">🌿</div>
    </section>

    <!-- ② お悩み -->
    <section class="lp-sec bg-white">
      <div class="lp-container">
        <h2 class="lp-sec-title">こんなお悩みありませんか？</h2>
        <div class="lp-worries-grid">
          {worries.map(w => (
            <div class="lp-worry-card">
              <div class="lp-worry-icon">
                <img src="/images/shop/worries-icons.png" alt=""
                  style={`width:400%;margin-left:-${w.pos};height:100%;object-fit:cover;display:block`}/>
              </div>
              <p>{w.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ③ 選ばれる理由 -->
    <section id="reasons" class="lp-sec lp-sec--cream">
      <div class="lp-container">
        <div class="lp-reasons-layout">
          <div class="lp-reasons-head">
            <div class="lp-deco-chick">🐣</div>
            <h2>小澤鶏卵場の卵が<br/>選ばれる理由</h2>
            <div class="lp-deco-chick">🐣</div>
          </div>
          <div class="lp-points-row">
            {points.map(p => (
              <div class="lp-point-item">
                <div class="lp-point-img">
                  <img src={p.img} alt={p.title} loading="lazy"/>
                </div>
                <p class="lp-point-num">{p.num}</p>
                <p class="lp-point-title">{p.title}</p>
                <p class="lp-point-body">{p.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 健康メリット -->
    <section id="health" class="lp-sec bg-white">
      <div class="lp-container">
        <div class="lp-health-layout">
          <div class="lp-health-text">
            <h2>毎日の卵を、<br/>ちゃんと選ぶ理由。</h2>
            <p class="lp-health-lead">卵は「完全栄養食品」と呼ばれるほど<br/>栄養バランスに優れた食材。<br/>良い環境と餌で育った卵は、<br/>家族みんなの毎日を支えます。</p>
            <ul class="lp-nutrient-list">
              {nutrients.map(n => (
                <li>
                  <span class="lp-nutrient-icon">{n.icon}</span>
                  <div>
                    <strong>{n.title}</strong>
                    <span>{n.body}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div class="lp-health-photos">
            <div class="lp-health-photo">
              <img src="/images/shop/health-egg.jpg" alt="卵黄" loading="lazy"/>
            </div>
            <div class="lp-health-photo">
              <img src="/images/shop/health-baby.jpg" alt="離乳食" loading="lazy"/>
            </div>
            <p class="lp-health-note">※アレルギーや月齢に配慮し、必要に応じて医師や専門家にご相談ください。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ 商品一覧 -->
    <section id="products" class="lp-sec lp-sec--cream">
      <div class="lp-container">
        <div class="lp-sec-head-deco">
          <span>🌿</span><h2>商品一覧</h2><span>🌿</span>
        </div>
        <div class="lp-products-grid">
          {products.map(p => (
            <div class:list={["lp-product-card", { "lp-product-card--featured": p.badge }]} id={p.id === 'morning' ? 'morning-set' : ''}>
              {p.badge && <span class="lp-product-badge">{p.badge}</span>}
              <div class="lp-product-img">
                <img src={p.img} alt={p.name} loading="lazy"/>
              </div>
              <div class="lp-product-body">
                <h3>{p.name}</h3>
                <p class="lp-product-price">{p.price}</p>
                <p class="lp-product-lead">{p.lead}</p>
                {p.contents && (
                  <div class="lp-product-contents">
                    <p class="lp-product-contents-title">セット内容</p>
                    <ul>{p.contents.map(c => <li>＋ {c}</li>)}</ul>
                    <p class="lp-product-contents-note">※セット内容は変更になる場合があります</p>
                  </div>
                )}
                <a href={LINE_URL} target="_blank" rel="noopener" class="lp-product-btn">詳しく見る</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑥ 定期便 -->
    <section id="subscription" class="lp-subscription">
      <div class="lp-subscription-bg">
        <img src="/images/shop/subscription-bg.jpg" alt="" aria-hidden="true"/>
        <div class="lp-subscription-overlay"></div>
      </div>
      <div class="lp-container lp-subscription-inner">
        <div class="lp-subscription-card">
          <span class="lp-subscription-badge">人気 No.1</span>
          <h2>定期便のご案内</h2>
          <ul class="lp-subscription-list">
            <li>✓ 20個入りを2週間ごとにお届け</li>
            <li>✓ 2,780円（税込）／1回あたり</li>
            <li>✓ いつでも停止OK・縛りなし</li>
          </ul>
          <a href={LINE_URL} target="_blank" rel="noopener" class="lp-line-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.07 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            LINEで定期便を相談する
          </a>
        </div>
        <div class="lp-subscription-photo">
          <img src="/images/feature/feature-egg.jpg" alt="新鮮な卵" loading="lazy"/>
          <p>買い忘れの心配なし！<br/>いつも新鮮なたまごを<br/>お届けします。</p>
        </div>
      </div>
    </section>

    <!-- ⑦ お客様の声 -->
    <section id="reviews" class="lp-sec bg-white">
      <div class="lp-container">
        <h2 class="lp-sec-title">お客様の声</h2>
        <div class="lp-reviews-grid">
          {reviews.map(r => (
            <div class="lp-review-card">
              <div class="lp-review-photo">
                <img src="/images/shop/review-avatar.png" alt="" loading="lazy"/>
              </div>
              <div class="lp-review-body">
                <p class="lp-review-text">{r.text}</p>
                <p class="lp-review-name">{r.name}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="lp-review-dots">
          <span class="active"></span><span></span><span></span>
        </div>
      </div>
    </section>

    <!-- ⑧ FAQ -->
    <section id="faq" class="lp-sec lp-sec--cream">
      <div class="lp-container">
        <h2 class="lp-sec-title">よくあるご質問</h2>
        <div class="lp-faq-grid">
          {faqs.map(f => (
            <div class="lp-faq-item">
              <p class="lp-faq-q">
                <span>＋</span>{f.q}
              </p>
              <p class="lp-faq-a">{f.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑨ 最終CTA -->
    <section class="lp-final-cta">
      <div class="lp-container lp-final-inner">
        <div class="lp-final-text">
          <h2>まずはLINEで<br/>お気軽にご相談ください。</h2>
          <p>商品のこと、定期便のこと、<br/>どんなことでも大歓迎です。</p>
          <a href={LINE_URL} target="_blank" rel="noopener" class="lp-line-btn">
