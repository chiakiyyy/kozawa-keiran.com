---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LineButton from '../components/LineButton.astro';

const LINE_URL = 'https://line.me/ti/p/@215bpskd';
const SITE_URL = 'https://kozawa-keiran.com';
const OG_IMG   = `${SITE_URL}/images/shop/og-shop.jpg`;

const worries = [
  { img:'/images/shop/worries-icons.png', pos:'0%',    text:'子どもに安心できる\n食材を選びたい' },
  { img:'/images/shop/worries-icons.png', pos:'33.3%', text:'毎日の朝食を\nちゃんとしたい' },
  { img:'/images/shop/worries-icons.png', pos:'66.6%', text:'スーパーの卵との\n違いを知りたい' },
  { img:'/images/shop/worries-icons.png', pos:'100%',  text:'離乳食や幼児食に\n使う卵を選びたい' },
];

const points = [
  { num:'01', title:'富山の自然',        body:'澄んだ水と空気、豊かな自然環境に恵まれた富山で、健康な鶏を育てています。', img:'/images/shop/point1.jpg' },
  { num:'02', title:'平飼いで育った鶏',  body:'のびのびと平飼いで育つ環境だから、自然な形で健康な鶏に育ちます。',         img:'/images/feature/feature-chicken.jpg' },
  { num:'03', title:'健康的な餌',        body:'鶏の健康を第一に考えた餌を与え、安全第一に考えています。',                   img:'/images/shop/point3.jpg' },
  { num:'04', title:'チルド配送',        body:'採れたての鮮度をチルド（冷蔵）でそのままお届けしています。',                   img:'/images/shop/point4.jpg' },
  { num:'05', title:'生産者の顔が見える',body:'家族に食べさせたい卵を、責任をもってお届けしています。',                       img:'/images/shop/point5.jpg' },
];

const nutrients = [
  { icon:'💪', title:'良質なたんぱく質',       body:'体をつくる土台となるたんぱく質をバランスよく含んでいます。' },
  { icon:'🧠', title:'コリン・レシチン',        body:'卵黄に含まれるコリンやレシチンは、学習や記憶に関わる栄養素です。' },
  { icon:'🌱', title:'成長期の体づくりをサポート', body:'成長期の子どもに必要な栄養を、毎日の食事で手軽にとれます。' },
  { icon:'🍼', title:'離乳食・幼児食にも使いやすい', body:'やさしい味わいで、いろいろな料理に使いやすい食材です。' },
  { icon:'😋', title:'シンプルでもおいしい',    body:'素材が良いから、シンプルな料理でもおいしく食べられます。' },
  { icon:'✨', title:'食への興味・関心につながる', body:'おいしい体験が、子どもの食への興味や「食べる力」を育みます。' },
];

const products = [
  {
    id:'egg20', badge:null, highlight:false,
    img:'/images/shop/product1.jpg',
    name:'平飼い卵 20個',
    price:'2,980円（税込・送料込み）',
    lead:'まずはシンプルに、鮮度そのものの\nおいしさを確かめてください。',
    contents: null,
  },
  {
    id:'egg-soy', badge:null, highlight:false,
    img:'/images/shop/product2.jpg',
    name:'平飼い卵 20個\n＋卵かけご飯醤油',
    price:'3,500円（税込・送料込み）',
    lead:'卵かけご飯専用の醤油がついた、\n卵の美味しさが引き立つセットです。',
    contents: null,
  },
  {
    id:'morning', badge:'おすすめ', highlight:true,
    img:'/images/shop/product3.jpg',
    name:'富山の朝ごはんセット',
    price:'5,000円（税込・送料込み）',
    lead:'富山のおいしいものを詰め合わせた、特別な朝ごはん体験セットです。',
    contents: ['平飼い卵 20個（10個×2パック）','卵かけご飯醤油 1本（150ml）','富山県産米 富富富 2合（300g）','富山の味 お漬物・味噌汁の素（例）'],
  },
];

const reviews = [
  { name:'S.さん（富山市・30代・お子さま2人）', img:'/images/shop/review-avatar.png', text:'子どもが「この卵おいしい！」と言って食べてくれます。卵かけご飯が食卓の楽しみになりました！', stars:5 },
  { name:'K.さん（高岡市・40代・お子さま1人）', img:'/images/shop/review-avatar.png', text:'卵かけご飯が大好きになって、朝ごはんが楽しみになりました！黄身の濃さが全然違います。', stars:5 },
  { name:'M.さん（射水市・30代・お子さま1人）', img:'/images/shop/review-avatar.png', text:'離乳食にも安心して使えるので、本当に助かっています。生産者さんの顔が見えるのも安心。', stars:5 },
];

const faqs = [
  { q:'配送料について教えてください',           a:'商品価格に送料を含んでいます。別途送料はかかりません。' },
  { q:'お支払い方法はありますか？',             a:'クレジットカード（Square決済）をご利用いただけます。LINEでのお申し込み後にご案内します。' },
  { q:'定期便はいつでも停止できますか？',       a:'はい、いつでも停止・再開できます。縛りや解約手数料は一切ありません。' },
  { q:'卵は生で食べても大丈夫ですか？',         a:'新鮮な状態でお届けしていますが、適切な保管・加熱をお勧めします。' },
  { q:'卵が割れていた場合はどうすればいいですか？', a:'お届け時に割れがあった場合は、写真をLINEにお送りください。すぐに対応いたします。' },
  { q:'離乳食に使っても大丈夫ですか？',         a:'赤ちゃんの月齢や体調、アレルギーに配慮し、必要に応じて医師や専門家にご相談のうえご使用ください。' },
];

const jsonLd = {
  "@context":"https://schema.org","@type":"Product",
  "name":"小澤鶏卵場 富山の平飼い朝どれ卵",
  "description":"富山の自然で育った平飼い卵。子どもにも安心な朝食提案。チルド配送・生産者直送・定期便あり。",
  "brand":{"@type":"Brand","name":"小澤鶏卵場"},
  "offers":{"@type":"Offer","price":"2980","priceCurrency":"JPY","availability":"https://schema.org/InStock","url":`${SITE_URL}/shop/`}
};
---
<Layout
  title="子どもに食べさせたい卵があります｜富山の平飼い卵・小澤鶏卵場"
  description="富山の自然で育った平飼い卵を家族の朝ごはんに。チルド配送・生産者直送・定期便あり。30〜40代の子育て家族に選ばれる小澤鶏卵場の卵をLINEでご注文・ご相談ください。"
>
  <meta slot="head" property="og:title"       content="子どもに食べさせたい卵があります｜小澤鶏卵場"/>
  <meta slot="head" property="og:description" content="富山の平飼い・朝どれ卵。家族の朝ごはんに。チルド配送・縛りなし定期便。"/>
  <meta slot="head" property="og:image"       content={OG_IMG}/>
  <meta slot="head" property="og:url"         content={`${SITE_URL}/shop/`}/>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <Header/>
  <main class="font-['Zen_Kaku_Gothic_New',sans-serif] bg-[#FFFDF5]">

    <!-- ① HERO ──────────────────────────────────────── -->
    <section id="hero" class="relative bg-[#FFFDF5] overflow-hidden" style="margin-top:76px">
      <!-- 卵の丸装飾 -->
      <div class="pointer-events-none absolute left-[48%] top-8 w-20 h-20 rounded-full bg-[rgba(240,178,60,0.15)]"></div>

      <div class="mx-auto max-w-5xl px-8 py-14 sm:py-20 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <!-- 左：テキスト -->
        <div>
          <p class="text-sm text-[#BA7517] mb-3 font-semibold">富山の生産者から直送</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-[#2C2A24] leading-tight mb-5">
            子どもに<br/>食べさせたい<br/>卵があります。
          </h1>
          <p class="text-[#6B6860] text-sm leading-relaxed mb-7">
            富山の自然で育った平飼い卵を、<br/>家族の朝ごはんに。
          </p>
          <LineButton text="LINEで注文・相談する" size="lg"/>
        </div>
        <!-- 右：丸角写真 -->
        <div class="rounded-3xl overflow-hidden aspect-[4/3] shadow-lg">
          <img src="/images/shop/hero-family.jpg" alt="家族の朝ごはん" loading="eager" class="w-full h-full object-cover" style="object-position:30% center"/>
        </div>
      </div>
    </section>

    <!-- ② お悩み ───────────────────────────────────── -->
    <section id="worries" class="py-14 bg-[#FFFDF5]">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="text-center text-lg sm:text-xl font-bold text-[#2C2A24] mb-8">こんなお悩みありませんか？</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {worries.map(w => (
            <div class="flex flex-col items-center gap-3 rounded-2xl bg-white border border-[rgba(186,117,23,.15)] p-5 text-center shadow-sm">
              <div class="w-14 h-14 overflow-hidden flex-shrink-0">
                <img src={w.img} alt="" loading="lazy"
                  style={`width:400%;object-fit:cover;margin-left:-${w.pos};height:100%;`}
                  class="block"/>
              </div>
              <p class="text-xs text-[#5a4a2a] font-semibold leading-snug whitespace-pre-line">{w.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ③ 選ばれる理由 ───────────────────────────────── -->
    <section id="reasons" class="py-14 bg-[#FFFDF5]">
      <div class="mx-auto max-w-5xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-8 items-start">
          <!-- 左：見出し -->
          <div class="md:w-36 flex-shrink-0">
            <h2 class="text-lg font-bold text-[#2C2A24] leading-snug">
              小澤鶏卵場の卵が<br/>選ばれる理由
            </h2>
            <span class="block w-8 h-0.5 bg-[#F0B23C] mt-3"></span>
          </div>
          <!-- 右：5枚グリッド -->
          <div class="grid grid-cols-5 gap-3">
            {points.map(p => (
              <div>
                <div class="rounded-2xl overflow-hidden aspect-square bg-gradient-to-br from-[#FCE9B8] to-[#F0B23C] mb-2">
                  <img src={p.img} alt={p.title} loading="lazy" class="w-full h-full object-cover"
                    onerror="this.style.display='none'"/>
                </div>
                <p class="text-[#BA7517] font-['Manrope',sans-serif] font-bold text-xs mb-0.5">{p.num}</p>
                <p class="font-bold text-xs text-[#2C2A24] mb-1 leading-snug">{p.title}</p>
                <p class="text-[10px] text-[#6B6860] leading-relaxed">{p.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 健康メリット ──────────────────────────────── -->
    <section id="health" class="py-14 bg-white">
      <div class="mx-auto max-w-5xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-8 items-start">
          <!-- 左：見出し＋卵黄写真 -->
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-[#2C2A24] leading-snug mb-5">
              毎日の卵を、<br/>ちゃんと選ぶ理由。
            </h2>
            <div class="rounded-2xl overflow-hidden aspect-[16/9]">
              <img src="/images/shop/health-egg.jpg" alt="卵黄" loading="lazy" class="w-full h-full object-cover"/>
            </div>
          </div>
          <!-- 中：栄養リスト -->
          <div class="md:w-56">
            <ul class="space-y-3 mt-2">
              {nutrients.map(n => (
                <li class="flex items-start gap-2">
                  <span class="text-lg flex-shrink-0 leading-tight">{n.icon}</span>
                  <div>
                    <p class="text-xs font-bold text-[#2C2A24] leading-snug">{n.title}</p>
                    <p class="text-[11px] text-[#6B6860] leading-relaxed">{n.body}</p>
                  </div>
                </li>
              ))}
            </ul>
            <div class="mt-4 rounded-xl bg-[#FFF8EC] border border-[rgba(186,117,23,.2)] p-3 text-[10px] text-[#9B9994] leading-relaxed">
              ※アレルギーや月齢に配慮し、必要に応じて医師や専門家にご相談ください。
            </div>
          </div>
          <!-- 右：赤ちゃん写真 -->
          <div>
            <div class="rounded-2xl overflow-hidden aspect-[3/4] mt-2">
              <img src="/images/shop/health-baby.jpg" alt="離乳食にも安心な卵" loading="lazy" class="w-full h-full object-cover"/>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ 商品一覧 ─────────────────────────────────── -->
    <section id="products" class="py-14 bg-[#FFFDF5]">
      <div class="mx-auto max-w-5xl px-6">
        <div class="flex items-center justify-center gap-3 mb-10">
          <span class="text-lg opacity-40">🌿</span>
          <h2 class="text-xl sm:text-2xl font-bold text-[#2C2A24]">商品一覧</h2>
          <span class="text-lg opacity-40">🌿</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {products.map(p => (
            <div class:list={["relative rounded-3xl overflow-hidden bg-white shadow-sm flex flex-col", p.highlight ? "border-2 border-[#BA7517]" : "border border-[rgba(186,117,23,.15)]"]}>
              {p.badge && (
                <span class="absolute top-3 right-3 z-10 rounded-full bg-[#BA7517] px-3 py-1 text-xs font-bold text-white">{p.badge}</span>
              )}
              <div class="aspect-[4/3] bg-gradient-to-br from-[#FCE9B8] to-[#F0B23C] overflow-hidden">
                <img src={p.img} alt={p.name} loading="lazy" class="w-full h-full object-cover"
                  onerror="this.parentElement.style.cssText='display:flex;align-items:center;justify-content:center;font-size:3rem';this.style.display='none'"/>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <h3 class="font-bold text-[#2C2A24] text-base mb-1 whitespace-pre-line leading-snug">{p.name}</h3>
                <p class="text-[#BA7517] font-['Manrope',sans-serif] font-bold text-sm mb-2">{p.price}</p>
                <p class="text-xs text-[#6B6860] leading-relaxed mb-3 whitespace-pre-line flex-1">{p.lead}</p>
                {p.contents && (
                  <div class="mb-3 rounded-xl bg-[#FDF6E9] border border-[rgba(186,117,23,.2)] p-3">
                    <p class="text-xs font-bold text-[#BA7517] mb-1.5">セット内容</p>
                    <ul class="space-y-1">
                      {p.contents.map(c => <li class="text-xs text-[#6B6860]">＋ {c}</li>)}
                    </ul>
                    <p class="text-[10px] text-[#9B9994] mt-1.5">※セット内容は変更になる場合があります</p>
                  </div>
                )}
                <LineButton text="詳しく見る" size="sm"/>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑥ 定期便 ──────────────────────────────────── -->
    <section id="subscription" class="relative py-0 overflow-hidden">
      <!-- 背景画像 -->
      <div class="absolute inset-0">
        <img src="/images/shop/subscription-bg.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true"/>
        <div class="absolute inset-0 bg-white/70"></div>
      </div>
      <div class="relative mx-auto max-w-5xl px-6 py-16 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <!-- 左：白カード -->
        <div class="rounded-3xl bg-white shadow-lg p-8 border border-[rgba(186,117,23,.15)]">
          <span class="inline-block mb-3 rounded-full bg-[#BA7517] px-4 py-1 text-xs font-bold text-white">人気 No.1</span>
          <h2 class="text-xl font-bold text-[#2C2A24] mb-5">定期便のご案内</h2>
          <ul class="space-y-2.5 mb-6">
            {['20個入りを2週間ごとにお届け','2,780円（税込）／1回あたり','いつでも停止OK・縛りなし'].map(item => (
              <li class="flex items-center gap-2 text-sm text-[#2C2A24]">
                <span class="w-5 h-5 flex-shrink-0 rounded-full bg-[#06C755] text-white text-xs flex items-center justify-center font-bold">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <LineButton text="LINEで定期便を相談する" size="md" class="w-full justify-center"/>
        </div>
        <!-- 右：テキスト -->
        <div>
          <p class="text-base text-[#2C2A24] font-bold mb-2">買い忘れの心配なし！</p>
          <p class="text-sm text-[#6B6860] leading-relaxed">いつも新鮮なたまごをお届けします。</p>
        </div>
      </div>
    </section>

    <!-- ⑦ お客様の声 ───────────────────────────────── -->
    <section id="reviews" class="py-14 bg-[#FFFDF5]">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="text-center text-xl sm:text-2xl font-bold text-[#2C2A24] mb-10">お客様の声</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {reviews.map(r => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-[rgba(186,117,23,.1)]">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-[#F0B23C] flex-shrink-0">
                  <img src={r.img} alt="" loading="lazy" class="w-full h-full object-cover"/>
                </div>
                <span class="text-xs text-[#9B9994] leading-snug">{r.name}</span>
              </div>
              <p class="text-sm text-[#6B6860] leading-loose mb-3">{r.text}</p>
              <div class="text-[#F0B23C] text-sm">{"★".repeat(r.stars)}</div>
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-2 mt-8">
          <span class="w-2.5 h-2.5 rounded-full bg-[#F0B23C]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[rgba(186,117,23,.3)]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[rgba(186,117,23,.3)]"></span>
        </div>
      </div>
    </section>

    <!-- ⑧ FAQ ──────────────────────────────────────── -->
    <section id="faq" class="py-14 bg-white">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="text-center text-xl sm:text-2xl font-bold text-[#2C2A24] mb-10">よくあるご質問</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {faqs.map(f => (
            <details class="group rounded-2xl border border-[rgba(186,117,23,.15)] bg-[#FFFDF5] overflow-hidden">
              <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer list-none">
                <span class="text-sm font-bold text-[#2C2A24] leading-snug">{f.q}</span>
                <span class="text-[#BA7517] font-bold text-lg flex-shrink-0 group-open:rotate-45 transition-transform">＋</span>
              </summary>
              <div class="px-5 pb-4 text-sm text-[#6B6860] leading-relaxed border-t border-[rgba(186,117,23,.1)] pt-3">
                {f.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑨ 最終CTA ─────────────────────────────────── -->
    <section id="cta" class="py-14 bg-[#FFF8EC]">
      <div class="mx-auto max-w-5xl px-6 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-[#2C2A24] leading-snug mb-3">
            まずはLINEで<br/>お気軽にご相談ください。
          </h2>
          <p class="text-sm text-[#6B6860] leading-relaxed mb-6">
            商品のこと、定期便のこと、<br/>どんなことでも大歓迎です。
          </p>
          <LineButton text="LINEで注文・相談する" size="lg"/>
          <p class="mt-3 text-xs text-[#9B9994]">無理な営業はいたしません</p>
        </div>
        <div class="rounded-3xl overflow-hidden aspect-[4/3]">
          <img src="/images/feature/feature-egg.jpg" alt="富山の卵" loading="lazy" class="w-full h-full object-cover"/>
        </div>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>
