---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LineButton from '../components/LineButton.astro';

const LINE_URL  = 'https://line.me/ti/p/@215bpskd';
const SITE_URL  = 'https://kozawa-keiran.com';
const OG_IMG    = `${SITE_URL}/images/shop/og-shop.jpg`;

const reasons = [
  { emoji: '🛒', title: '買い忘れがなくなる',        body: '「あ、卵が切れてた」という朝のプチストレスがゼロになります。' },
  { emoji: '🌅', title: 'いつも新鮮な卵が届く',      body: '朝どれ・生産者直送だから、届くたびに黄身がぷりっと立っています。' },
  { emoji: '⏱️', title: 'スーパーへ行く手間が減る', body: '重い卵を運ぶ必要なし。玄関で受け取るだけ。週1回の買い物が少し楽になります。' },
  { emoji: '👨‍👩‍👧', title: '家族が喜ぶ',               body: '黄身の濃さ、卵本来のコク。「この卵おいしい！」が聞けるようになります。' },
];

const commitments = [
  { emoji: '🐔', title: '平飼い飼育',    body: '広い鶏舎でのびのびと育てた鶏が産む卵。ストレスの少ない環境が、卵の質に直結します。', img: '/images/feature/feature-chicken.jpg' },
  { emoji: '🌄', title: '朝どれ卵',      body: '毎朝採卵したその日の卵をお届け。鮮度の高さが黄身の盛り上がりや味わいに現れます。', img: '/images/feature/feature-egg.jpg' },
  { emoji: '❄️', title: 'チルド配送',    body: '冷蔵温度を保ったまま全国配送。夏場でも品質を損なわず、安心してお届けします。', img: '/images/flow/flow-hero.jpg' },
  { emoji: '👤', title: '生産者の顔が見える', body: '富山・小澤鶏卵場から直送。LINEでいつでも生産者に直接質問できます。', img: '/images/about/about-hero.jpg' },
];

const reviews = [
  { name: 'M.K. さん（富山市・30代主婦）', text: '届いた卵で卵かけご飯にしたら、黄身が濃くてびっくり！子どもが「この卵おいしい！」と言ってくれて、それから定期便にしました。冷蔵庫に卵が切れなくなったのも地味に嬉しいです。', stars: 5 },
  { name: 'T.Y. さん（富山市・40代会社員）', text: 'スーパーで卵を買い忘れることが多かったので試してみました。朝どれなので黄身がしっかり立っていて新鮮さを実感。チルド配送なのも安心感があります。', stars: 5 },
  { name: 'A.N. さん（射水市・50代）', text: '生産者さんの顔が見えるのが一番の決め手でした。LINEで質問にも丁寧に答えていただけるので信頼感があります。これからもよろしくお願いします。', stars: 5 },
];

const faqs = [
  { q: '定期便はいつでも停止できますか？',   a: 'はい、いつでも停止・再開できます。縛りは一切ありません。LINEにてご連絡ください。' },
  { q: '配送日は選べますか？',               a: 'はい、ご希望の曜日・時間帯をLINEでお知らせください。できる限りご希望に合わせます。' },
  { q: '卵が割れていた場合は？',             a: 'お届け時に割れがあった場合は、写真をLINEにお送りください。すぐに対応いたします。' },
  { q: '支払い方法は？',                     a: 'クレジットカード（Square決済）をご利用いただけます。LINEでのお申し込み後にご案内します。' },
  { q: '対応エリアはどこですか？',           a: '全国へお届けできます。送料は商品価格に含まれています（送料込み価格）。' },
];

// 構造化データ (JSON-LD)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "小澤鶏卵場 平飼い朝どれ卵 定期便",
  "description": "富山の平飼い・朝どれ卵を2週間ごとにお届けする定期便。チルド配送・生産者直送・縛りなし。",
  "brand": { "@type": "Brand", "name": "小澤鶏卵場" },
  "offers": {
    "@type": "Offer",
    "price": "2780",
    "priceCurrency": "JPY",
    "availability": "https://schema.org/InStock",
    "url": `${SITE_URL}/shop/`
  }
};
---
<Layout
  title="富山の平飼い朝どれ卵 定期便｜小澤鶏卵場"
  description="富山・小澤鶏卵場から直送。平飼い・朝どれ・チルド配送の新鮮な卵を2週間ごとにお届けする定期便。2,780円（税込・送料込）。いつでも停止可能・縛りなし。LINEで簡単お申し込み。"
>
  <!-- OGP / Twitter Card -->
  <meta slot="head" property="og:title"       content="富山の平飼い朝どれ卵 定期便｜小澤鶏卵場"/>
  <meta slot="head" property="og:description" content="富山・小澤鶏卵場から直送。平飼い・朝どれ・チルド配送の卵定期便。2,780円（税込・送料込）。縛りなし。"/>
  <meta slot="head" property="og:image"       content={OG_IMG}/>
  <meta slot="head" property="og:url"         content={`${SITE_URL}/shop/`}/>
  <meta slot="head" property="og:type"        content="website"/>
  <meta slot="head" name="twitter:card"       content="summary_large_image"/>

  <!-- 構造化データ -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <Header/>
  <main>

    <!-- ①────────────────── HERO ────────────────── -->
    <section class="relative overflow-hidden bg-[#FFFDF7]" style="margin-top:76px">
      <!-- 背景装飾 -->
      <div class="pointer-events-none absolute inset-0"
        style="background:radial-gradient(ellipse at 75% 40%,rgba(240,178,60,.2) 0,transparent 55%),radial-gradient(circle at 8% 85%,rgba(186,117,23,.1) 0,transparent 45%)">
      </div>

      <div class="relative mx-auto max-w-5xl px-6 py-16 sm:py-24 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="inline-block mb-4 rounded-full bg-[rgba(186,117,23,0.12)] px-4 py-1.5 text-xs font-bold tracking-widest text-[#BA7517]">
            富山の生産者から直送
          </span>
          <h1 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-4xl sm:text-5xl font-bold text-[#2C2A24] leading-tight mb-4">
            朝の卵を<br/>切らさない<br/>暮らし。
          </h1>
          <p class="text-[#6B6860] text-base leading-relaxed mb-8">
            富山の平飼い朝どれ卵を<br/>定期便でお届けします。
          </p>
          <LineButton size="lg"/>
          <p class="mt-3 text-xs text-[#9B9994]">無理な営業はいたしません。まずはお気軽にどうぞ。</p>
        </div>
        <div class="rounded-3xl overflow-hidden aspect-[4/3] bg-gradient-to-br from-[#FCE9B8] to-[#F0B23C] flex items-center justify-center text-6xl">
          <img src="/images/shop/shop-hero.jpg" alt="富山の朝どれ卵" loading="eager" class="w-full h-full object-cover" onerror="this.style.display='none'"/>
          🥚
        </div>
      </div>
    </section>

    <!-- ②──────────────── ありがとう ──────────────── -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-3xl px-6">
        <div class="flex gap-5 rounded-2xl border-2 border-[rgba(186,117,23,0.2)] bg-[#FFFDF7] p-8">
          <span class="text-4xl flex-shrink-0">🥚</span>
          <div>
            <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-xl font-bold text-[#2C2A24] mb-4 leading-snug">
              ご購入ありがとうございます。<br/>
              まずは卵を楽しんでいただけましたか？
            </h2>
            <p class="text-sm text-[#6B6860] leading-relaxed mb-3">
              富山からお届けした卵は、いかがでしたでしょうか。卵かけご飯、ゆで卵、だし巻き卵…何にしても、素材の味がしっかり感じられましたか？
            </p>
            <p class="text-sm text-[#6B6860] leading-relaxed">
              「次もまた食べたい」と思っていただけたなら、ぜひ定期便をご検討ください。冷蔵庫に卵が切れることなく、いつも新鮮な卵が届く暮らしをご提案します。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ③──────────────── なぜ定期便か ──────────────── -->
    <section class="py-16 bg-[#F9F7F2]">
      <div class="mx-auto max-w-4xl px-6">
        <div class="text-center mb-12">
          <span class="block font-['Manrope',sans-serif] text-xs tracking-[.22em] text-[#BA7517] mb-2">WHY SUBSCRIPTION</span>
          <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-2xl sm:text-3xl font-bold text-[#2C2A24]">定期便にすると、こんなに楽に</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {reasons.map(r => (
            <div class="bg-white rounded-2xl p-6 border border-[rgba(186,117,23,0.1)] shadow-sm">
              <span class="text-3xl block mb-3">{r.emoji}</span>
              <h3 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-base font-bold text-[#2C2A24] mb-2">{r.title}</h3>
              <p class="text-sm text-[#6B6860] leading-relaxed">{r.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ④──────────────── こだわり ──────────────── -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-6">
        <div class="text-center mb-12">
          <span class="block font-['Manrope',sans-serif] text-xs tracking-[.22em] text-[#BA7517] mb-2">OUR EGG</span>
          <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-2xl sm:text-3xl font-bold text-[#2C2A24]">小澤鶏卵場のこだわり</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {commitments.map(c => (
            <div class="rounded-2xl overflow-hidden border border-[rgba(186,117,23,0.12)] bg-[#FFFDF7] shadow-sm">
              <div class="aspect-[16/7] bg-gradient-to-br from-[#FCE9B8] to-[#F0B23C] flex items-center justify-center text-5xl overflow-hidden">
                <img src={c.img} alt={c.title} loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none'"/>
                {c.emoji}
              </div>
              <div class="p-5">
                <h3 class="font-['Zen_Kaku_Gothic_New',sans-serif] font-bold text-[#2C2A24] mb-2">{c.title}</h3>
                <p class="text-sm text-[#6B6860] leading-relaxed">{c.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤──────────────── お客様の声 ──────────────── -->
    <section class="py-16 bg-[#F9F7F2]">
      <div class="mx-auto max-w-4xl px-6">
        <div class="text-center mb-12">
          <span class="block font-['Manrope',sans-serif] text-xs tracking-[.22em] text-[#BA7517] mb-2">REVIEWS</span>
          <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-2xl sm:text-3xl font-bold text-[#2C2A24]">お客様の声</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {reviews.map(r => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-[rgba(186,117,23,0.1)]">
              <div class="text-[#F0B23C] text-lg mb-3">{"★".repeat(r.stars)}</div>
              <p class="text-sm text-[#6B6860] leading-loose mb-4 italic">「{r.text}」</p>
              <span class="text-xs text-[#9B9994]">{r.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑥──────────────── 定期便プラン ──────────────── -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-3xl px-6">
        <div class="text-center mb-12">
          <span class="block font-['Manrope',sans-serif] text-xs tracking-[.22em] text-[#BA7517] mb-2">PLAN</span>
          <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-2xl sm:text-3xl font-bold text-[#2C2A24]">定期便プラン</h2>
        </div>

        <!-- おすすめ定期便カード -->
        <div class="relative rounded-3xl border-2 border-[#06C755] bg-[#F0FFF4] p-8 shadow-[0_8px_32px_rgba(6,199,85,0.12)]">
          <span class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-[#06C755] px-5 py-1.5 text-xs font-bold text-white tracking-wide">おすすめ</span>

          <div class="text-center mb-6">
            <span class="block font-['Manrope',sans-serif] text-xs tracking-widest text-[#06C755] mb-1">おすすめ定期便</span>
            <h3 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-xl font-bold text-[#2C2A24] mb-4">平飼い卵 20個入り<br/>2週間ごとお届け</h3>
            <div class="flex items-end justify-center gap-1 mb-1">
              <span class="font-['Manrope',sans-serif] text-5xl font-bold text-[#2C2A24]">2,780</span>
              <span class="text-base text-[#6B6860] mb-2">円（税込）</span>
            </div>
            <p class="text-xs text-[#9B9994]">送料込み</p>
          </div>

          <ul class="mb-8 space-y-3 max-w-xs mx-auto">
            {[
              '2週間ごとに自動でお届け',
              'いつでも停止・再開OK',
              '縛りなし・解約手数料なし',
              'LINEで配送日の相談ができる',
              '朝どれ・チルド配送・生産者直送',
            ].map(item => (
              <li class="flex items-center gap-2 text-sm text-[#2C2A24]">
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-[#06C755] text-white text-xs flex items-center justify-center font-bold">✓</span>
                {item}
              </li>
            ))}
          </ul>

          <div class="flex justify-center">
            <LineButton text="LINEで申し込む" size="lg"/>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑦──────────────── FAQ ──────────────── -->
    <section class="py-16 bg-[#F9F7F2]">
      <div class="mx-auto max-w-2xl px-6">
        <div class="text-center mb-12">
          <span class="block font-['Manrope',sans-serif] text-xs tracking-[.22em] text-[#BA7517] mb-2">FAQ</span>
          <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-2xl sm:text-3xl font-bold text-[#2C2A24]">よくあるご質問</h2>
        </div>
        <div class="space-y-4">
          {faqs.map(f => (
            <div class="bg-white rounded-2xl p-6 border border-[rgba(186,117,23,0.1)] shadow-sm">
              <div class="flex gap-3 mb-3">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#F0B23C] text-white text-xs font-bold flex items-center justify-center">Q</span>
                <p class="font-bold text-[#2C2A24] text-sm leading-relaxed pt-1">{f.q}</p>
              </div>
              <div class="flex gap-3">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-[rgba(186,117,23,0.12)] text-[#BA7517] text-xs font-bold flex items-center justify-center">A</span>
                <p class="text-sm text-[#6B6860] leading-relaxed pt-1">{f.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑧──────────────── 最終CTA ──────────────── -->
    <section class="py-20" style="background:linear-gradient(135deg,#F0B23C,#BA7517)">
      <div class="mx-auto max-w-xl px-6 text-center">
        <span class="text-4xl block mb-6">🥚</span>
        <h2 class="font-['Zen_Kaku_Gothic_New',sans-serif] text-2xl sm:text-3xl font-bold text-white mb-4">
          まずはお気軽にご相談ください。
        </h2>
        <p class="text-white/90 text-base leading-relaxed mb-8">
          無理な営業はいたしません。<br/>
          「興味はあるけど…」くらいのお気持ちで大丈夫です。
        </p>
        <LineButton text="LINEで相談する（無料）" size="lg" variant="white"/>
        <p class="mt-4 text-xs text-white/75">友だち追加後、トーク画面からご相談ください</p>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>
