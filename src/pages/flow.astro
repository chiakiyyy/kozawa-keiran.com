---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';

const steps = [
  {
    num: '01',
    title: '採卵',
    body: '毎朝、鶏舎で産みたてのたまごを丁寧に集めます。鶏の健康状態を確認しながら、一個一個を大切に扱います。',
    img: '/images/flow/flow1.jpg',
    icon: `<svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="15" cy="17" rx="8" ry="10"/><path d="M15 6V3"/></svg>`,
  },
  {
    num: '02',
    title: '洗浄・殺菌',
    body: '採卵後すぐに専用ラインで洗浄。衛生管理を徹底し、食中毒リスクを排除します。',
    img: '/images/flow/flow2.jpg',
    icon: `<svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 23c0-6 3-13 8-13s8 7 8 13"/><path d="M11 15c0-3 1.5-6 3-6"/><path d="M6 26h18"/></svg>`,
  },
  {
    num: '03',
    title: '検卵・選別',
    body: '光を透過させる検卵で内部の品質を確認。ひび・異常卵を取り除き、サイズ（S〜LL）・種別ごとに自動選別します。',
    img: '/images/flow/flow3.jpg',
    icon: `<svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="15" cy="15" r="10.5"/><path d="M10.5 15l3 3 6-6"/></svg>`,
  },
  {
    num: '04',
    title: '包装・刻印',
    body: '賞味期限・農場名・産地をパック・ケースに刻印。トレーサビリティを確保します。',
    img: '/images/flow/flow4.jpg',
    icon: `<svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="7.5" width="18" height="15" rx="2.2"/><path d="M6 12.5h18M11 7.5v5M19 7.5v5"/></svg>`,
  },
  {
    num: '05',
    title: '温度管理・保管',
    body: '包装後は適切な温度帯で保管。コールドチェーンを維持し、品質劣化を防ぎます。',
    img: '/images/flow/flow5.jpg',
    icon: `<svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="7.5" y="4.5" width="15" height="21" rx="2.2"/><path d="M15 9v7.5l3.7 2.3"/><path d="M7.5 13.5h3M19.5 13.5h3"/></svg>`,
  },
  {
    num: '06',
    title: '配送・納品',
    body: '富山市内を中心に自社配送。月・水・金の注文は当日夕方にお届けします。大量注文・定期納品・催事対応も承ります。',
    img: '/images/business_hero.png',
    icon: `<svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="10.5" width="16.5" height="10.5" rx="1.5"/><path d="M19.5 13.5h4.5l3 3.75v3h-7.5v-6.75z"/><circle cx="8.3" cy="22.5" r="2.25"/><circle cx="23.3" cy="22.5" r="2.25"/></svg>`,
  },
];

const points = [
  { title:'採卵から最短当日配達', body:'月・水・金の午前9:30までのご注文で、当日夕方にお届けします。' },
  { title:'自社配送で品質を守る', body:'外部委託せず自社スタッフが責任を持って配送。温度管理を維持したままお届けします。' },
  { title:'100年以上の品質管理', body:'大正時代の創業から積み重ねた品質基準。長年のノウハウが一個一個に詰まっています。' },
  { title:'トレーサビリティの確保', body:'賞味期限・農場名・産地を全ての商品に表示。安心・安全を数字で証明します。' },
];
---
<Layout
  title="出荷までの流れ｜小澤鶏卵｜富山の鶏卵専門店"
  description="小澤鶏卵の採卵から配送までの品質管理フローをご紹介。採卵→洗浄殺菌→検卵選別→包装→温度管理→富山市内当日配送まで徹底した衛生・品質管理を行っています。"
>
  <Header/>
  <main>
    <!-- パンくず -->
    <div class="breadcrumb">
      <div class="container"><a href="/">TOP</a> <span>&gt;</span> <span>FLOW</span></div>
    </div>

    <!-- ヒーロー -->
    <section class="fl-hero">
      <div class="container fl-hero-in">
        <div class="fl-hero-text">
          <span class="fl-en">QUALITY &amp; FLOW</span>
          <h1>採卵から食卓へ。<br/>品質を守る出荷の流れ</h1>
          <p>小澤鶏卵では、採卵から富山市内への配送まで<br/>一貫した品質管理体制でたまごをお届けしています。</p>
        </div>
        <div class:list={["fl-hero-img", { "img-fallback": true }]}>
          <img src="/images/flow/flow-hero.jpg" alt="新鮮なたまご" loading="eager" onerror="this.closest('.fl-hero-img').classList.add('img-fallback')"/>
        </div>
      </div>
    </section>

    <!-- フロー -->
    <section class="fl-steps-sec">
      <div class="container">
        <div class="fl-steps">
          <span class="fl-steps-line"></span>
          {steps.map((s) => (
            <div class="fl-step">
              <span class="fl-step-num">{s.num}</span>
              <div class="fl-step-card">
                <div class="fl-step-icon" set:html={s.icon}></div>
                <div class="fl-step-body">
                  <h3>{s.title}</h3>
                  <p>{s.body}</p>
                </div>
                <div class:list={["fl-step-img", { "img-fallback": s.img !== '/images/business_hero.png' }]}>
                  <img src={s.img} alt={s.title} loading="lazy" onerror="this.closest('.fl-step-img').classList.add('img-fallback')"/>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 品質へのこだわり -->
    <section class="fl-promise">
      <div class="container">
        <div class="fl-head">
          <h2>品質へのこだわり</h2>
          <span class="fl-head-line"></span>
        </div>
        <div class="points-grid">
          {points.map(p => (
            <div class="point-card">
              <div class="point-check">✓</div>
              <div>
                <h3 class="point-title">{p.title}</h3>
                <p class="point-body">{p.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <ContactSection
      title="業務用たまごのご相談はお気軽に"
      lead="富山市内への当日配達・定期納品・催事対応など、まずはお電話・LINE・フォームのいずれかでご連絡ください"
    />
  </main>
  <Footer/>
</Layout>

<style>
.container { max-width: 1000px; margin: 0 auto; padding: 0 2rem; }

/* パンくず */
.breadcrumb { margin-top:76px; padding:.9rem 0; background:#FAFAF7; border-bottom:1px solid rgba(186,117,23,.08); }
.breadcrumb .container { font-size:.78rem; color:#9B9994; }
.breadcrumb a { color:#9B9994; text-decoration:none; }
.breadcrumb a:hover { color:#BA7517; }
.breadcrumb span { margin:0 .4rem; }

/* ヒーロー */
.fl-hero { padding:4.5rem 0 3.5rem; background:#fff; }
.fl-hero-in { display:grid; grid-template-columns:1fr 1.1fr; gap:3rem; align-items:center; }
.fl-en { font-family:Manrope,sans-serif; font-size:.7rem; letter-spacing:.25em; color:#BA7517; text-transform:uppercase; display:block; margin-bottom:.6rem; }
.fl-hero-text h1 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:clamp(1.6rem,3.6vw,2.3rem); font-weight:700; color:#2C2A24; line-height:1.5; margin-bottom:1rem; }
.fl-hero-text p { font-size:.85rem; color:#6B6860; line-height:1.9; }
.fl-hero-img { border-radius:20px; overflow:hidden; aspect-ratio:16/9; }
.fl-hero-img img { width:100%; height:100%; object-fit:cover; display:block; }
.fl-hero-img.img-fallback { background:linear-gradient(135deg,#FCE9B8,#F0B23C); display:flex; align-items:center; justify-content:center; }
.fl-hero-img.img-fallback img { display:none; }
.fl-hero-img.img-fallback::after { content:'🥚'; font-size:4rem; }

/* 見出し共通 */
.fl-head { text-align:center; margin-bottom:3rem; }
.fl-head h2 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:clamp(1.3rem,2.6vw,1.7rem); font-weight:700; color:#2C2A24; }
.fl-head-line { display:block; width:2.5rem; height:2px; background:#BA7517; margin:1.1rem auto 0; }

/* フローステップ：縦タイムライン */
.fl-steps-sec { padding:0 0 5rem; background:#fff; }
.fl-steps { position:relative; display:flex; flex-direction:column; gap:1.5rem; padding-left:64px; }
.fl-steps-line { position:absolute; left:24px; top:24px; bottom:24px; width:2px; background:repeating-linear-gradient(to bottom,#F0B23C 0,#F0B23C 6px,transparent 6px,transparent 12px); }
.fl-step { position:relative; }
.fl-step-num {
  position:absolute; left:-64px; top:0; width:48px; height:48px; border-radius:50%;
  background:#F0B23C; color:white; font-family:Manrope,sans-serif; font-weight:700; font-size:1rem;
  display:flex; align-items:center; justify-content:center; z-index:2;
}
.fl-step-card {
  display:grid; grid-template-columns:auto 1fr 180px; gap:1.5rem; align-items:center;
  background:white; border:1px solid rgba(186,117,23,.14); border-radius:14px;
  padding:1.5rem 1.75rem; box-shadow:0 2px 14px rgba(44,44,42,.05);
}
.fl-step-icon { width:52px; height:52px; border-radius:50%; background:#FDF1DC; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.fl-step-body h3 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:1.05rem; font-weight:700; color:#2C2A24; margin-bottom:.5rem; }
.fl-step-body p { font-size:.8rem; color:#6B6860; line-height:1.8; margin:0; }
.fl-step-img { width:180px; height:110px; border-radius:10px; overflow:hidden; flex-shrink:0; }
.fl-step-img img { width:100%; height:100%; object-fit:cover; display:block; }
.fl-step-img.img-fallback { background:linear-gradient(135deg,#FCE9B8,#F0B23C); display:flex; align-items:center; justify-content:center; }
.fl-step-img.img-fallback img { display:none; }
.fl-step-img.img-fallback::after { content:'🥚'; font-size:2rem; opacity:.85; }

/* 品質へのこだわり */
.fl-promise { padding:5rem 0; background:#FDF6E9; }
.points-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.point-card {
  display: flex; gap: 1rem; align-items: flex-start;
  background: white; border-radius: 12px; padding: 1.5rem;
  border: 0.5px solid rgba(186,117,23,0.12);
  box-shadow: 0 2px 12px rgba(44,44,42,0.04);
}
.point-check {
  width: 28px; height: 28px; border-radius: 50%;
  background: #BA7517; color: white;
  font-size: .8rem; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.point-title { font-size: .95rem; font-weight: 700; color: #2C2A24; margin-bottom: .35rem; }
.point-body { font-size: .82rem; color: #6B6860; line-height: 1.8; margin: 0; }

@media (max-width:900px) {
  .fl-step-card { grid-template-columns:auto 1fr; }
  .fl-step-img { display:none; }
}
@media (max-width: 780px) {
  .fl-hero-in { grid-template-columns:1fr; }
  .fl-hero-img { order:-1; }
}
@media (max-width: 640px) {
  .fl-steps { padding-left:54px; }
  .fl-step-num { left:-54px; width:40px; height:40px; font-size:.85rem; }
  .fl-steps-line { left:20px; }
  .fl-step-card { grid-template-columns:1fr; text-align:left; padding:1.25rem; }
  .points-grid { grid-template-columns: 1fr; }
}
</style>
