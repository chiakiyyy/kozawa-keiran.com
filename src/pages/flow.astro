---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const steps = [
  {
    num: '01',
    title: '採卵',
    body: '毎朝、鶏舎で産みたてのたまごを丁寧に集めます。鶏の健康状態を確認しながら、一個一個を大切に扱います。',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#BA7517" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="20" cy="22" rx="11" ry="13"/><path d="M20 9V5M14 11l-3-3M26 11l3-3"/></svg>`,
  },
  {
    num: '02',
    title: '洗浄・殺菌',
    body: '採卵後すぐに専用ラインで洗浄。衛生管理を徹底し、食中毒リスクを排除します。',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#BA7517" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M10 30c0-8 4-18 10-18s10 10 10 18"/><path d="M16 20c0-4 2-8 4-8"/><path d="M8 34h24"/></svg>`,
  },
  {
    num: '03',
    title: '検卵・選別',
    body: '光を透過させる検卵で内部の品質を確認。ひび・異常卵を取り除き、サイズ（S〜LL）・種別ごとに自動選別します。',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#BA7517" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><circle cx="20" cy="20" r="14"/><path d="M14 20l4 4 8-8"/></svg>`,
  },
  {
    num: '04',
    title: '包装・刻印',
    body: '賞味期限・農場名・産地をパック・ケースに刻印。トレーサビリティを確保します。',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#BA7517" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="10" width="24" height="20" rx="3"/><path d="M8 17h24M15 10v7M25 10v7"/></svg>`,
  },
  {
    num: '05',
    title: '温度管理・保管',
    body: '包装後は適切な温度帯で保管。コールドチェーンを維持し、品質劣化を防ぎます。',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#BA7517" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="10" y="6" width="20" height="28" rx="3"/><path d="M20 12v10l5 3"/><path d="M10 18h4M26 18h4"/></svg>`,
  },
  {
    num: '06',
    title: '配送・納品',
    body: '富山市内を中心に自社配送。月・水・金の注文は当日夕方にお届けします。大量注文・定期納品・催事対応も承ります。',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#BA7517" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="14" width="22" height="14" rx="2"/><path d="M26 18h6l4 6v4h-10V18z"/><circle cx="11" cy="30" r="3"/><circle cx="31" cy="30" r="3"/></svg>`,
  },
];

const points = [
  { title:'採卵から最短当日配達', body:'月・水・金の午前9:30までのご注文で、当日夕方にお届けします。' },
  { title:'自社配送で品質を守る', body:'外部委託せず自社スタッフが責任を持って配送。温度管理を維持したままお届けします。' },
  { title:'100年以上の品質管理', body:'大正時代の創業から積み重ねた品質基準。長年のノウハウが一個一個に詰まっています。' },
  { title:'トレーサビリティの確保', body:'賞味期限・農場名・産地を全ての商品に表示。安心・安全を数字で証明します。' },
];
---
<Layout
  title="出荷までの流れ｜小澤鶏卵｜富山の鶏卵専門店"
  description="小澤鶏卵の採卵から配送までの品質管理フローをご紹介。採卵→洗浄殺菌→検卵選別→包装→温度管理→富山市内当日配送まで徹底した衛生・品質管理を行っています。"
>
  <Header/>
  <main>
    <div class="page-hero">
      <div class="container">
        <span class="page-hero-en">QUALITY &amp; FLOW</span>
        <h1 class="page-hero-title">採卵から食卓へ。<br/>品質を守る出荷の流れ</h1>
        <p class="page-hero-sub">小澤鶏卵では、採卵から富山市内への配送まで<br/>一貫した品質管理体制でたまごをお届けしています。</p>
      </div>
    </div>

    <!-- フロー -->
    <section class="sec">
      <div class="container">
        <div class="center-head">
          <span class="sec-label" style="display:flex;justify-content:center">PROCESS</span>
          <h2 class="sec-title" style="text-align:center;margin-top:.5rem">出荷までの6ステップ</h2>
          <span class="sec-deco sec-deco--center"></span>
        </div>

        <div class="flow-steps">
          {steps.map((s, i) => (
            <div class="flow-step-row">
              <div class="flow-num-col">
                <div class="flow-num">{s.num}</div>
                {i < steps.length - 1 && <div class="flow-line"></div>}
              </div>
              <div class="flow-card">
                <div class="flow-icon" set:html={s.icon}></div>
                <div class="flow-body">
                  <h3 class="flow-title">{s.title}</h3>
                  <p class="flow-desc">{s.body}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 品質へのこだわり -->
    <section class="sec sec-amber">
      <div class="container">
        <div class="center-head">
          <span class="sec-label" style="display:flex;justify-content:center">OUR PROMISE</span>
          <h2 class="sec-title" style="text-align:center;margin-top:.5rem">品質へのこだわり</h2>
          <span class="sec-deco sec-deco--center"></span>
        </div>
        <div class="points-grid">
          {points.map(p => (
            <div class="point-card">
              <div class="point-check">✓</div>
              <div>
                <h3 class="point-title">{p.title}</h3>
                <p class="point-body">{p.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="sec sec-cta">
      <div class="container" style="text-align:center">
        <span class="sec-label" style="display:flex;justify-content:center">CONTACT</span>
        <h2 class="sec-title" style="margin:.5rem 0 1rem">業務用たまごのご相談はお気軽に</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:2rem">富山市内への当日配達・定期納品・催事対応など、まずはお電話かフォームにてご連絡ください。</p>
        <div style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap">
          <a href="/contact" class="btn btn-primary">お問い合わせフォーム →</a>
          <a href="tel:076-466-3815" class="btn btn-outline">📞 076-466-3815</a>
        </div>
      </div>
    </section>
  </main>
  <Footer/>
</Layout>

<style>
.container { max-width: 860px; margin: 0 auto; padding: 0 2rem; }
.sec { padding: 5rem 0; }
.sec-amber { background: #FDF6E9; }
.sec-cta { background: #FDF6E9; border-top: 1px solid rgba(186,117,23,0.1); }

/* Hero */
.page-hero {
  background: var(--bg2,#F9F7F2); padding: 7rem 0 4rem; margin-top: 72px;
  border-bottom: 1px solid rgba(245,184,46,.2);
}
.page-hero-en {
  font-family: Manrope, sans-serif; font-size: .7rem; letter-spacing: .25em;
  color: #BA7517; text-transform: uppercase; display: block; margin-bottom: .6rem;
}
.page-hero-title {
  font-family: 'Zen Kaku Gothic New', sans-serif; font-size: clamp(1.6rem,4vw,2.6rem);
  font-weight: 700; color: #2C2A24; line-height: 1.5; margin-bottom: .75rem;
}
.page-hero-sub { font-size: .9rem; color: #6B6860; line-height: 1.9; }

/* center-head */
.center-head { text-align: center; margin-bottom: 3.5rem; }

/* フローステップ */
.flow-steps { display: flex; flex-direction: column; gap: 0; }
.flow-step-row { display: flex; align-items: flex-start; gap: 1.5rem; }
.flow-num-col { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 56px; }
.flow-num {
  width: 56px; height: 56px; border-radius: 50%;
  background: #BA7517; color: white;
  font-family: Manrope, sans-serif; font-size: 1.1rem; font-weight: 700; letter-spacing: .04em;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.flow-line { width: 1.5px; flex: 1; min-height: 2rem; background: rgba(186,117,23,0.25); margin: .35rem 0; }
.flow-card {
  display: flex; align-items: flex-start; gap: 1.25rem;
  background: white; border-radius: 12px;
  border: 0.5px solid rgba(186,117,23,0.12);
  padding: 1.5rem 1.75rem; margin-bottom: 1rem; flex: 1;
  box-shadow: 0 2px 16px rgba(44,44,42,0.05);
}
.flow-icon { flex-shrink: 0; margin-top: .25rem; }
.flow-title {
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-size: 1rem; font-weight: 700; color: #2C2A24; margin-bottom: .4rem;
}
.flow-desc { font-size: .875rem; color: #6B6860; line-height: 1.8; margin: 0; }

/* こだわりポイント */
.points-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.point-card {
  display: flex; gap: 1rem; align-items: flex-start;
  background: white; border-radius: 12px; padding: 1.5rem;
  border: 0.5px solid rgba(186,117,23,0.12);
  box-shadow: 0 2px 12px rgba(44,44,42,0.04);
}
.point-check {
  width: 28px; height: 28px; border-radius: 50%;
  background: #BA7517; color: white;
  font-size: .8rem; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.point-title { font-size: .95rem; font-weight: 700; color: #2C2A24; margin-bottom: .35rem; }
.point-body { font-size: .82rem; color: #6B6860; line-height: 1.8; margin: 0; }

@media (max-width: 640px) {
  .flow-card { flex-direction: column; gap: .75rem; }
  .points-grid { grid-template-columns: 1fr; }
}
</style>
