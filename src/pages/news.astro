---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';

const cats = ['すべて','お知らせ','メディア掲載','イベント','その他'];
const articles = [
  { date:'2025.04.01', cat:'お知らせ',  title:'ホームページをリニューアルしました', excerpt:'いつも小澤鶏卵をご愛顧いただき、誠にありがとうございます。このたび、ホームページをリニューアルいたしました。', img:'/images/news/news1.jpg', href:'/news/detail' },
  { date:'2025.03.10', cat:'お知らせ',  title:'ゴールデンウィーク期間の配送について', excerpt:'ゴールデンウィーク期間（4/27〜5/6）の配送スケジュールについて、ご案内いたします。', img:'/images/news/news2.jpg', href:'/news/detail' },
  { date:'2025.02.14', cat:'メディア掲載', title:'富山新聞に掲載されました', excerpt:'2025年2月付の富山新聞に、当社の取り組みが掲載されました。', img:'/images/news/news3.jpg', href:'/news/detail' },
  { date:'2025.01.20', cat:'お知らせ',  title:'鶏舎の衛生管理強化について', excerpt:'お客様により安心・安全な卵をお届けするため、鶏舎の衛生管理をさらに強化いたしました。', img:'/images/news/news4.jpg', href:'/news/detail' },
  { date:'2024.12.01', cat:'その他', title:'新年のご挨拶', excerpt:'新年あけましておめでとうございます。本年も変わらぬご愛顧のほど、よろしくお願い申し上げます。', img:'/images/news/news5.jpg', href:'/news/detail' },
];
---
<Layout title="お知らせ｜小澤鶏卵" description="小澤鶏卵からのお知らせや最新情報をお届けします。">
  <Header/>
  <main>
    <!-- パンくず -->
    <div class="breadcrumb">
      <div class="container"><a href="/">TOP</a> <span>&gt;</span> <span>NEWS</span></div>
    </div>

    <!-- ヒーロー -->
    <section class="nw-hero">
      <div class="container nw-hero-in">
        <div class="nw-hero-text">
          <span class="nw-en">NEWS</span>
          <h1>お知らせ</h1>
          <p>小澤鶏卵からのお知らせや最新情報をお届けします。</p>
        </div>
        <div class:list={["nw-hero-img", { "img-fallback": true }]}>
          <img src="/images/news/news-hero.jpg" alt="新鮮なたまご" loading="eager" onerror="this.closest('.nw-hero-img').classList.add('img-fallback')"/>
        </div>
      </div>
    </section>

    <section class="news-sec">
      <div class="container">
        <!-- カテゴリフィルター -->
        <div class="cat-tabs">
          {cats.map((c, i) => (
            <button class={`cat-btn ${i === 0 ? 'active' : ''}`}>{c}</button>
          ))}
        </div>

        <!-- 記事一覧 -->
        <div class="article-list">
          {articles.map(a => (
            <a href={a.href} class="article-card">
              <div class:list={["art-thumb", { "img-fallback": true }]}>
                <img src={a.img} alt="" loading="lazy" onerror="this.closest('.art-thumb').classList.add('img-fallback')"/>
              </div>
              <div class="art-body">
                <div class="art-meta">
                  <span class="art-date">{a.date}</span>
                  <span class={`art-cat art-cat--${a.cat === 'メディア掲載' ? 'media' : a.cat === 'イベント' ? 'ev' : a.cat === 'その他' ? 'other' : 'default'}`}>{a.cat}</span>
                </div>
                <h2 class="art-title">{a.title}</h2>
                <p class="art-excerpt">{a.excerpt}</p>
              </div>
              <span class="art-arrow">›</span>
            </a>
          ))}
        </div>

        <!-- ページネーション -->
        <div class="pagination">
          <a href="#" class="page-nav">‹</a>
          <span class="page-num active">1</span>
          <a href="#" class="page-num">2</a>
          <a href="#" class="page-num">3</a>
          <span class="page-ellipsis">…</span>
          <a href="#" class="page-num">8</a>
          <a href="#" class="page-nav">›</a>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <ContactSection title="業務用たまごのご相談・お見積りはお気軽にお問い合わせください" lead=""/>
  </main>
  <Footer/>
</Layout>
<style>
.container { max-width:1000px; margin:0 auto; padding:0 2rem; }

/* パンくず */
.breadcrumb { margin-top:76px; padding:.9rem 0; background:#FAFAF7; border-bottom:1px solid rgba(186,117,23,.08); }
.breadcrumb .container { font-size:.78rem; color:#9B9994; }
.breadcrumb a { color:#9B9994; text-decoration:none; }
.breadcrumb a:hover { color:#BA7517; }
.breadcrumb span { margin:0 .4rem; }

/* ヒーロー */
.nw-hero { padding:4.5rem 0 3.5rem; background:#fff; }
.nw-hero-in { display:grid; grid-template-columns:1fr 1.1fr; gap:3rem; align-items:center; }
.nw-en { font-family:Manrope,sans-serif; font-size:.7rem; letter-spacing:.25em; color:#BA7517; text-transform:uppercase; display:block; margin-bottom:.6rem; }
.nw-hero-text h1 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:clamp(1.9rem,4vw,2.7rem); font-weight:700; color:#2C2A24; margin-bottom:1rem; }
.nw-hero-text p { font-size:.88rem; color:#6B6860; line-height:1.9; }
.nw-hero-img { border-radius:20px; overflow:hidden; aspect-ratio:16/9; }
.nw-hero-img img { width:100%; height:100%; object-fit:cover; display:block; }
.nw-hero-img.img-fallback { background:linear-gradient(135deg,#FCE9B8,#F0B23C); display:flex; align-items:center; justify-content:center; }
.nw-hero-img.img-fallback img { display:none; }
.nw-hero-img.img-fallback::after { content:'🥚'; font-size:4rem; }

.news-sec { padding:4rem 0 6rem; background:#fff; }

/* カテゴリタブ */
.cat-tabs { display:flex; gap:.6rem; flex-wrap:wrap; margin-bottom:2.5rem; justify-content:center; }
.cat-btn { padding:.5rem 1.3rem; border-radius:999px; border:1.5px solid rgba(186,117,23,.35); background:white; color:#6B6860; font-size:.8rem; font-weight:700; cursor:pointer; transition:all .2s; }
.cat-btn:hover { background:rgba(186,117,23,.08); }
.cat-btn.active { background:#F0B23C; border-color:#F0B23C; color:white; }

/* 記事カード */
.article-list { display:flex; flex-direction:column; gap:1.1rem; }
.article-card {
  display:flex; gap:1.5rem; align-items:center;
  padding:1.1rem 1.5rem 1.1rem 1.1rem; background:white; border-radius:14px;
  border:1px solid rgba(186,117,23,.12); text-decoration:none; color:inherit;
  box-shadow:0 2px 14px rgba(44,44,42,.04);
  transition:box-shadow .2s, transform .2s;
}
.article-card:hover { box-shadow:0 10px 26px rgba(44,44,42,.09); transform:translateY(-2px); }
.art-thumb { flex-shrink:0; width:140px; height:100px; border-radius:10px; overflow:hidden; background:#FDF6E9; }
.art-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
.art-thumb.img-fallback { background:linear-gradient(135deg,#FCE9B8,#F0B23C); display:flex; align-items:center; justify-content:center; }
.art-thumb.img-fallback img { display:none; }
.art-thumb.img-fallback::after { content:'🥚'; font-size:1.75rem; opacity:.85; }
.art-body { flex:1; min-width:0; }
.art-meta { display:flex; align-items:center; gap:.65rem; margin-bottom:.5rem; }
.art-date { font-family:Manrope,sans-serif; font-size:.78rem; color:#9B9994; letter-spacing:.03em; }
.art-cat { font-size:.66rem; font-weight:700; padding:.2rem .65rem; border-radius:999px; white-space:nowrap; }
.art-cat--default { background:rgba(186,117,23,.12); color:#BA7517; }
.art-cat--media { background:rgba(80,150,80,.12); color:#3F7D3F; }
.art-cat--ev { background:rgba(60,100,200,.1); color:#3060C0; }
.art-cat--other { background:rgba(150,150,150,.12); color:#777; }
.art-title { font-family:'Zen Kaku Gothic New',sans-serif; font-size:1rem; font-weight:700; color:#2C2A24; margin:0 0 .5rem; line-height:1.5; }
.art-excerpt {
  font-size:.8rem; color:#9B9994; line-height:1.75; margin:0;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}
.art-arrow { flex-shrink:0; font-size:1.5rem; color:#F0B23C; font-weight:300; }

/* ページネーション */
.pagination { display:flex; justify-content:center; align-items:center; gap:.5rem; margin-top:3rem; }
.page-num,.page-nav { width:36px; height:36px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:.85rem; font-weight:700; text-decoration:none; color:#2C2A24; background:white; border:1px solid rgba(186,117,23,.25); transition:all .2s; }
.page-num.active { background:#F0B23C; border-color:#F0B23C; color:white; }
.page-num:hover:not(.active),.page-nav:hover { background:rgba(186,117,23,.08); }
.page-ellipsis { display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; color:#9B9994; }

@media (max-width:780px) {
  .nw-hero-in { grid-template-columns:1fr; }
  .nw-hero-img { order:-1; }
}
@media (max-width:640px) {
  .article-card { flex-wrap:wrap; }
  .art-thumb { width:100%; height:160px; }
  .art-arrow { display:none; }
}
</style>
