---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { products } from '../data/products';
---
<Layout title="商品紹介｜小澤鶏卵" description="小澤鶏卵の商品紹介。こだわりのたまご・ピンクたまご・アローカナのたまご・ギフトセットなど幅広いラインナップ。">
  <Header/>
  <main>
    <div class="page-hero">
      <div class="container">
        <span class="page-hero-en">LINE UP</span>
        <h1 class="page-hero-title">商品紹介</h1>
        <p class="page-hero-sub">用途に合わせた多彩なたまごをご用意しています</p>
      </div>
    </div>

    <!-- 商品一覧 -->
    <section class="products-sec">
      <div class="container">
        {products.map((p, i) => (
          <article class={`product-row ${i % 2 === 1 ? 'product-row--rev' : ''}`} id={p.id}>
            <div class="pr-img">
              <img src={p.img} alt={p.name} loading="lazy"/>
              <span class="pr-badge">{p.badge}</span>
            </div>
            <div class="pr-text">
              <h2 class="pr-name">{p.name}</h2>
              <div class="pr-divider"></div>
              <p class="pr-desc">{p.desc}</p>
              <dl class="pr-specs">
                <dt>サイズ</dt><dd>{p.sizes}</dd>
                <dt>パック</dt><dd>{p.pack}</dd>
                <dt>価格</dt><dd>{p.price}</dd>
              </dl>
              <div class="pr-tags">
                {p.business && <span class="pr-tag pr-tag--biz">業務用対応</span>}
                {p.gift && <span class="pr-tag pr-tag--gift">ギフト対応</span>}
              </div>
              <div class="pr-actions">
                <a href="/contact" class="btn btn-primary">ご注文・お問い合わせ</a>
                {p.business && <a href="/business" class="btn btn-outline">法人向け詳細</a>}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ギフト対応 -->
    <section class="gift-sec">
      <div class="container gift-inner">
        <div class="gift-text">
          <span class="sec-en">Gift</span>
          <h2 class="sec-title mt">ギフト対応しています</h2>
          <p>大切な方への贈り物に、小澤鶏卵のたまごはいかがでしょうか。化粧箱入りのギフトセットをご用意しています。内祝い・お中元・お歳暮・父の日・母の日などさまざまなシーンに対応します。</p>
          <a href="/contact" class="btn btn-green">ギフトについて問い合わせる</a>
        </div>
        <div class="gift-img">
          <img src="/images/product_gift.svg" alt="ギフトセット" loading="lazy"/>
        </div>
      </div>
    </section>

    <!-- 業務用CTA -->
    <section class="biz-cta">
      <div class="container biz-cta-inner">
        <div>
          <h2>業務用のご注文はこちら</h2>
          <p>飲食店・給食・製菓など大口のご注文はお任せください。定期納品にも対応しています。</p>
        </div>
        <a href="/business" class="btn btn-outline-yellow">法人向けページを見る →</a>
      </div>
    </section>
  </main>
  <Footer/>
</Layout>
<style>
.container { max-width:1100px; margin:0 auto; padding:0 2rem; }
.page-hero { background:var(--bg2); padding:7rem 0 4rem; margin-top:76px; border-bottom:1px solid rgba(245,184,46,.2); }
.page-hero-en { font-family:'Lato',sans-serif; font-size:.7rem; letter-spacing:.25em; color:var(--green); text-transform:uppercase; display:block; margin-bottom:.4rem; }
.page-hero-title { font-family:'Noto Serif JP',serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; color:var(--brown); }
.page-hero-sub { font-size:.9rem; color:var(--muted); margin-top:.5rem; }
.products-sec { padding:5rem 0; background:var(--bg); }
.product-row { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; padding:4rem 0; border-bottom:1px solid rgba(245,184,46,.15); }
.product-row:first-child { padding-top:0; }
.product-row--rev .pr-img { order:2; }
.product-row--rev .pr-text { order:1; }
.pr-img { position:relative; border-radius:16px; overflow:hidden; }
.pr-img img { width:100%; height:360px; object-fit:cover; display:block; }
.pr-badge { position:absolute; top:14px; left:14px; background:var(--yellow); color:var(--brown); font-size:.7rem; font-weight:700; padding:.3rem .75rem; border-radius:999px; }
.pr-name { font-family:'Noto Serif JP',serif; font-size:clamp(1.4rem,2.5vw,2rem); font-weight:700; color:var(--brown); margin-bottom:0; }
.pr-divider { width:2.5rem; height:2px; background:var(--yellow); margin:1rem 0; }
.pr-desc { font-size:.9rem; color:var(--muted); line-height:1.9; margin-bottom:1.25rem; }
.pr-specs { display:grid; grid-template-columns:5rem 1fr; gap:.4rem .75rem; margin-bottom:1.25rem; }
.pr-specs dt { font-size:.8rem; font-weight:700; color:var(--brown); }
.pr-specs dd { font-size:.8rem; color:var(--muted); margin:0; }
.pr-tags { display:flex; gap:.5rem; margin-bottom:1.5rem; flex-wrap:wrap; }
.pr-tag { font-size:.7rem; font-weight:700; padding:.25rem .7rem; border-radius:999px; }
.pr-tag--biz { background:rgba(111,143,58,.12); color:var(--green); border:1px solid rgba(111,143,58,.3); }
.pr-tag--gift { background:rgba(245,184,46,.15); color:#8B6010; border:1px solid rgba(245,184,46,.4); }
.pr-actions { display:flex; gap:.875rem; flex-wrap:wrap; }
.gift-sec { background:var(--bg2); padding:5rem 0; }
.gift-inner { display:grid; grid-template-columns:1.1fr 1fr; gap:5rem; align-items:center; }
.gift-text .sec-title { margin-top:.6rem; }
.gift-text p { font-size:.9rem; color:var(--muted); line-height:1.9; margin:1rem 0 1.75rem; }
.gift-img { border-radius:16px; overflow:hidden; }
.gift-img img { width:100%; height:320px; object-fit:cover; display:block; }
.mt { margin-top:.6rem; }
.biz-cta { background:#2A4A20; padding:3.5rem 0; }
.biz-cta-inner { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
.biz-cta h2 { font-family:'Noto Serif JP',serif; font-size:1.3rem; font-weight:700; color:white; margin-bottom:.4rem; }
.biz-cta p { font-size:.875rem; color:rgba(255,255,255,.7); margin:0; }
@media (max-width:900px) {
  .product-row,.product-row--rev,.gift-inner { grid-template-columns:1fr; gap:2rem; }
  .product-row--rev .pr-img,.product-row--rev .pr-text { order:unset; }
  .pr-img img { height:280px; }
  .biz-cta-inner { flex-direction:column; text-align:center; }
}
</style>
