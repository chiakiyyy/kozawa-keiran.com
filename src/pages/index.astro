---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { products } from '../data/products';
---
<Layout title="小澤鶏卵｜富山の業務用たまご・鶏卵専門店｜当日配達対応" description="富山県の鶏卵専門店・小澤鶏卵。大正時代創業100年以上。富山市を中心に飲食店・ホテル・給食施設・スーパーへ業務用たまごを当日配達。月・水・金9:30までのご注文で当日夕方お届け。定期納品・催事対応も承ります。">
  <Header/>
  <main>

    <!-- HERO -->
    <section class="hero">
      <img class="hero-bg-img" src="/images/hero_main.png" alt="小澤鶏卵のたまご" loading="eager"/>
      <div class="hero-inner">
        <div class="hero-text">
          <span class="hero-label">TOYAMA · EST. 1920s · EGG SUPPLIER</span>
          <h1 class="sr-only">小澤鶏卵 - 富山の業務用たまご・鶏卵専門店。当日配達対応。</h1>
          <p class="hero-title" aria-hidden="true">幸せは、<br/><em>たまご</em>のある<br/>食卓にある。</p>
          <p class="hero-sub">おひさまを浴びる幸せ。新鮮なものを食べる幸せ。<br/>安心できるものを選べる幸せ。</p>
          <div class="hero-btns">
            <a href="/business" class="btn btn-primary">法人取引のご相談</a>
            <a href="/products" class="btn btn-outline">商品を見る</a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <span>SCROLL</span>
        <div class="hero-scroll-line"></div>
      </div>
    </section>

    <!-- STATS -->
    <div class="stats-wrap">
      <div class="stat-egg">
        <div class="stat-egg-inner">
          <div class="stat-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="#BA7517" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="14" width="28" height="18" rx="3"/>
              <path d="M12 14V10a6 6 0 0112 0v4"/>
              <circle cx="18" cy="23" r="2.5"/>
            </svg>
          </div>
          <div class="stat-deco"></div>
          <div class="stat-num">100<span class="stat-unit">年+</span></div>
          <div class="stat-label">創業からの歴史</div>
          <div class="stat-desc">大正時代から続く鶏卵一筋の歩み。<br/>これからも信頼を積み重ねて<br/>まいります。</div>
        </div>
      </div>
      <div class="stat-egg">
        <div class="stat-egg-inner">
          <div class="stat-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="#BA7517" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="6" width="28" height="24" rx="3"/>
              <path d="M4 13h28M12 4v4M24 4v4"/>
              <rect x="10" y="18" width="4" height="4" rx="1"/>
              <rect x="16" y="18" width="4" height="4" rx="1"/>
              <rect x="22" y="18" width="4" height="4" rx="1"/>
            </svg>
          </div>
          <div class="stat-deco"></div>
          <div class="stat-num">月水金</div>
          <div class="stat-label">注文受付日</div>
          <div class="stat-desc">毎週 月・水・金は<br/>ご注文を受け付けています。<br/>計画的にお届けします。</div>
        </div>
      </div>
      <div class="stat-egg">
        <div class="stat-egg-inner">
          <div class="stat-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="#BA7517" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="14" width="22" height="12" rx="2"/>
              <path d="M24 18h4l4 4H24v-4z"/>
              <circle cx="9" cy="28" r="3"/>
              <circle cx="27" cy="28" r="3"/>
              <path d="M6 14V10h12v4"/>
            </svg>
          </div>
          <div class="stat-deco"></div>
          <div class="stat-num">当日</div>
          <div class="stat-label">夕方お届け対応</div>
          <div class="stat-desc">ご注文は当日夕方にお届け。<br/>新鮮な卵をできるだけ<br/>早くお届けします。</div>
        </div>
      </div>
    </div>
    <p class="stats-note">※お届けエリアや時間帯は地域によって異なります。詳しくはお問い合わせください。</p>

    <!-- FOR BUSINESS -->
    <section class="sec">
      <div class="container">
        <div class="two-col">
          <div class="two-col-img">
            <img src="/images/business_hero.png" alt="業務用たまご" loading="lazy"/>
          </div>
          <div class="two-col-body">
            <span class="sec-label">FOR BUSINESS</span>
            <h2 class="sec-title">富山の飲食店・施設へ<br/>業務用たまごを安定配達</h2>
            <span class="sec-deco"></span>
            <p class="sec-lead">富山市を中心に、飲食店・ホテル・給食施設・スーパーなど業務用たまごの安定供給はお任せください。<br/>大量注文・定期納品・催事対応など柔軟に対応します。</p>
            <div class="biz-tags">
              {['ラーメン店','洋菓子店','ホテル','スーパー','給食施設','催事・イベント'].map(t => <span class="biz-tag">{t}</span>)}
            </div>
            <a href="/business" class="btn btn-primary" style="margin-top:2.5rem">法人取引のご相談はこちら →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="sec">
      <div class="container">
        <div class="center-head fade-up" style="margin-bottom:3.5rem">
          <span class="sec-label" style="justify-content:center;display:flex">LINE UP</span>
          <h2 class="sec-title" style="text-align:center">商品紹介</h2>
          <span class="sec-deco sec-deco--center"></span>
        </div>
        <div class="prod-grid">
          {products.filter(p => p.id !== 'business').map((p, i) => (
            <a href={`/products#${p.id}`} class={`prod-card card fade-up fade-up-d${i + 1}`}>
              <div class="prod-img"><img src={p.img} alt={p.name} loading="lazy"/></div>
              <div class="prod-body">
                <h3>{p.name}</h3>
                <p>{p.note}</p>
                <span class="link-arrow">詳しく見る →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- NEWS -->
    <!-- ABOUT -->
    <section class="sec">
      <div class="container">
        <div class="two-col">
          <div class="fade-up">
            <span class="sec-label">ABOUT</span>
            <h2 class="sec-title">私たちについて</h2>
            <span class="sec-deco"></span>
            <p class="sec-lead">小澤鶏卵は、自然豊かな環境の中で、鶏の健康を第一に考え、こだわりの飼料ときれいな水で鶏を育てています。創業100年以上、富山の食卓を支えてきました。</p>
            <a href="/about" class="link-arrow" style="margin-top:1.75rem;display:inline-flex">詳しく見る →</a>
          </div>
          <div class="two-col-img fade-up fade-up-d2">
            <img src="/images/about_chickens.svg" alt="小澤鶏卵について" loading="lazy"/>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURE -->
    <section class="sec sec--pale">
      <div class="container">
        <div class="center-head fade-up" style="margin-bottom:3.5rem">
          <span class="sec-label" style="justify-content:center;display:flex">FEATURE</span>
          <h2 class="sec-title" style="text-align:center">こだわり</h2>
          <span class="sec-deco sec-deco--center"></span>
        </div>
        <div class="feat-grid">
          {[
            { img:'/images/feature_feed.svg',   title:'こだわりの飼料',       body:'鶏の健康を考え、厳選した原料を使用した自家配合飼料を与えています。', d:'fade-up-d1' },
            { img:'/images/feature_env.svg',    title:'快適な飼育環境',       body:'清潔で風通しの良い鶏舎で、のびのびと育った鶏から産まれています。', d:'fade-up-d2' },
            { img:'/images/feature_water.svg',  title:'おいしい水',           body:'地下から汲み上げたきれいな水をたっぷり与えています。', d:'fade-up-d3' },
            { img:'/images/feature_safety.svg', title:'安心・安全への取り組み', body:'徹底した衛生管理のもと、安心・安全なたまごをお届けします。', d:'fade-up-d4' },
          ].map(f => (
            <div class={`feat-card card fade-up ${f.d}`}>
              <div class="feat-img"><img src={f.img} alt={f.title} loading="lazy"/></div>
              <div class="feat-body">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- NEWS -->
    <section class="sec sec--pale">
      <div class="container">
        <div class="news-head fade-up">
          <div>
            <span class="sec-label">NEWS</span>
            <h2 class="sec-title">お知らせ</h2>
          </div>
          <a href="/news" class="link-arrow">すべて見る →</a>
        </div>
        <ul class="news-list">
          {[
            { date:'2024.05.01', tag:'お知らせ', title:'ゴールデンウィーク期間の営業について' },
            { date:'2024.04.10', tag:'重要',     title:'「こだわりのたまご」価格改定のお知らせ' },
            { date:'2024.03.15', tag:'お知らせ', title:'ホームページをリニューアルしました' },
          ].map(n => (
            <li class="news-item fade-up">
              <a href="/news">
                <span class="news-date">{n.date}</span>
                <span class={`news-tag ${n.tag === '重要' ? 'news-tag--imp' : ''}`}>{n.tag}</span>
                <span class="news-title">{n.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-sec">
      <div class="container" style="text-align:center">
        <span class="sec-label" style="justify-content:center;display:flex;">CONTACT</span>
        <h2 class="sec-title" style="margin:.5rem 0 1rem">ご注文・ご相談はお気軽に</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:3rem">まずはお電話・LINE・フォームのいずれかでお気軽にご連絡ください</p>
        <div class="contact-methods">
          <div class="method-card">
            <div class="method-icon">
              <svg width="26" height="26" viewBox="0 0 20 20" fill="none" stroke="#BA7517" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3.5C3 3.5 4.5 2 6 2c.5 0 1 .3 1.3.8l1.4 2.4c.3.5.2 1.1-.2 1.5L7.2 8c.8 1.5 2 2.8 3.5 3.6l1.3-1.3c.4-.4 1-.5 1.5-.2l2.4 1.4c.5.3.8.8.8 1.3 0 1.5-1.5 3-1.5 3C6 18 2 10 3 3.5z"/>
              </svg>
            </div>
            <h3>お電話</h3>
            <a href="tel:076-466-3815" class="method-tel">076-466-3815</a>
            <p>月〜土 8:00〜17:00</p>
            <a href="tel:076-466-3815" class="method-btn">電話をかける</a>
          </div>
          <div class="method-card method-card--line">
            <div class="method-icon method-icon--line">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="white">
                <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.070 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
              </svg>
            </div>
            <h3>LINE</h3>
            <p class="method-line-id">@215bpskd</p>
            <p>お気軽にメッセージください</p>
            <a href="https://line.me/ti/p/@215bpskd" target="_blank" rel="noopener" class="method-btn method-btn--line">LINEで相談する</a>
          </div>
          <div class="method-card">
            <div class="method-icon">
              <svg width="26" height="26" viewBox="0 0 20 20" fill="none" stroke="#BA7517" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="16" height="12" rx="2"/>
                <path d="M2 7l8 5 8-5"/>
              </svg>
            </div>
            <h3>お問い合わせフォーム</h3>
            <p class="method-email">info@kozawa-keiran.com</p>
            <p>24時間受付・翌営業日返信</p>
            <a href="/contact" class="method-btn">フォームを開く</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>

<style>
/* HERO */
.hero {
  position: relative;
  min-height: 75svh;
  display: flex;
  align-items: center;
  padding-top: 76px;
  overflow: hidden;
  background: #F9F7F2;
}
.hero-bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center right;
  display: block;
}
.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, #F9F7F2 0%, #F9F7F2 28%, rgba(249,247,242,0.85) 48%, rgba(249,247,242,0.2) 65%, transparent 80%);
  pointer-events: none;
  z-index: 0;
}
.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 5rem;
  width: 100%;
  min-height: calc(75svh - 72px);
  display: flex;
  align-items: center;
}
.hero-text {
  width: 44%;
  padding: 4rem 0;
}
.hero-label {
  font-family: Manrope, sans-serif;
  font-size: .58rem;
  letter-spacing: .3em;
  color: #BA7517;
  display: block;
  margin-bottom: 2rem;
  opacity: .8;
}
.hero-title {
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-size: clamp(2rem, 4.2vw, 3.4rem);
  font-weight: 300;
  color: #2C2A24;
  line-height: 1.75;
  margin-bottom: 1.75rem;
  letter-spacing: .12em;
}
.hero-title em { font-style: normal; color: #BA7517; }
.hero-sub {
  font-size: .88rem;
  color: #5C5A54;
  line-height: 2.2;
  margin-bottom: 3rem;
  letter-spacing: .06em;
  font-weight: 300;
}
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

/* SCROLL インジケーター */
.hero-scroll { position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%); z-index:2; display:flex; flex-direction:column; align-items:center; gap:.6rem; }
.hero-scroll span { font-family:Manrope,sans-serif; font-size:.52rem; letter-spacing:.22em; color:rgba(186,117,23,.5); }
.hero-scroll-line { width:1px; height:48px; background:linear-gradient(to bottom,rgba(186,117,23,.4),transparent); animation:scrollLine 1.8s ease-in-out infinite; }
@keyframes scrollLine { 0%,100%{opacity:.3;transform:scaleY(.5);transform-origin:top} 50%{opacity:1;transform:scaleY(1)} }

/* STATS 卵型カード */
.stats-wrap {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 3.5rem;
  padding: 5rem 2rem;
  background: #F9F7F2;
  flex-wrap: nowrap;
}
.stat-egg {
  width: 220px;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: 220px;
}
.stat-egg-inner {
  background: white;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  width: 220px;
  height: 293px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2.5rem 1.5rem;
  text-align: center;
  box-shadow: 0 8px 40px rgba(44,44,42,0.07);
  border: 0.5px solid rgba(186,117,23,0.1);
  gap: 0;
  box-sizing: border-box;
}
.stat-icon {
  color: #BA7517;
  margin-bottom: .75rem;
}
.stat-deco {
  width: 24px;
  height: 1px;
  background: #BA7517;
  opacity: .4;
  margin: .5rem auto .85rem;
}
.stat-num {
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-size: 2.2rem;
  font-weight: 400;
  color: #BA7517;
  line-height: 1.1;
  letter-spacing: .04em;
  margin-bottom: .4rem;
}
.stat-unit {
  font-size: 1rem;
  font-weight: 400;
}
.stat-label {
  font-size: .78rem;
  font-weight: 500;
  color: #2C2A24;
  letter-spacing: .1em;
  margin-bottom: .85rem;
}
.stat-desc {
  font-size: .72rem;
  color: #9B9994;
  line-height: 1.9;
  letter-spacing: .04em;
}
.stats-note {
  text-align: center;
  font-size: .72rem;
  color: #9B9994;
  padding-bottom: 3rem;
  background: #F9F7F2;
  letter-spacing: .04em;
}

/* TWO COL */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:5.5rem; align-items:center; }
.two-col--rev { direction:rtl; }
.two-col--rev > * { direction:ltr; }
.two-col-img { border-radius:var(--radius-lg); overflow:hidden; aspect-ratio:4/3; background:var(--amber-bg); }
.two-col-img img { width:100%; height:100%; object-fit:cover; display:block; }

.biz-tags { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:1.75rem; }
.biz-tag { background:var(--gray-lt); color:var(--muted); font-size:.72rem; padding:.35rem .9rem; border-radius:999px; border:.5px solid var(--border); }

/* ORDER */
.order-methods { display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem; margin-bottom:2rem; }
.method-card { background:white; border-radius:var(--radius-md); border:.5px solid rgba(44,44,42,.08); padding:2.25rem 1.5rem; text-align:center; box-shadow:0 4px 24px rgba(44,44,42,.06); }
.method-icon { font-size:1.75rem; display:block; margin-bottom:.85rem; }
.method-card h3 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:.95rem; font-weight:700; color:var(--text); margin-bottom:.45rem; }
.method-detail { font-size:.85rem; color:var(--amber); font-weight:500; margin-bottom:.25rem; }
.method-sub { font-size:.72rem; color:var(--muted); }
.order-note { background:white; border-radius:var(--radius-sm); border:.5px solid rgba(186,117,23,.18); padding:1.5rem 2rem; font-size:.875rem; color:var(--muted); line-height:1.9; text-align:center; }
.order-note strong { color:var(--text); font-weight:700; }

/* FEAT */
.feat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; }
.feat-card { display:flex; flex-direction:column; }
.feat-img { aspect-ratio:1; background:var(--amber-bg); overflow:hidden; }
.feat-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s cubic-bezier(.25,.46,.45,.94); }
.feat-card:hover .feat-img img { transform:scale(1.06); }
.feat-body { padding:1.4rem; }
.feat-body h3 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:.9rem; font-weight:700; color:var(--text); margin-bottom:.45rem; }
.feat-body p { font-size:.78rem; color:var(--muted); line-height:1.8; margin:0; }

/* PRODUCTS */
.prod-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; }
.prod-card { text-decoration:none; color:inherit; display:flex; flex-direction:column; }
.prod-img { aspect-ratio:1; background:var(--amber-bg); overflow:hidden; }
.prod-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s cubic-bezier(.25,.46,.45,.94); }
.prod-card:hover .prod-img img { transform:scale(1.06); }
.prod-body { padding:1.4rem; }
.prod-body h3 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:.9rem; font-weight:700; color:var(--text); margin-bottom:.35rem; }
.prod-body p { font-size:.78rem; color:var(--muted); line-height:1.7; margin-bottom:.85rem; }

/* NEWS */
.news-head { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:2.5rem; }
