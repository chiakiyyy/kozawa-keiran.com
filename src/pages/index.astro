---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="小澤鶏卵｜新鮮で安心なたまごを地域へ"
  description="幸せは、たまごのある食卓にある。小澤鶏卵は地域の飲食店・施設・ご家庭へ、安全で高品質なたまごをお届けします。"
>
  <Header />
  <main>

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="hero">
      <div class="hero-left">
        <div class="hero-egg-deco" aria-hidden="true">
          <svg viewBox="0 0 70 88" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="35" cy="47" rx="30" ry="38" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1.5"/>
            <ellipse cx="35" cy="52" rx="15" ry="19" fill="#F5B82E" opacity="0.32"/>
          </svg>
        </div>

        <h1 class="hero-title">
          幸せは、<br/>
          <em class="hero-em">たまご</em>のある<br/>
          食卓にある。
        </h1>

        <p class="hero-catch">
          おひさまを浴びる幸せ。<br/>
          新鮮なものを食べる幸せ。<br/>
          安心できるものを選べる幸せ。
        </p>

        <p class="hero-body">
          小澤鶏卵は、地域の食卓に寄り添いながら、<br/>
          毎日新鮮で安心なたまごをお届けしています。
        </p>

        <div class="hero-ctas">
          <a href="/business" class="hero-btn-primary">法人取引のご相談</a>
          <a href="/products" class="hero-btn-ghost">商品を見る</a>
        </div>

        <!-- ドット装飾 -->
        <div class="hero-dots" aria-hidden="true">
          {Array.from({length:15}).map((_,i) => <span class="hdot" style={`--n:${i}`}></span>)}
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo">
          <img src="/images/hero_main.svg" alt="農場と新鮮なたまご" loading="eager"/>
        </div>
        <!-- 左側の有機白カーブ -->
        <svg class="hero-curve" viewBox="0 0 140 700" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" aria-hidden="true">
          <path d="M140,0 L0,0 L0,700 L140,700 Q20,560 50,350 Q80,140 140,0 Z" fill="#FFFAF0"/>
        </svg>
      </div>
    </section>


    <!-- ============================================================
         FOR BUSINESS（最重要 — HEROの直下）
    ============================================================ -->
    <section class="for-biz">
      <div class="for-biz-inner">
        <div class="for-biz-text">
          <span class="sec-badge sec-badge--dark">FOR BUSINESS</span>
          <h2 class="for-biz-title">
            毎日使うたまごを、<br/>
            安定してお届けします。
          </h2>
          <p class="for-biz-body">
            飲食店・ホテル・給食施設・スーパーなど、業務用たまごの安定供給はお任せください。
            大量注文・定期納品・サイズ規格指定など、柔軟に対応します。
          </p>

          <!-- 対応業種アイコン -->
          <div class="biz-targets">
            {[
              {icon:'🍜', label:'ラーメン店'},
              {icon:'🎂', label:'洋菓子店'},
              {icon:'🏨', label:'ホテル'},
              {icon:'🛒', label:'スーパー'},
              {icon:'🏫', label:'給食施設'},
              {icon:'🎪', label:'催事・イベント'},
            ].map(t => (
              <div class="biz-target">
                <span class="biz-target-icon">{t.icon}</span>
                <span class="biz-target-label">{t.label}</span>
              </div>
            ))}
          </div>

          <a href="/business" class="btn-biz">
            法人取引のご相談はこちら
            <svg width="16" height="12" viewBox="0 0 16 12" fill="none"><path d="M10 1l5 5-5 5M1 6h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </a>
        </div>

        <div class="for-biz-visual" aria-hidden="true">
          <img src="/images/business_hero.svg" alt=""/>
          <div class="for-biz-card">
            <div class="fbc-num">01</div>
            <p class="fbc-text">ご注文・<br/>ヒアリング</p>
            <div class="fbc-arrow">↓</div>
            <div class="fbc-num">02</div>
            <p class="fbc-text">ご提案・<br/>お見積り</p>
            <div class="fbc-arrow">↓</div>
            <div class="fbc-num">03</div>
            <p class="fbc-text">納品<br/>スタート</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================================
         FOR HOME
    ============================================================ -->
    <section class="for-home">
      <div class="for-home-inner">
        <div class="for-home-img">
          <img src="/images/hero_main.svg" alt="家庭用たまごイメージ" loading="lazy"/>
        </div>
        <div class="for-home-text">
          <span class="sec-badge">FOR HOME</span>
          <h2 class="for-home-title">
            毎日の食卓に、<br/>
            安心でおいしいたまごを。
          </h2>
          <p class="for-home-body">
            ご家庭用・ギフト・通販・定期購入など、個人のお客様にも幅広くご対応します。
            産地直送の新鮮なたまごを、毎日の食卓へお届けします。
          </p>
          <div class="for-home-links">
            <a href="/shop" class="btn-home-primary">個人のお客様はこちら →</a>
            <a href="/products" class="btn-home-ghost">商品ラインナップ →</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================================
         ABOUT
    ============================================================ -->
    <section class="about">
      <!-- 左: 丸い鶏写真 -->
      <div class="about-img-wrap">
        <div class="about-circle">
          <img src="/images/about_chickens.svg" alt="元気に育つ鶏たち" loading="lazy"/>
        </div>
        <div class="about-deco-g" aria-hidden="true">
          <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="40" cy="53" rx="34" ry="44" fill="#EAF0DA" stroke="#6F8F3A" stroke-width="1"/>
          </svg>
        </div>
        <div class="about-deco-y" aria-hidden="true">
          <svg viewBox="0 0 60 75" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="30" cy="40" rx="26" ry="32" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1"/>
          </svg>
        </div>
      </div>

      <!-- 右: テキスト -->
      <div class="about-text">
        <span class="about-en">ABOUT</span>
        <span class="about-ja">私たちについて</span>
        <p class="about-body">
          小澤鶏卵は、自然豊かな環境の中で、鶏の健康を第一に考え、こだわりの飼料ときれいな水で鶏を育てています。
          新鮮でおいしいたまごを、まごころ込めてお届けします。
        </p>
        <a href="/about" class="btn-green">詳しく見る　→</a>
      </div>
    </section>


    <!-- ============================================================
         FEATURE
    ============================================================ -->
    <section class="feature-sec">
      <div class="feature-sec-inner">
        <div class="feature-label">
          <span class="fl-en">FEATURE</span>
          <span class="fl-ja">こだわり</span>
        </div>
        <div class="feature-cards">
          {[
            {img:'/images/feature_feed.svg',   name:'こだわりの飼料',     desc:'鶏の健康を考え、厳選した原料を使用した自家配合飼料を与えています。'},
            {img:'/images/feature_env.svg',    name:'快適な飼育環境',     desc:'清潔で風通しの良い鶏舎で、のびのびと育った鶏から産まれています。'},
            {img:'/images/feature_water.svg',  name:'おいしい水',         desc:'地下から汲み上げたきれいな水をたっぷり与えています。'},
            {img:'/images/feature_safety.svg', name:'安心・安全への取り組み', desc:'徹底した衛生管理のもと、安心・安全なたまごをお届けします。'},
          ].map(f => (
            <article class="fcard">
              <div class="fcard-img">
                <img src={f.img} alt={f.name} loading="lazy"/>
              </div>
              <div class="fcard-body">
                <h3 class="fcard-name">{f.name}</h3>
                <p class="fcard-desc">{f.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>


    <!-- ============================================================
         LINE UP
    ============================================================ -->
    <section class="lineup-sec">
      <div class="lineup-deco-y" aria-hidden="true"></div>
      <div class="lineup-deco-g" aria-hidden="true"></div>
      <div class="lineup-sec-inner">
        <div class="lineup-label">
          <span class="ll-en">LINE UP</span>
          <span class="ll-ja">商品紹介</span>
        </div>
        <div class="lineup-cards">
          {[
            {img:'/images/product_kodawari.svg', name:'こだわりのたまご',   desc:'コクと甘みが特徴の、当社自慢のたまごです。',             href:'/products#kodawari'},
            {img:'/images/product_pink.svg',     name:'ピンクたまご',       desc:'やさしいピンク色の殻が特徴のたまごです。',               href:'/products#pink'},
            {img:'/images/product_araucana.svg', name:'アローカナのたまご', desc:'南米原産の鶏が産む、希少な青い殻のたまごです。',         href:'/products#araucana'},
            {img:'/images/product_gift.svg',     name:'ギフトセット',       desc:'大切な方への贈り物に。ギフトセットをご用意しています。', href:'/products#gift'},
          ].map(p => (
            <article class="lcard">
              <a href={p.href} class="lcard-link-wrap">
                <div class="lcard-img">
                  <img src={p.img} alt={p.name} loading="lazy"/>
                </div>
                <div class="lcard-body">
                  <h3 class="lcard-name">{p.name}</h3>
                  <p class="lcard-desc">{p.desc}</p>
                  <span class="lcard-more">詳しく見る　→</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>


    <!-- ============================================================
         NEWS
    ============================================================ -->
    <section class="news-sec">
      <div class="news-label">
        <span class="nl-en">NEWS</span>
        <span class="nl-ja">お知らせ</span>
      </div>

      <ul class="news-list">
        {[
          {date:'2024.05.01', title:'ゴールデンウィーク期間の営業について'},
          {date:'2024.04.10', title:'「こだわりのたまご」価格改定のお知らせ'},
          {date:'2024.03.15', title:'ホームページをリニューアルしました'},
        ].map(n => (
          <li>
            <a href="/news" class="nrow">
              <span class="ndate">{n.date}</span>
              <span class="ntitle">{n.title}</span>
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" class="narr">
                <path d="M9 1l4 4-4 4M1 5h12" stroke="#6F8F3A" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <div class="news-img">
        <div class="news-circle">
          <img src="/images/news_eggs.svg" alt="たまごイメージ" loading="lazy"/>
        </div>
      </div>
    </section>


    <!-- ============================================================
         CONTACT
    ============================================================ -->
    <section class="contact-sec">
      <div class="contact-text">
        <span class="ct-en">CONTACT</span>
        <span class="ct-ja">お問い合わせ</span>
        <p class="ct-body">
          ご注文やご質問など、<br/>
          お気軽にお問い合わせください。
        </p>
      </div>

      <div class="contact-center">
        <a href="/contact" class="contact-btn">
          <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
            <rect x="1" y="1" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M1 3l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          お問い合わせフォームへ　→
        </a>
      </div>

      <div class="contact-photo" aria-hidden="true">
        <img src="/images/contact_bg.svg" alt=""/>
        <div class="contact-photo-fade"></div>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>

<style>
/* ====================================================
   共通
==================================================== */
.btn-green {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .85rem 2rem; background: #6F8F3A; color: white;
  font-size: .875rem; font-weight: 700; border-radius: 999px;
  text-decoration: none; box-shadow: 0 4px 14px rgba(111,143,58,.3);
  transition: all .22s;
}
.btn-green:hover { background: #4A6A20; transform: translateY(-2px); }

/* ====================================================
   HERO
==================================================== */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100svh - 70px);
  margin-top: 70px;
  background: #FFFAF0;
  overflow: hidden;
}

.hero-left {
  padding: 5rem 3rem 4rem 5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.hero-egg-deco {
  position: absolute; top: 3rem; left: 3rem;
  width: 52px; opacity: .7;
}

.hero-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.9rem, 3.5vw, 3.1rem);
  font-weight: 700; color: #3B321F;
  line-height: 1.55; letter-spacing: .03em;
  margin-bottom: 1.4rem;
}
.hero-em { font-style: normal; color: #F5B82E; }

.hero-catch {
  font-size: .875rem; color: #7A6A4A;
  line-height: 2; margin-bottom: 1.1rem;
}

.hero-body {
  font-size: .875rem; color: #3B321F;
  line-height: 1.9; margin-bottom: 2rem;
}

.hero-ctas { display: flex; gap: .875rem; flex-wrap: wrap; }

.hero-btn-primary {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .9rem 1.75rem;
  background: #F5B82E; color: #3B321F;
  font-size: .875rem; font-weight: 700;
  border-radius: 999px; text-decoration: none;
  box-shadow: 0 4px 14px rgba(245,184,46,.4);
  transition: all .22s; white-space: nowrap;
}
.hero-btn-primary:hover { background: #E8A818; transform: translateY(-2px); }

.hero-btn-ghost {
  display: inline-flex; align-items: center;
  padding: .9rem 1.75rem;
  border: 2px solid #6F8F3A; color: #6F8F3A;
  font-size: .875rem; font-weight: 700;
  border-radius: 999px; text-decoration: none;
  background: white; transition: all .22s; white-space: nowrap;
}
.hero-btn-ghost:hover { background: #6F8F3A; color: white; }

.hero-dots {
  position: absolute; bottom: 2.5rem; right: 1.5rem;
  display: grid; grid-template-columns: repeat(5,1fr); gap: 6px;
  opacity: .5;
}
.hdot { width: 6px; height: 6px; border-radius: 50%; background: #F5B82E; }
.hdot:nth-child(3n) { background: #D4E4B0; }

.hero-right { position: relative; overflow: hidden; }
.hero-photo { position: absolute; inset: 0; }
.hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
.hero-curve {
  position: absolute; left: -1px; top: 0; bottom: 0;
  width: 130px; height: 100%; z-index: 1;
}


/* ====================================================
   FOR BUSINESS
==================================================== */
.for-biz {
  background: #2A4A20;
  padding: 6rem 0;
}
.for-biz-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 2rem;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 5rem; align-items: center;
}

.sec-badge {
  display: inline-block;
  font-family: 'Lato', sans-serif;
  font-size: .65rem; font-weight: 700;
  letter-spacing: .22em; text-transform: uppercase;
  padding: .3rem .9rem;
  border: 1px solid rgba(245,184,46,.5);
  color: rgba(245,184,46,.85);
  border-radius: 999px;
  margin-bottom: 1.25rem;
}
.sec-badge--dark { background: rgba(245,184,46,.1); }

.for-biz-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem, 2.8vw, 2.25rem);
  font-weight: 700; color: white;
  line-height: 1.55; margin-bottom: 1rem;
}

.for-biz-body {
  font-size: .9rem; color: rgba(255,255,255,.72);
  line-height: 1.9; margin-bottom: 2rem;
}

.biz-targets {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: .625rem; margin-bottom: 2rem;
}
.biz-target {
  display: flex; flex-direction: column; align-items: center;
  gap: .3rem; padding: .75rem .5rem;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 10px;
  transition: background .2s;
}
.biz-target:hover { background: rgba(255,255,255,.12); }
.biz-target-icon { font-size: 1.4rem; line-height: 1; }
.biz-target-label { font-size: .72rem; color: rgba(255,255,255,.75); font-weight: 500; text-align: center; }

.btn-biz {
  display: inline-flex; align-items: center; gap: .6rem;
  padding: 1rem 2.25rem;
  background: #F5B82E; color: #3B321F;
  font-size: .9rem; font-weight: 700;
  border-radius: 999px; text-decoration: none;
  box-shadow: 0 4px 18px rgba(245,184,46,.45);
  transition: all .22s;
}
.btn-biz:hover { background: #E8A818; transform: translateY(-2px); }

.for-biz-visual {
  position: relative; border-radius: 16px; overflow: hidden;
  min-height: 400px;
}
.for-biz-visual img {
  width: 100%; height: 100%; object-fit: cover;
  display: block; opacity: .5;
  position: absolute; inset: 0;
}
.for-biz-card {
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 130px;
  background: rgba(255,255,255,.96);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: .4rem; padding: 1.5rem 1rem;
}
.fbc-num {
  font-family: 'Lato', sans-serif;
  font-size: .65rem; font-weight: 700;
  letter-spacing: .15em; color: #F5B82E;
  width: 28px; height: 28px; border-radius: 50%;
  background: rgba(245,184,46,.12);
  display: flex; align-items: center; justify-content: center;
}
.fbc-text { font-size: .75rem; font-weight: 700; color: #3B321F; text-align: center; line-height: 1.5; }
.fbc-arrow { font-size: .8rem; color: #6F8F3A; opacity: .6; }


/* ====================================================
   FOR HOME
==================================================== */
.for-home {
  background: #F7F1DF;
  padding: 6rem 0;
}
.for-home-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 2rem;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 5rem; align-items: center;
}
.for-home-img {
  border-radius: 20px; overflow: hidden;
  box-shadow: 0 8px 32px rgba(59,50,31,.12);
}
.for-home-img img {
  width: 100%; height: 400px; object-fit: cover; display: block;
}
.sec-badge { /* for HOME variant */ }
.for-home-text .sec-badge {
  border-color: rgba(111,143,58,.4);
  color: #6F8F3A; background: rgba(111,143,58,.08);
}
.for-home-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem, 2.8vw, 2.25rem);
  font-weight: 700; color: #3B321F;
  line-height: 1.55; margin-bottom: 1rem;
}
.for-home-body {
  font-size: .9rem; color: #7A6A4A;
  line-height: 1.9; margin-bottom: 2rem;
}
.for-home-links { display: flex; flex-direction: column; gap: .875rem; width: fit-content; }
.btn-home-primary {
  display: inline-flex; align-items: center;
  padding: .9rem 2rem;
  background: #6F8F3A; color: white;
  font-size: .875rem; font-weight: 700;
  border-radius: 999px; text-decoration: none;
  box-shadow: 0 4px 14px rgba(111,143,58,.3);
  transition: all .22s;
}
.btn-home-primary:hover { background: #4A6A20; transform: translateY(-2px); }
.btn-home-ghost {
  display: inline-flex; align-items: center;
  padding: .9rem 2rem;
  border: 2px solid #6F8F3A; color: #6F8F3A;
  font-size: .875rem; font-weight: 700;
  border-radius: 999px; text-decoration: none;
  background: white; transition: all .22s;
}
.btn-home-ghost:hover { background: #6F8F3A; color: white; }


/* ====================================================
   ABOUT
==================================================== */
.about {
  display: grid; grid-template-columns: 1fr 1.15fr;
  gap: 5rem; align-items: center;
  max-width: 1100px; margin: 0 auto;
  padding: 6rem 2rem;
}
.about-img-wrap { position: relative; display: flex; justify-content: center; }
.about-circle {
  width: min(380px,100%); aspect-ratio: 1;
  border-radius: 50%; overflow: hidden;
  position: relative; z-index: 1;
  box-shadow: 0 8px 32px rgba(59,50,31,.1);
}
.about-circle img { width: 100%; height: 100%; object-fit: cover; }
.about-deco-g { position: absolute; bottom: -8px; right: 4px; width: 88px; opacity: .75; z-index: 0; }
.about-deco-y { position: absolute; top: 12px; right: -12px; width: 62px; opacity: .7; z-index: 0; }
.about-en {
  font-family: 'Lato', sans-serif; font-size: 1.1rem;
  font-weight: 700; letter-spacing: .2em; color: #6F8F3A; display: block;
}
.about-ja {
  font-size: .75rem; color: #7A6A4A; letter-spacing: .1em;
  display: block; margin-top: 3px; margin-bottom: 1.25rem;
}
.about-body {
  font-size: .9rem; color: #7A6A4A;
  line-height: 1.95; margin-bottom: 1.75rem;
}


/* ====================================================
   FEATURE
==================================================== */
.feature-sec { background: #F7F1DF; padding: 5.5rem 0; }
.feature-sec-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 2rem;
