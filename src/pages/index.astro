---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const heroSlides = [
  { src: '/images/hero1.svg', alt: '農場の風景' },
  { src: '/images/hero2.svg', alt: 'たまごのビジュアル' },
  { src: '/images/hero3.svg', alt: '朝の農場' },
  { src: '/images/hero4.svg', alt: '山と農場' },
];

const products = [
  { src: '/images/product1.svg', name: '新鮮たまご', badge: '人気 No.1', desc: '産地直送で毎朝入荷。ふっくらとした黄身と締まった白身が自慢の一品です。', href: '/products#fresh' },
  { src: '/images/product2.svg', name: '業務用たまご', badge: '安定供給！', desc: '飲食店・給食・製菓など大量のご要望に。定期納品サービスも充実しています。', href: '/products#business' },
  { src: '/images/product3.svg', name: '温泉卵・加工品', badge: 'とろ〜り食感', desc: 'こだわりの温度管理で仕上げた温泉卵。そのままお使いいただける便利な加工品。', href: '/products#processed' },
];

const features = [
  { src: '/images/feature1.svg', title: 'たまご物語', desc: '産地から食卓まで', href: '/quality#story' },
  { src: '/images/feature2.svg', title: '産地紹介', desc: '信頼できる農場から', href: '/quality#area' },
  { src: '/images/feature3.svg', title: '環境への取り組み', desc: '自然と共に歩む', href: '/quality#env' },
];

const news = [
  { date: '2025.04.01', cat: 'お知らせ', title: '春のたまごフェア開催のお知らせ', href: '#' },
  { date: '2025.03.15', cat: 'お知らせ', title: '業務用定期納品サービスをリニューアルしました', href: '#' },
  { date: '2025.02.28', cat: 'お知らせ', title: '温泉卵の新パッケージ販売開始', href: '#' },
  { date: '2025.01.10', cat: 'お知らせ', title: '年始の営業開始のご案内', href: '#' },
];
---

<Layout
  title="小澤鶏卵｜新鮮で安心なたまごを地域へ"
  description="小澤鶏卵は地域の飲食店・施設・ご家庭へ、安全で高品質なたまごをお届けします。"
>
  <Header />
  <main>

    <!-- ===== HERO SLIDER ===== -->
    <section class="hero" aria-label="ヒーロー">
      <div class="hero-slider" id="hero-slider">
        {heroSlides.map((slide, i) => (
          <div class={`hero-slide ${i === 0 ? 'active' : ''}`} aria-hidden={i !== 0}>
            <img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} />
          </div>
        ))}
        <!-- オーバーレイコンテンツ -->
        <div class="hero-overlay">
          <div class="hero-content">
            <p class="hero-eyebrow">Since 1965 — 地域とともに</p>
            <h1 class="hero-title">
              新鮮で安心な<br />
              <span class="hero-title-accent">たまご</span>を、<br />
              毎日の食卓へ。
            </h1>
            <p class="hero-sub">
              小澤鶏卵は産地と食卓をつなぐ、<br class="sp-br"/>地域密着の鶏卵専門店です。
            </p>
            <div class="hero-btns">
              <a href="/products" class="btn-yellow">
                商品を見る
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </a>
              <a href="/contact" class="btn-outline" style="background:white;">
                お問い合わせ
              </a>
            </div>
          </div>
          <!-- 雲の装飾 -->
          <div class="hero-cloud hero-cloud--left" aria-hidden="true">
            <svg viewBox="0 0 200 110" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="100" cy="65" rx="95" ry="50" fill="white" opacity="0.9"/>
              <ellipse cx="60" cy="75" rx="65" ry="44" fill="white" opacity="0.9"/>
              <ellipse cx="145" cy="70" rx="70" ry="42" fill="white" opacity="0.9"/>
            </svg>
          </div>
          <div class="hero-cloud hero-cloud--right" aria-hidden="true">
            <svg viewBox="0 0 180 100" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="90" cy="60" rx="85" ry="46" fill="white" opacity="0.85"/>
              <ellipse cx="52" cy="68" rx="58" ry="38" fill="white" opacity="0.85"/>
              <ellipse cx="132" cy="64" rx="62" ry="36" fill="white" opacity="0.85"/>
            </svg>
          </div>
        </div>
        <!-- ドット -->
        <div class="hero-dots" role="tablist" aria-label="スライド選択">
          {heroSlides.map((_, i) => (
            <button class={`hero-dot ${i === 0 ? 'active' : ''}`} role="tab" aria-selected={i === 0} data-index={i} aria-label={`スライド${i+1}`}></button>
          ))}
        </div>
      </div>

      <!-- 山の波形 -->
      <div class="hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 100" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,60 C180,100 360,20 540,60 C720,100 900,20 1080,60 C1260,100 1350,40 1440,60 L1440,100 L0,100 Z" fill="#FFFCE8"/>
        </svg>
      </div>
    </section>

    <!-- ===== ABOUT ===== -->
    <section class="about-section" id="about">
      <!-- 山のイラスト背景 -->
      <div class="about-mountain" aria-hidden="true">
        <img src="/images/about_bg.svg" alt="" loading="lazy" />
      </div>

      <div class="about-inner">
        <div class="about-illust" aria-hidden="true">
          <!-- 大きなたまご＋鶏 -->
          <svg viewBox="0 0 340 420" xmlns="http://www.w3.org/2000/svg" class="about-egg-svg">
            <defs>
              <radialGradient id="aeg" cx="38%" cy="32%" r="58%">
                <stop offset="0%" stop-color="#FFFEF5"/>
                <stop offset="100%" stop-color="#E8DFC8"/>
              </radialGradient>
              <radialGradient id="ayk" cx="40%" cy="38%" r="55%">
                <stop offset="0%" stop-color="#FFD840"/>
                <stop offset="100%" stop-color="#C08010"/>
              </radialGradient>
            </defs>
            <!-- 卵 -->
            <ellipse cx="170" cy="230" rx="120" ry="155" fill="url(#aeg)" stroke="#D4C080" stroke-width="2"/>
            <ellipse cx="170" cy="245" rx="65" ry="82" fill="url(#ayk)" opacity="0.52"/>
            <ellipse cx="140" cy="198" rx="30" ry="19" fill="white" opacity="0.42" transform="rotate(-22,140,198)"/>
            <!-- ニワトリ(上に乗ってる感じ) -->
            <g transform="translate(170,82)">
              <ellipse cx="0" cy="18" rx="40" ry="28" fill="#F5E8C0" stroke="#D4B880" stroke-width="1.5"/>
              <circle cx="0" cy="-8" r="22" fill="#F5E8C0" stroke="#D4B880" stroke-width="1.5"/>
              <polygon points="15,-8 26,-3 15,0" fill="#F4A020"/>
              <ellipse cx="-2" cy="-26" rx="9" ry="5.5" fill="#E04040"/>
              <circle cx="10" cy="-12" r="5" fill="#333"/>
              <circle cx="11" cy="-13" r="2" fill="white"/>
              <!-- 羽 -->
              <ellipse cx="-32" cy="12" rx="20" ry="10" fill="#E8D8A0" stroke="#C8B870" stroke-width="1" transform="rotate(-25,-32,12)"/>
              <ellipse cx="32" cy="12" rx="20" ry="10" fill="#E8D8A0" stroke="#C8B870" stroke-width="1" transform="rotate(25,32,12)"/>
              <!-- 足 -->
              <line x1="-12" y1="46" x2="-18" y2="70" stroke="#F4A020" stroke-width="3" stroke-linecap="round"/>
              <line x1="12" y1="46" x2="8" y2="70" stroke="#F4A020" stroke-width="3" stroke-linecap="round"/>
            </g>
            <!-- 小さいひよこ -->
            <g transform="translate(48,348)">
              <ellipse cx="0" cy="0" rx="18" ry="14" fill="#FFD840" opacity="0.9"/>
              <circle cx="0" cy="-16" r="12" fill="#FFD840" opacity="0.9"/>
              <polygon points="7,-16 14,-12 7,-10" fill="#F4A020"/>
              <line x1="-6" y1="14" x2="-9" y2="30" stroke="#F4A020" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="5" y1="14" x2="3" y2="30" stroke="#F4A020" stroke-width="2.5" stroke-linecap="round"/>
            </g>
            <g transform="translate(290,340)">
              <ellipse cx="0" cy="0" rx="16" ry="12" fill="#FFD840" opacity="0.85"/>
              <circle cx="0" cy="-14" r="10" fill="#FFD840" opacity="0.85"/>
              <polygon points="6,-14 12,-10 6,-8" fill="#F4A020"/>
              <line x1="-5" y1="12" x2="-8" y2="26" stroke="#F4A020" stroke-width="2" stroke-linecap="round"/>
              <line x1="4" y1="12" x2="2" y2="26" stroke="#F4A020" stroke-width="2" stroke-linecap="round"/>
            </g>
          </svg>
        </div>

        <div class="about-text">
          <span class="section-en">About Us</span>
          <h2 class="section-title">
            幸せは、<br />
            自然のなかにある。
          </h2>
          <div class="about-body">
            <p>
              おひさまを浴びる幸せ。<br />
              気持ちのいい風にあたる幸せ。<br />
              新鮮なものを食べる幸せ。
            </p>
            <p>
              自然がくれるのは、そんなふとした贈り物のような幸せ。
              地域の食卓に寄り添い続けて60年、小澤鶏卵は産地との信頼関係を大切に、毎日新鮮で安心なたまごをお届けしてきました。
            </p>
            <p>
              これからも、安全・安心・おいしいたまごを通じて、皆さまの日々の幸せに貢献し続けます。
            </p>
          </div>

          <div class="about-links">
            <a href="/company" class="btn-yellow">
              私たちについて
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </a>
            <ul class="about-sub-links">
              <li><a href="/company#philosophy">小澤鶏卵の想い</a></li>
              <li><a href="/company#history">歩み</a></li>
              <li><a href="/company">会社概要</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- 波形下 -->
      <div class="section-wave-bottom" aria-hidden="true">
        <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,20 1440,40 L1440,80 L0,80 Z" fill="white"/>
        </svg>
      </div>
    </section>

    <!-- ===== NEWS ===== -->
    <section class="news-section">
      <div class="news-mountain" aria-hidden="true">
        <svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,60 C180,10 360,100 540,50 C720,0 900,90 1080,45 C1260,0 1380,70 1440,50 L1440,0 L0,0 Z" fill="white"/>
        </svg>
      </div>

      <div class="news-inner">
        <div class="news-header">
          <div>
            <span class="section-en">News</span>
            <h2 class="section-title">お知らせ</h2>
          </div>
          <a href="/news" class="btn-outline">お知らせ一覧</a>
        </div>

        <ul class="news-list">
          {news.map(item => (
            <li>
              <a href={item.href} class="news-item">
                <span class="news-date">{item.date}</span>
                <span class="news-cat">{item.cat}</span>
                <span class="news-title">{item.title}</span>
                <svg class="news-arrow" width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="section-wave-bottom" aria-hidden="true">
        <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,30 C240,80 480,10 720,50 C960,90 1200,10 1440,50 L1440,80 L0,80 Z" fill="#FFFCE8"/>
        </svg>
      </div>
    </section>

    <!-- ===== PRODUCTS ===== -->
    <section class="products-section">
      <div class="products-inner">
        <div class="products-header">
          <span class="section-en">Products</span>
          <h2 class="section-title">小澤鶏卵のたまご</h2>
          <p class="products-lead">
            60年のノウハウが詰まった<br />
            自慢のたまごをご紹介します。
          </p>
        </div>

        <!-- スライダー風カード -->
        <div class="products-slider" id="products-slider">
          {products.map((p, i) => (
            <article class={`product-card ${i === 0 ? 'active' : ''}`}>
              <div class="product-img-wrap">
                <img src={p.src} alt={p.name} loading="lazy" />
                <span class="product-badge">{p.badge}</span>
              </div>
              <div class="product-card-body">
                <h3>{p.name}</h3>
                <p>{p.desc}</p>
                <a href={p.href} class="btn-yellow">
                  商品詳細
                  <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- スライダードット -->
        <div class="products-dots">
          {products.map((_, i) => (
            <button class={`products-dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`商品${i+1}`}></button>
          ))}
        </div>

        <div class="products-cta">
          <a href="/products" class="btn-green">
            すべての商品を見る
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="features-section">
      <div class="features-mountain-top" aria-hidden="true">
        <svg viewBox="0 0 1440 100" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,50 C360,100 720,0 1080,50 C1260,75 1380,25 1440,50 L1440,100 L0,100 Z" fill="#FFFCE8"/>
        </svg>
      </div>

      <div class="features-inner">
        <div class="features-header">
          <span class="section-en" style="color:rgba(255,255,255,0.7)">Quality</span>
          <h2 class="section-title" style="color:white">
            たまごへのこだわり
          </h2>
          <p style="color:rgba(255,255,255,0.75);font-size:0.9rem;line-height:1.8;max-width:480px;margin:0 auto;">
            全ては美味しいたまごを食卓へ届けるために。<br />
            小澤鶏卵のこだわりをお伝えします。
          </p>
        </div>

        <div class="features-grid">
          {features.map(f => (
            <a href={f.href} class="feature-card">
              <div class="feature-img">
                <img src={f.src} alt={f.title} loading="lazy" />
              </div>
              <div class="feature-info">
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
                <span class="feature-link">
                  詳しく見る →
                </span>
              </div>
            </a>
          ))}
        </div>

        <div style="text-align:center;margin-top:3rem">
          <a href="/quality" class="btn-yellow">
            こだわりをすべて見る
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>

      <div class="features-mountain-bottom" aria-hidden="true">
        <svg viewBox="0 0 1440 100" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,50 C360,0 720,100 1080,50 C1260,25 1380,75 1440,50 L1440,0 L0,0 Z" fill="#FFFCE8"/>
        </svg>
      </div>
    </section>

    <!-- ===== CONTACT CTA ===== -->
    <section class="cta-section">
      <div class="cta-inner">
        <!-- たまごのイラスト -->
        <div class="cta-illust" aria-hidden="true">
          <svg viewBox="0 0 180 220" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="90" cy="120" rx="72" ry="92" fill="#FFF8C0" stroke="#F2C94C" stroke-width="2"/>
            <ellipse cx="90" cy="130" rx="38" ry="48" fill="#F2C94C" opacity="0.5"/>
            <ellipse cx="72" cy="98" rx="20" ry="13" fill="white" opacity="0.4" transform="rotate(-22,72,98)"/>
          </svg>
        </div>
        <div class="cta-text">
          <span class="section-en">Contact</span>
          <h2 class="section-title">ご注文・お問い合わせ</h2>
          <p>
            業務用のご注文から個人のお客様まで、<br />
            お気軽にご相談ください。
          </p>
          <div class="cta-btns">
            <a href="/contact" class="btn-yellow">
              お問い合わせはこちら
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </a>
            <a href="tel:0000-00-0000" class="cta-tel">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 3h4l2 4-2 1.5c.8 1.6 2 2.8 3.5 3.5L13 10l4 2v4a1.5 1.5 0 01-1.5 1.5C5 16.5 1.5 10 1.5 4.5A1.5 1.5 0 013 3h1z" stroke="#5A9A50" stroke-width="1.5" fill="none"/></svg>
              0000-00-0000
            </a>
          </div>
        </div>
        <div class="cta-illust cta-illust--right" aria-hidden="true">
          <svg viewBox="0 0 160 200" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="80" cy="108" rx="62" ry="80" fill="#FFF8C0" stroke="#F2C94C" stroke-width="2"/>
            <ellipse cx="80" cy="116" rx="32" ry="40" fill="#F2C94C" opacity="0.45"/>
            <ellipse cx="64" cy="88" rx="18" ry="11" fill="white" opacity="0.38" transform="rotate(-22,64,88)"/>
          </svg>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* ===== HERO ===== */
.hero { position: relative; }
.hero-slider {
  position: relative;
  height: 100svh;
  min-height: 560px;
  overflow: hidden;
}
.hero-slide {
  position: absolute; inset: 0;
  opacity: 0;
  transition: opacity 0.8s ease;
}
.hero-slide.active { opacity: 1; }
.hero-slide img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.hero-overlay {
  position: absolute; inset: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 8vw;
  padding-top: 72px;
  background: linear-gradient(to right, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
}
.hero-content { max-width: 560px; }
.hero-eyebrow {
  font-family: 'Lato', sans-serif;
  font-size: 0.72rem;
  letter-spacing: 0.26em;
  color: #F2C94C;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 2rem;
  height: 1px;
  background-color: #F2C94C;
  opacity: 0.7;
}
.hero-title {
  font-family: 'Zen Maru Gothic', sans-serif;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  color: white;
  line-height: 1.45;
  letter-spacing: 0.04em;
  margin-bottom: 1rem;
  text-shadow: 0 2px 12px rgba(0,0,0,0.3);
}
.hero-title-accent {
  color: #F2C94C;
}
.hero-sub {
  font-size: clamp(0.875rem, 1.5vw, 1rem);
  color: rgba(255,255,255,0.85);
  line-height: 1.8;
  margin-bottom: 2.25rem;
}
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

/* 雲 */
.hero-cloud {
  position: absolute;
  bottom: 80px;
  opacity: 0.92;
}
.hero-cloud--left { left: -20px; width: 220px; }
.hero-cloud--right { right: 5%; width: 180px; }

/* ドット */
.hero-dots {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 10;
}
.hero-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  border: none; cursor: pointer;
  transition: all 0.3s;
  padding: 0;
}
.hero-dot.active {
  background: #F2C94C;
  transform: scale(1.25);
}

/* Wave */
.hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0;
}
.hero-wave svg { display: block; width: 100%; height: 70px; }

/* ===== ABOUT ===== */
.about-section {
  background: #FFFCE8;
  padding: 6rem 0 0;
  position: relative;
  overflow: hidden;
}
.about-mountain {
  position: absolute; inset: 0;
  z-index: 0;
}
.about-mountain img {
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0.25;
}
.about-inner {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 5rem;
  align-items: center;
  padding-bottom: 5rem;
}
