<script>
// Hero slider
const heroSlides = document.querySelectorAll('.hero-slide');
const heroDots = document.querySelectorAll('.hero-dot');
let currentHero = 0;

function goToHero(n: number) {
  heroSlides[currentHero].classList.remove('active');
  heroDots[currentHero].classList.remove('active');
  currentHero = (n + heroSlides.length) % heroSlides.length;
  heroSlides[currentHero].classList.add('active');
  heroDots[currentHero].classList.add('active');
}

heroDots.forEach((dot, i) => dot.addEventListener('click', () => goToHero(i)));
let heroTimer = setInterval(() => goToHero(currentHero + 1), 4500);
document.querySelector('.hero-slider')?.addEventListener('mouseenter', () => clearInterval(heroTimer));
document.querySelector('.hero-slider')?.addEventListener('mouseleave', () => {
  heroTimer = setInterval(() => goToHero(currentHero + 1), 4500);
});

// Products slider (mobile)
const prodCards = document.querySelectorAll('.product-card');
const prodDots = document.querySelectorAll('.products-dot');
let currentProd = 0;

function goToProd(n: number) {
  if (window.innerWidth > 900) return;
  prodCards[currentProd].classList.remove('active');
  prodDots[currentProd].classList.remove('active');
  currentProd = (n + prodCards.length) % prodCards.length;
  prodCards[currentProd].classList.add('active');
  prodDots[currentProd].classList.add('active');
}
prodDots.forEach((dot, i) => dot.addEventListener('click', () => goToProd(i)));
</script>
