---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const news = [
  { tag: 'お知らせ', tagType: 'info', date: '2026.06.01', title: '夏季の配送スケジュールについてのご案内' },
  { tag: 'お知らせ', tagType: 'info', date: '2026.05.15', title: '業務用定期納品サービスをリニューアルしました' },
  { tag: 'お知らせ', tagType: 'farm', date: '2026.04.20', title: '新しい取引農場との連携を開始しました' },
  { tag: 'お知らせ', tagType: 'info', date: '2026.03.10', title: '春の新商品「春のたまごセット」販売開始' },
  { tag: 'お知らせ', tagType: 'info', date: '2026.02.01', title: '年始営業のご案内' },
];

const products = [
  {
    img: '/images/product1.png',
    badge: '人気No.1',
    name: '新鮮たまご',
    desc: '産地直送で毎朝入荷。ふっくらとした黄身と締まった白身が自慢の、地域で一番愛されるたまごです。',
    href: '/products#fresh',
  },
  {
    img: '/images/product2.png',
    badge: '業務用人気！',
    name: '業務用たまご',
    desc: '飲食店・給食・製菓など大量のご要望に。規格・サイズ別に安定供給いたします。定期納品対応。',
    href: '/products#business',
  },
  {
    img: '/images/product3.png',
    badge: 'とろとろ食感',
    name: '温泉卵・加工品',
    desc: 'こだわりの温度管理で仕上げた温泉卵。黄身がとろりとやわらかく、飲食店でそのままお使いいただけます。',
    href: '/products#processed',
  },
];
---

<Layout
  title="小澤鶏卵｜新鮮で安心なたまごを地域へ"
  description="小澤鶏卵は地域の飲食店・施設・ご家庭へ、安全で高品質なたまごをお届けします。新鮮・安全・安定供給を大切にした卵の販売・卸売。"
>
  <Header />
  <main>

    <!-- ========== HERO SLIDER ========== -->
    <section class="hero" aria-label="ヒーローセクション">
      <div class="hero-slider" id="hero-slider">
        {['hero1','hero2','hero3','hero4'].map((name, i) => (
          <div class={`hero-slide ${i===0?'active':''}`} style={`background-image:url('/images/${name}.png')`}>
            <div class="hero-slide-overlay"></div>
          </div>
        ))}
      </div>

      <!-- コピー -->
      <div class="hero-content">
        <div class="hero-cloud" aria-hidden="true">
          <svg viewBox="0 0 300 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="100" cy="55" rx="95" ry="42" fill="white" opacity="0.92"/>
            <ellipse cx="160" cy="42" rx="75" ry="38" fill="white" opacity="0.9"/>
            <ellipse cx="215" cy="58" rx="70" ry="35" fill="white" opacity="0.88"/>
            <ellipse cx="60"  cy="62" rx="55" ry="28" fill="white" opacity="0.85"/>
          </svg>
        </div>
        <h1 class="hero-title">
          新鮮で安心な<br />
          <em>たまご</em>を、<br />
          毎日の食卓へ。
        </h1>
        <p class="hero-sub">地域の飲食店・施設・ご家庭へ<br />安全で高品質なたまごをお届けします</p>
        <div class="hero-btns">
          <a href="/products" class="btn-yellow">商品案内を見る</a>
          <a href="/contact" class="btn-outline-green-hero">お問い合わせ</a>
        </div>
      </div>

      <!-- スライダードット -->
      <div class="hero-dots" aria-label="スライダーコントロール">
        {[0,1,2,3].map(i => (
          <button class={`hero-dot ${i===0?'active':''}`} data-index={i} aria-label={`スライド${i+1}`}></button>
        ))}
      </div>

      <!-- 山の装飾 -->
      <div class="hero-mountain" aria-hidden="true">
        <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 120 L0 90 Q180 20 360 65 Q540 110 720 50 Q900 10 1080 70 Q1260 110 1440 55 L1440 120 Z" fill="rgba(255,255,255,0.3)"/>
          <path d="M0 120 L0 100 Q240 50 480 85 Q720 115 960 70 Q1200 30 1440 80 L1440 120 Z" fill="white"/>
        </svg>
      </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section class="about-section" id="about">
      <!-- 雲の装飾 -->
      <div class="cloud-deco cloud-deco--left" aria-hidden="true">
        <svg viewBox="0 0 200 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="80" cy="50" rx="75" ry="38" fill="white" opacity="0.7"/>
          <ellipse cx="120" cy="38" rx="55" ry="30" fill="white" opacity="0.65"/>
          <ellipse cx="40"  cy="55" rx="38" ry="22" fill="white" opacity="0.6"/>
        </svg>
      </div>
      <div class="cloud-deco cloud-deco--right" aria-hidden="true">
        <svg viewBox="0 0 180 70" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="100" cy="45" rx="75" ry="35" fill="white" opacity="0.65"/>
          <ellipse cx="55"  cy="35" rx="50" ry="28" fill="white" opacity="0.6"/>
          <ellipse cx="145" cy="48" rx="35" ry="20" fill="white" opacity="0.55"/>
        </svg>
      </div>

      <div class="about-bg-img" aria-hidden="true"></div>

      <div class="container">
        <div class="about-inner">
          <!-- イラスト群 -->
          <div class="about-illust" aria-hidden="true">
            <!-- 大きな卵 -->
            <div class="illust-egg illust-egg--main">
              <svg viewBox="0 0 180 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="90" cy="120" rx="70" ry="90" fill="#f5f0e0" stroke="#e8d340" stroke-width="1.5"/>
                <ellipse cx="90" cy="128" rx="38" ry="50" fill="#f2c94c" opacity="0.55"/>
                <ellipse cx="72" cy="100" rx="18" ry="12" fill="white" opacity="0.45" transform="rotate(-22,72,100)"/>
              </svg>
            </div>
            <!-- ひよこ -->
            <div class="illust-chick">
              <svg viewBox="0 0 80 90" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- 体 -->
                <ellipse cx="40" cy="60" rx="28" ry="24" fill="#f5c842"/>
                <!-- 頭 -->
                <circle cx="40" cy="34" r="18" fill="#f5c842"/>
                <!-- 目 -->
                <circle cx="34" cy="32" r="3" fill="#333"/>
                <circle cx="35" cy="31" r="1" fill="white"/>
                <!-- くちばし -->
                <path d="M40 37 L44 40 L40 42 Z" fill="#e88c20"/>
                <!-- 羽 -->
                <ellipse cx="18" cy="58" rx="10" ry="7" fill="#f0b830" transform="rotate(-20,18,58)"/>
                <ellipse cx="62" cy="58" rx="10" ry="7" fill="#f0b830" transform="rotate(20,62,58)"/>
                <!-- 足 -->
                <path d="M30 82 L27 90 M30 82 L33 90 M30 82 L36 88" stroke="#e88c20" stroke-width="2" stroke-linecap="round"/>
                <path d="M50 82 L47 90 M50 82 L53 90 M50 82 L56 88" stroke="#e88c20" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <!-- 小さい卵たち -->
            <div class="illust-egg illust-egg--sm1">
              <svg viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="40" cy="56" rx="30" ry="38" fill="#faf7f0" stroke="#e8d340" stroke-width="1"/>
                <ellipse cx="40" cy="60" rx="16" ry="22" fill="#f2c94c" opacity="0.45"/>
              </svg>
            </div>
            <div class="illust-egg illust-egg--sm2">
              <svg viewBox="0 0 60 76" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="30" cy="42" rx="22" ry="28" fill="#faf7f0" stroke="#e8d340" stroke-width="1"/>
                <ellipse cx="30" cy="45" rx="12" ry="16" fill="#f2c94c" opacity="0.4"/>
              </svg>
            </div>
          </div>

          <div class="about-text">
            <span class="sec-en">About Us</span>
            <h2 class="about-catch">
              幸せは、<br />
              新鮮なたまごのなかにある。
            </h2>
            <div class="about-body-text">
              <p>
                おひさまを浴びる幸せ。<br />
                気持ちのいい風にあたる幸せ。<br />
                新鮮なものを食べる幸せ。
              </p>
              <p>
                自然がくれるのは、そんなふとした贈り物のような幸せ。
                小澤鶏卵は1965年の創業以来、地域の食卓にそんな幸せをお届けしてきました。
              </p>
              <p>
                信頼できる生産者との連携のもと、毎日の品質管理を徹底し、
                飲食店・施設・ご家庭に安全で新鮮なたまごをお届けし続けています。
              </p>
            </div>

            <div class="about-links">
              <a href="/company" class="btn-yellow">
                小澤鶏卵について
                <svg width="16" height="12" viewBox="0 0 16 12" fill="none"><path d="M10 1l5 5-5 5M1 6h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </a>
            </div>

            <ul class="about-sub-links">
              <li><a href="/company">会社概要</a></li>
              <li><a href="/quality">品質へのこだわり</a></li>
              <li><a href="/company#access">アクセス</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- 山形区切り（下） -->
      <div class="about-mountain-bottom" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 0 L0 40 Q360 80 720 30 Q1080 0 1440 50 L1440 0 Z" fill="white"/>
        </svg>
      </div>
    </section>

    <!-- ========== NEWS ========== -->
    <section class="news-section">
      <!-- 山形区切り（上） -->
      <div class="news-mountain-top" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 80 L0 55 Q360 10 720 50 Q1080 80 1440 35 L1440 80 Z" fill="white"/>
        </svg>
      </div>

      <div class="container">
        <div class="news-header">
          <div>
            <span class="sec-en">News</span>
            <h2 class="sec-ja">お知らせ</h2>
          </div>
          <a href="/news" class="btn-outline-green">一覧を見る</a>
        </div>

        <ul class="news-list">
          {news.map(item => (
            <li class="news-item">
              <a href="/news">
                <span class={`news-tag news-tag--${item.tagType}`}>{item.tag}</span>
                <time class="news-date">{item.date}</time>
                <span class="news-title">{item.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ========== PRODUCTS LINE UP ========== -->
    <section class="lineup-section">
      <!-- 区切り -->
      <div class="lineup-mountain-top" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 0 L0 50 Q480 80 720 40 Q960 10 1440 60 L1440 0 Z" fill="#fffde8"/>
        </svg>
      </div>

      <div class="container">
        <div class="lineup-header">
          <span class="sec-en">Line Up</span>
          <h2 class="sec-ja">商品案内</h2>
          <p class="lineup-lead">
            小澤鶏卵の技術と誠実さが詰まった、<br />
            自慢のたまごをご紹介します。
          </p>
        </div>

        <div class="lineup-slider">
          {products.map((p, i) => (
            <article class="lineup-card">
              <div class="lineup-card-img">
                <img src={p.img} alt={p.name} loading={i===0?'eager':'lazy'} />
                <span class="lineup-badge">{p.badge}</span>
              </div>
              <div class="lineup-card-body">
                <h3>{p.name}</h3>
                <p>{p.desc}</p>
                <a href={p.href} class="lineup-card-link">
                  商品詳細
                  <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="lineup-cta">
          <a href="/products" class="btn-yellow">
            すべての商品を見る
            <svg width="16" height="12" viewBox="0 0 16 12" fill="none"><path d="M10 1l5 5-5 5M1 6h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== QUALITY FEATURE ========== -->
    <section class="feature-section">
      <div class="feature-mountain-top" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 80 L0 50 Q360 10 720 55 Q1080 90 1440 40 L1440 80 Z" fill="#fffde8"/>
        </svg>
      </div>

      <div class="container">
        <div class="feature-header">
          <span class="sec-en">Feature</span>
          <h2 class="sec-ja">品質へのこだわり</h2>
          <p class="feature-lead">
            全ては美味しいたまごを<br />
            食卓へ届けるために。<br />
            小澤鶏卵のこだわりをお伝えします。
          </p>
        </div>

        <div class="feature-grid">
          <div class="feature-card">
            <div class="feature-card-img">
              <img src="/images/feature1.png" alt="鮮度管理" loading="lazy" />
              <div class="feature-card-overlay">
                <h3>鮮度管理</h3>
                <p>産地直送・当日入荷にこだわり、常に新鮮なたまごをお届けします。</p>
              </div>
            </div>
          </div>
          <div class="feature-card">
            <div class="feature-card-img">
              <img src="/images/feature2.png" alt="衛生管理" loading="lazy" />
              <div class="feature-card-overlay">
                <h3>衛生管理</h3>
                <p>保管・配送の全工程で温度・衛生基準を厳守しています。</p>
              </div>
            </div>
          </div>
          <div class="feature-card">
            <div class="feature-card-img">
              <img src="/images/feature3.png" alt="生産者連携" loading="lazy" />
              <div class="feature-card-overlay">
                <h3>生産者との連携</h3>
                <p>顔の見える仕入れ体制で安心・安全を確保しています。</p>
              </div>
            </div>
          </div>
        </div>

        <div class="feature-cta">
          <a href="/quality" class="btn-yellow">
            品質へのこだわりを知る
            <svg width="16" height="12" viewBox="0 0 16 12" fill="none"><path d="M10 1l5 5-5 5M1 6h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== CONTACT CTA ========== -->
    <section class="cta-section">
      <div class="cta-mountain-top" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 0 L0 45 Q480 80 720 35 Q960 5 1440 55 L1440 0 Z" fill="white"/>
        </svg>
      </div>
      <div class="container">
        <div class="cta-inner">
          <span class="sec-en" style="color:rgba(255,255,255,0.7)">Contact</span>
          <h2 class="cta-title">ご注文・お問い合わせ</h2>
          <p class="cta-text">業務用のご注文から個人のお客様まで、お気軽にご相談ください。</p>
          <div class="cta-methods">
            <div class="cta-method">
              <div class="cta-method-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                  <path d="M5 4h5l2 5-2.5 1.5c1 2 2.5 3.5 4.5 4.5L15.5 13l5 2v5c0 .8-.7 1.5-1.5 1.5C8 21 4.5 13.5 4.5 7.5 4.5 5.7 5.2 5 5 4z" stroke="#f1e16d" stroke-width="1.5" fill="none"/>
                </svg>
              </div>
              <div>
                <p class="cta-method-label">お電話</p>
                <a href="tel:0000-00-0000" class="cta-phone">0000-00-0000</a>
                <p class="cta-method-note">月〜土 8:00〜17:00</p>
              </div>
            </div>
            <div class="cta-divider"></div>
            <div class="cta-method">
              <div class="cta-method-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                  <rect x="3" y="7" width="22" height="15" rx="2" stroke="#f1e16d" stroke-width="1.5"/>
                  <path d="M3 9l11 7.5L25 9" stroke="#f1e16d" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <p class="cta-method-label">フォーム・メール</p>
                <a href="/contact" class="cta-form-link">お問い合わせフォームへ</a>
                <p class="cta-method-note">24時間受付・翌営業日ご返信</p>
              </div>
            </div>
          </div>
          <a href="/contact" class="cta-btn">お問い合わせはこちら</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* ===== HERO ===== */
.hero {
  position: relative;
  height: 100svh;
  min-height: 560px;
  overflow: hidden;
}

.hero-slider {
  position: absolute;
  inset: 0;
}

.hero-slide {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 1s ease;
}
.hero-slide.active { opacity: 1; }

.hero-slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.15) 0%,
    rgba(0,0,0,0.1) 50%,
    rgba(255,255,255,0) 100%
  );
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  text-align: center;
  padding: 70px 2rem 120px;
  gap: 1.25rem;
}

.hero-cloud {
  width: min(360px, 80vw);
  margin-bottom: 0.5rem;
  animation: cloudFloat 8s ease-in-out infinite;
}

@keyframes cloudFloat {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.hero-title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  color: #333;
  line-height: 1.5;
  letter-spacing: 0.06em;
  text-shadow: 0 2px 20px rgba(255,255,255,0.8);
}

.hero-title em {
  font-style: normal;
  color: var(--color-green-d);
}

.hero-sub {
  font-size: clamp(0.875rem, 1.5vw, 1.05rem);
  color: #444;
  line-height: 1.8;
  text-shadow: 0 1px 8px rgba(255,255,255,0.9);
}

.hero-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 0.5rem;
}

.btn-outline-green-hero {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 2.25rem;
  border: 2px solid var(--color-green);
  color: var(--color-green);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  border-radius: 50px;
  text-decoration: none;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(4px);
  transition: all 0.2s;
}
.btn-outline-green-hero:hover {
  background: var(--color-green);
  color: white;
}

.hero-dots {
  position: absolute;
  bottom: 100px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0.625rem;
  z-index: 3;
}

.hero-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  border: 2px solid white;
  background: transparent;
  cursor: pointer;
  transition: background 0.2s;
  padding: 0;
}
.hero-dot.active { background: white; }

.hero-mountain {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  z-index: 2;
  line-height: 0;
}
.hero-mountain svg { display: block; width: 100%; }

/* ===== ABOUT ===== */
.about-section {
  position: relative;
  background: linear-gradient(to bottom, #eaf6ff 0%, #d4eef8 40%, #c8e8a0 100%);
  padding: 5rem 0 0;
  overflow: hidden;
}

.about-bg-img {
  position: absolute;
  inset: 0;
  background-image: url('/images/about_bg.png');
  background-size: cover;
  background-position: center top;
  opacity: 0.3;
}

.cloud-deco {
  position: absolute;
  z-index: 1;
  pointer-events: none;
  animation: cloudFloat 10s ease-in-out infinite;
}
.cloud-deco--left { top: 80px; left: -30px; width: 200px; }
.cloud-deco--right { top: 120px; right: -20px; width: 180px; animation-delay: -4s; }
.cloud-deco svg { width: 100%; }

.container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem;
  position: relative;
  z-index: 2;
}

.about-inner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 5rem;
  align-items: center;
  padding-bottom: 5rem;
}

/* Illustrations */
.about-illust {
  position: relative;
  height: 400px;
}

.illust-egg { position: absolute; }
.illust-egg--main {
  width: 160px;
  top: 60px; left: 50%;
  transform: translateX(-50%);
  filter: drop-shadow(0 8px 24px rgba(0,0,0,0.1));
  animation: eggFloat 6s ease-in-out infinite;
}
.illust-chick {
  position: absolute;
  width: 90px;
  bottom: 30px; right: 20px;
  animation: eggFloat 5s ease-in-out infinite;
  animation-delay: -2s;
}
.illust-chick svg { width: 100%; }

.illust-egg--sm1 {
  width: 90px;
  bottom: 50px; left: 10px;
  animation: eggFloat 7s ease-in-out infinite;
  animation-delay: -1s;
}
.illust-egg--sm2 {
  width: 68px;
  top: 40px; right: 40px;
  animation: eggFloat 8s ease-in-out infinite;
  animation-delay: -3s;
}
.illust-egg svg, .illust-egg--sm1 svg, .illust-egg--sm2 svg { width: 100%; }

@keyframes eggFloat {
  0%,100% { transform: translateY(0) translateX(-50%); }
  50% { transform: translateY(-12px) translateX(-50%); }
}
.illust-egg--sm1, .illust-egg--sm2, .illust-chick {
  animation-name: eggFloatSimple;
}
@keyframes eggFloatSimple {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

