---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="小澤鶏卵｜新鮮で安心なたまごを地域へ"
  description="小澤鶏卵は地域の飲食店・施設・ご家庭へ、安全で高品質なたまごをお届けします。新鮮・安全・安定供給を大切にした卵の販売・卸売。"
>
  <Header />
  <main>

    <!-- ===================== HERO ===================== -->
    <section class="hero" aria-label="ヒーローセクション">
      <!-- 背景：大きな卵のビジュアル -->
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-bg-dark"></div>
        <!-- 大きなたまごシルエット -->
        <svg class="hero-egg-bg" viewBox="0 0 800 1000" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
          <defs>
            <radialGradient id="heroEggGrad" cx="42%" cy="38%" r="55%">
              <stop offset="0%" stop-color="#FAF7F2" stop-opacity="0.06"/>
              <stop offset="60%" stop-color="#F2C94C" stop-opacity="0.04"/>
              <stop offset="100%" stop-color="#D4A017" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <ellipse cx="600" cy="530" rx="340" ry="430" fill="url(#heroEggGrad)" stroke="rgba(242,201,76,0.08)" stroke-width="1"/>
          <ellipse cx="600" cy="530" rx="220" ry="280" fill="rgba(242,201,76,0.03)" stroke="rgba(242,201,76,0.05)" stroke-width="1"/>
        </svg>
        <!-- 右側のテクスチャライン -->
        <div class="hero-lines" aria-hidden="true">
          {Array.from({length: 8}).map((_, i) => (
            <div class="hero-line" style={`--i: ${i}`}></div>
          ))}
        </div>
      </div>

      <div class="hero-content">
        <div class="hero-left">
          <p class="hero-eyebrow">Since 1965 — 地域とともに</p>
          <h1 class="hero-title">
            <span class="hero-title-small">新鮮で安心な</span>
            <span class="hero-title-large">たまごを、</span>
            <span class="hero-title-large">毎日の食卓へ</span>
          </h1>
          <p class="hero-sub">
            小澤鶏卵は地域の飲食店・施設・ご家庭へ、<br />
            安全で高品質なたまごをお届けします。
          </p>
          <div class="hero-ctas">
            <a href="/contact" class="hero-btn-primary">お問い合わせ</a>
            <a href="/products" class="hero-btn-ghost">商品案内</a>
          </div>
        </div>
        <!-- 右: 卵のイラスト -->
        <div class="hero-visual" aria-hidden="true">
          <div class="hero-egg-wrap">
            <svg viewBox="0 0 360 440" xmlns="http://www.w3.org/2000/svg" class="hero-egg-svg">
              <defs>
                <radialGradient id="hegg1" cx="38%" cy="32%" r="58%">
                  <stop offset="0%" stop-color="#FAF7F2"/>
                  <stop offset="100%" stop-color="#DDD8D0"/>
                </radialGradient>
                <radialGradient id="hyolk" cx="40%" cy="38%" r="55%">
                  <stop offset="0%" stop-color="#F5D35E"/>
                  <stop offset="100%" stop-color="#C8920A"/>
                </radialGradient>
              </defs>
              <!-- 卵の本体 -->
              <ellipse cx="180" cy="240" rx="130" ry="170" fill="url(#hegg1)" stroke="rgba(212,160,23,0.2)" stroke-width="1"/>
              <!-- 黄身 -->
              <ellipse cx="180" cy="252" rx="70" ry="86" fill="url(#hyolk)" opacity="0.55"/>
              <!-- ハイライト -->
              <ellipse cx="148" cy="198" rx="26" ry="17" fill="white" opacity="0.38" transform="rotate(-22,148,198)"/>
              <ellipse cx="162" cy="188" rx="10" ry="6" fill="white" opacity="0.22" transform="rotate(-22,162,188)"/>
            </svg>
            <div class="hero-egg-glow"></div>
          </div>
        </div>
      </div>

      <!-- スクロールインジケーター -->
      <div class="hero-scroll" aria-hidden="true">
        <div class="scroll-track"><div class="scroll-dot"></div></div>
        <span>Scroll</span>
      </div>
    </section>

    <!-- ===================== ABOUT (アイボリー) ===================== -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div class="about-text-col">
            <span class="section-label">About Us</span>
            <h2 class="section-title">地域の食卓を<br />支えて60年</h2>
            <div class="divider"></div>
            <p class="about-lead">
              1965年の創業以来、地域の飲食店・給食施設・ご家庭に新鮮なたまごをお届けしてきました。
            </p>
            <p class="about-body">
              生産者との強い信頼関係のもと、毎日新鮮なたまごを安定的にお届けすることを第一に考えています。飲食店・福祉施設・学校給食から家庭用まで、幅広いニーズにお応えします。
            </p>
            <a href="/company" class="btn-outline">会社概要を見る</a>
          </div>
          <div class="about-features">
            <div class="feature-item">
              <div class="feature-num">01</div>
              <div class="feature-body">
                <h3>地域密着</h3>
                <p>地域の皆様との長年の信頼関係を大切に、きめ細やかなサービスをご提供します。</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-num">02</div>
              <div class="feature-body">
                <h3>安定供給</h3>
                <p>業務用から家庭用まで、ご要望に合わせた安定的な納品体制を整えています。</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-num">03</div>
              <div class="feature-body">
                <h3>品質管理</h3>
                <p>徹底した鮮度・衛生管理により、安全で美味しいたまごをお届けします。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== PRODUCTS (クリーム) ===================== -->
    <section class="products-section">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Products</span>
          <h2 class="section-title">商品案内</h2>
          <div class="divider"></div>
        </div>

        <div class="products-grid">
          <article class="product-card">
            <div class="product-visual pv--fresh" aria-hidden="true">
              <svg viewBox="0 0 240 280" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <radialGradient id="pe1" cx="38%" cy="32%" r="58%">
                    <stop offset="0%" stop-color="#FAF7F2"/>
                    <stop offset="100%" stop-color="#E8E0D4"/>
                  </radialGradient>
                </defs>
                <ellipse cx="120" cy="152" rx="82" ry="104" fill="url(#pe1)" stroke="rgba(212,160,23,0.25)" stroke-width="1"/>
                <ellipse cx="120" cy="160" rx="44" ry="56" fill="#F2C94C" opacity="0.42"/>
                <ellipse cx="100" cy="130" rx="18" ry="11" fill="white" opacity="0.4" transform="rotate(-22,100,130)"/>
              </svg>
            </div>
            <div class="product-info">
              <span class="product-tag">新鮮たまご</span>
              <h3>毎朝入荷の新鮮たまご</h3>
              <p>産地直送で毎朝入荷。ふっくらとした黄身と締まった白身が自慢です。</p>
              <a href="/products#fresh" class="product-link">
                詳しく見る
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </a>
            </div>
          </article>

          <article class="product-card product-card--dark">
            <div class="product-visual pv--business" aria-hidden="true">
              <svg viewBox="0 0 240 280" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <radialGradient id="pe2" cx="38%" cy="32%" r="58%">
                    <stop offset="0%" stop-color="#F5F0E8"/>
                    <stop offset="100%" stop-color="#DDD8D0"/>
                  </radialGradient>
                </defs>
                <ellipse cx="80" cy="160" rx="58" ry="72" fill="url(#pe2)" stroke="rgba(212,160,23,0.2)" stroke-width="1" opacity="0.85"/>
                <ellipse cx="160" cy="160" rx="58" ry="72" fill="#FAF7F2" stroke="rgba(212,160,23,0.2)" stroke-width="1" opacity="0.85"/>
                <ellipse cx="120" cy="148" rx="64" ry="82" fill="url(#pe2)" stroke="rgba(212,160,23,0.3)" stroke-width="1"/>
                <ellipse cx="120" cy="155" rx="34" ry="44" fill="#F2C94C" opacity="0.4"/>
                <ellipse cx="103" cy="128" rx="16" ry="10" fill="white" opacity="0.38" transform="rotate(-22,103,128)"/>
              </svg>
            </div>
            <div class="product-info">
              <span class="product-tag">業務用たまご</span>
              <h3>飲食店・施設向け業務用</h3>
              <p>飲食店・給食・製菓など大量のご要望に対応。定期納品サービスも充実しています。</p>
              <a href="/products#business" class="product-link">
                詳しく見る
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </a>
            </div>
          </article>

          <article class="product-card">
            <div class="product-visual pv--onsen" aria-hidden="true">
              <svg viewBox="0 0 240 280" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <radialGradient id="pe3" cx="38%" cy="32%" r="58%">
                    <stop offset="0%" stop-color="#FAF7F2"/>
                    <stop offset="100%" stop-color="#E0DCD5"/>
                  </radialGradient>
                  <radialGradient id="py3" cx="38%" cy="38%" r="55%">
                    <stop offset="0%" stop-color="#F2C94C"/>
                    <stop offset="100%" stop-color="#C8920A"/>
                  </radialGradient>
                </defs>
                <circle cx="120" cy="152" r="88" fill="url(#pe3)" stroke="rgba(212,160,23,0.25)" stroke-width="1"/>
                <circle cx="120" cy="152" r="56" fill="url(#py3)" opacity="0.5"/>
                <circle cx="120" cy="152" r="28" fill="#D4A017" opacity="0.55"/>
                <ellipse cx="102" cy="132" rx="16" ry="10" fill="white" opacity="0.4" transform="rotate(-22,102,132)"/>
              </svg>
            </div>
            <div class="product-info">
              <span class="product-tag">温泉卵・加工品</span>
              <h3>とろりなめらか温泉卵</h3>
              <p>こだわりの温度管理で仕上げた温泉卵。そのままお使いいただける便利な加工品です。</p>
              <a href="/products#processed" class="product-link">
                詳しく見る
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </a>
            </div>
          </article>
        </div>

        <div class="products-cta">
          <a href="/products" class="btn-primary">すべての商品を見る</a>
        </div>
      </div>
    </section>

    <!-- ===================== QUALITY (ダーク) ===================== -->
    <section class="quality-dark-section">
      <div class="container">
        <div class="quality-dark-grid">
          <div class="quality-dark-visual" aria-hidden="true">
            <div class="qdv-ring qdv-ring--outer"></div>
            <div class="qdv-ring qdv-ring--inner"></div>
            <svg viewBox="0 0 320 400" xmlns="http://www.w3.org/2000/svg" class="qdv-egg">
              <defs>
                <radialGradient id="qdegg" cx="38%" cy="32%" r="58%">
                  <stop offset="0%" stop-color="#FAF7F2" stop-opacity="0.9"/>
                  <stop offset="100%" stop-color="#C8C0B0" stop-opacity="0.7"/>
                </radialGradient>
                <radialGradient id="qdyolk" cx="40%" cy="38%" r="55%">
                  <stop offset="0%" stop-color="#F5D35E"/>
                  <stop offset="100%" stop-color="#B8800A"/>
                </radialGradient>
              </defs>
              <ellipse cx="160" cy="220" rx="110" ry="145" fill="url(#qdegg)" stroke="rgba(242,201,76,0.2)" stroke-width="1"/>
              <ellipse cx="160" cy="232" rx="60" ry="76" fill="url(#qdyolk)" opacity="0.6"/>
              <ellipse cx="136" cy="192" rx="24" ry="15" fill="white" opacity="0.3" transform="rotate(-22,136,192)"/>
            </svg>
            <div class="qdv-label">
              <span>品質</span>
              <span>Quality</span>
            </div>
          </div>

          <div class="quality-dark-text">
            <span class="section-label section-label--light">Quality</span>
            <h2 class="section-title section-title--light">品質への<br />こだわり</h2>
            <div class="divider divider--light"></div>
            <p class="quality-dark-lead">
              たまごの品質は、産地から食卓に届くまでの過程すべてにかかっています。
            </p>

            <ul class="quality-dark-list">
              <li>
                <div class="qdl-num">01</div>
                <div>
                  <strong>鮮度管理</strong>
                  <p>産地直送・当日入荷にこだわり、常に新鮮なたまごをお届けします。</p>
                </div>
              </li>
              <li>
                <div class="qdl-num">02</div>
                <div>
                  <strong>衛生管理</strong>
                  <p>保管・配送の全工程で温度・衛生基準を徹底遵守しています。</p>
                </div>
              </li>
              <li>
                <div class="qdl-num">03</div>
                <div>
                  <strong>安全管理</strong>
                  <p>信頼できる生産者との連携で、安心・安全を確保しています。</p>
                </div>
              </li>
            </ul>

            <a href="/quality" class="btn-outline-dark">品質への取り組みを見る</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== STATEMENT (クリーム) ===================== -->
    <section class="statement-section">
      <div class="container">
        <div class="statement-inner">
          <div class="statement-deco" aria-hidden="true">
            <svg viewBox="0 0 120 150" xmlns="http://www.w3.org/2000/svg" class="statement-egg-small">
              <ellipse cx="60" cy="82" rx="44" ry="56" fill="#F5F0E8" stroke="rgba(212,160,23,0.3)" stroke-width="1"/>
              <ellipse cx="60" cy="88" rx="24" ry="30" fill="#F2C94C" opacity="0.4"/>
            </svg>
            <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg" class="statement-egg-tiny">
              <ellipse cx="40" cy="55" rx="28" ry="36" fill="#F5F0E8" stroke="rgba(212,160,23,0.2)" stroke-width="1"/>
            </svg>
          </div>
          <blockquote class="statement-quote">
            <p>
              毎日のことだから、<br />
              毎日、妥協しない。
            </p>
            <cite>— 小澤鶏卵</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- ===================== CONTACT CTA (ダークグリーン) ===================== -->
    <section class="contact-cta-section">
      <div class="container">
        <div class="cta-inner">
          <span class="section-label section-label--light">Contact</span>
          <h2 class="cta-title">ご注文・お問い合わせ</h2>
          <p class="cta-text">
            業務用のご注文から個人のお客様まで、お気軽にご相談ください。<br />
            担当者が丁寧に対応いたします。
          </p>

          <div class="cta-methods">
            <div class="cta-method">
              <div class="cta-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M5 4h4l2 5-2.5 1.5c1 2 2.5 3.5 4.5 4.5L14.5 12l5 2v4c0 .8-.7 1.5-1.5 1.5C7.5 19.5 4 12.5 4 5.5 4 4.7 4.7 4 5 4z" stroke="rgba(250,247,242,0.7)" stroke-width="1.5" fill="none"/>
                </svg>
              </div>
              <div class="cta-method-text">
                <p class="cta-method-label">お電話</p>
                <a href="tel:0000-00-0000" class="cta-phone">0000-00-0000</a>
                <p class="cta-method-note">月〜土 8:00〜17:00</p>
              </div>
            </div>

            <div class="cta-divider"></div>

            <div class="cta-method">
              <div class="cta-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="6" width="18" height="13" rx="2" stroke="rgba(250,247,242,0.7)" stroke-width="1.5"/>
                  <path d="M3 8l9 6 9-6" stroke="rgba(250,247,242,0.7)" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="cta-method-text">
                <p class="cta-method-label">メール</p>
                <a href="mailto:info@kozawa-keiran.com" class="cta-email">info@kozawa-keiran.com</a>
                <p class="cta-method-note">24時間受付・翌営業日ご返信</p>
              </div>
            </div>

            <div class="cta-divider"></div>

            <div class="cta-method">
              <div class="cta-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="5" width="18" height="14" rx="2" stroke="rgba(250,247,242,0.7)" stroke-width="1.5"/>
                  <path d="M7 10h10M7 14h6" stroke="rgba(250,247,242,0.7)" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="cta-method-text">
                <p class="cta-method-label">フォーム</p>
                <a href="/contact" class="cta-form-link">お問い合わせフォーム</a>
                <p class="cta-method-note">詳細のご要望もお気軽に</p>
              </div>
            </div>
          </div>

          <a href="/contact" class="cta-btn">お問い合わせはこちら</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* ===== HERO ===== */
.hero {
  min-height: 100svh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  background-color: var(--color-deep);
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-bg-dark {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 70% 50%, #2A1C12 0%, #1A1008 60%, #0E0A06 100%);
}

.hero-egg-bg {
  position: absolute;
  right: -5%;
  top: 50%;
  transform: translateY(-50%);
  width: 60%;
  max-width: 700px;
  height: auto;
  opacity: 0.7;
}

.hero-lines {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 55%;
  overflow: hidden;
}

.hero-line {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 1px;
  background: linear-gradient(to bottom, transparent, rgba(212,160,23,0.06), transparent);
  left: calc(var(--i) * 12.5%);
  transform: skewX(-8deg);
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2.5rem;
  padding-top: 76px;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  min-height: 100svh;
}

.hero-eyebrow {
  font-family: 'Lato', sans-serif;
  font-size: 0.7rem;
  letter-spacing: 0.25em;
  color: rgba(242, 201, 76, 0.7);
  text-transform: uppercase;
  margin-bottom: 1.75rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.hero-eyebrow::before {
  content: '';
  display: block;
  width: 2rem;
  height: 1px;
  background-color: rgba(242, 201, 76, 0.5);
}

.hero-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 1.75rem;
  gap: 0.1em;
}

.hero-title-small {
  font-size: clamp(1.35rem, 2.5vw, 2rem);
  font-weight: 400;
  color: rgba(250, 247, 242, 0.75);
  letter-spacing: 0.06em;
  line-height: 1.4;
}

.hero-title-large {
  font-size: clamp(2.25rem, 4.5vw, 3.75rem);
  font-weight: 500;
  color: var(--color-ivory);
  letter-spacing: 0.04em;
  line-height: 1.3;
}

.hero-sub {
  font-size: clamp(0.875rem, 1.2vw, 1rem);
  color: rgba(250, 247, 242, 0.6);
  line-height: 1.9;
  margin-bottom: 2.75rem;
}

.hero-ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.hero-btn-primary {
  display: inline-block;
  padding: 0.975rem 2.5rem;
  background-color: var(--color-egg-yellow);
  color: var(--color-deep);
  font-family: 'Shippori Mincho', serif;
  font-size: 0.875rem;
  letter-spacing: 0.1em;
  text-decoration: none;
  transition: background-color 0.2s, transform 0.2s;
  font-weight: 500;
}

.hero-btn-primary:hover {
  background-color: #e8be38;
  transform: translateY(-1px);
}

.hero-btn-ghost {
  display: inline-block;
  padding: 0.975rem 2.5rem;
  border: 1px solid rgba(250, 247, 242, 0.3);
  color: rgba(250, 247, 242, 0.8);
  font-family: 'Shippori Mincho', serif;
  font-size: 0.875rem;
  letter-spacing: 0.1em;
  text-decoration: none;
  transition: all 0.2s;
}

.hero-btn-ghost:hover {
  border-color: rgba(250, 247, 242, 0.7);
  color: var(--color-ivory);
  background-color: rgba(250, 247, 242, 0.05);
}

/* Hero egg visual */
.hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-egg-wrap {
  position: relative;
  width: min(360px, 100%);
}

