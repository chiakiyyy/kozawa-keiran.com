---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const products = [
  { img: '/images/product_kodawari.svg', name: 'こだわりのたまご', desc: 'コクと甘みが特徴の、当社自慢のたまごです。', href: '/products#kodawari', badge: 'おすすめ' },
  { img: '/images/product_pink.svg',     name: 'ピンクたまご',     desc: 'やさしいピンク色の殻が特徴のたまごです。', href: '/products#pink',     badge: '人気' },
  { img: '/images/product_araucana.svg', name: 'アローカナのたまご', desc: '南米原産の鶏が産む、希少な青い殻のたまごです。', href: '/products#araucana', badge: '希少' },
  { img: '/images/product_gift.svg',     name: 'ギフトセット',      desc: '大切な方への贈り物に。ギフトセットをご用意しています。', href: '/products#gift', badge: 'ギフト' },
];

const features = [
  { img: '/images/feature_feed.svg',   title: 'こだわりの飼料',     desc: '鶏の健康を考え、厳選した原料を使用した自家配合飼料を与えています。' },
  { img: '/images/feature_env.svg',    title: '快適な飼育環境',     desc: '清潔で風通しの良い鶏舎で、のびのびと育った鶏から産まれています。' },
  { img: '/images/feature_water.svg',  title: 'おいしい水',         desc: '地下から汲み上げたきれいな水をたっぷり与えています。' },
  { img: '/images/feature_safety.svg', title: '安心・安全への取り組み', desc: '徹底した衛生管理のもと、安心・安全なたまごをお届けします。' },
];

const news = [
  { date: '2024.05.01', title: 'ゴールデンウィーク期間の営業について', href: '#' },
  { date: '2024.04.10', title: '「こだわりのたまご」価格改定のお知らせ', href: '#' },
  { date: '2024.03.15', title: 'ホームページをリニューアルしました', href: '#' },
];
---

<Layout title="小澤鶏卵｜新鮮で安心なたまごを地域へ" description="小澤鶏卵は地域の飲食店・施設・ご家庭へ、安全で高品質なたまごをお届けします。幸せは、たまごのある食卓にある。">
  <Header />
  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <!-- 右: 写真 -->
      <div class="hero-img">
        <img src="/images/hero_main.svg" alt="農場とたまご" loading="eager"/>
        <!-- 丸くくり抜く装飾 -->
        <div class="hero-img-deco" aria-hidden="true"></div>
      </div>

      <!-- 左: テキスト -->
      <div class="hero-text">
        <!-- 卵の装飾 -->
        <div class="hero-egg-deco" aria-hidden="true">
          <svg viewBox="0 0 60 75" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="30" cy="40" rx="26" ry="33" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1.5"/>
            <ellipse cx="30" cy="44" rx="14" ry="17" fill="#F5B82E" opacity="0.4"/>
          </svg>
        </div>

        <p class="hero-catch-small">おひさまを浴びる幸せ。<br/>新鮮なものを食べる幸せ。<br/>安心できるものを選べる幸せ。</p>

        <h1 class="hero-title">
          幸せは、<br/>
          <span class="hero-title-yellow">たまご</span>のある<br/>
          食卓にある。
        </h1>

        <p class="hero-sub">
          小澤鶏卵は、地域の食卓に寄り添いながら、<br/>
          毎日新鮮で安心なたまごをお届けしています。
        </p>

        <a href="/about" class="btn btn-primary hero-btn">
          私たちについて　→
        </a>

        <!-- ドット装飾 -->
        <div class="hero-dots-deco" aria-hidden="true">
          {Array.from({length:12}).map((_,i) => (
            <div class="hdot" style={`--c:${i}`}></div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== ABOUT ===== -->
    <section class="about-sec" id="about">
      <!-- 丸い写真 -->
      <div class="about-img-wrap">
        <div class="about-img-circle">
          <img src="/images/about_chickens.svg" alt="元気に育つ鶏たち" loading="lazy"/>
        </div>
        <!-- 卵の装飾 -->
        <div class="about-egg-lt" aria-hidden="true">
          <svg viewBox="0 0 50 62" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="25" cy="33" rx="21" ry="27" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="about-egg-dk" aria-hidden="true">
          <svg viewBox="0 0 40 50" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="20" cy="27" rx="17" ry="22" fill="#EAF0DA" stroke="#6F8F3A" stroke-width="1.2"/>
          </svg>
        </div>
      </div>

      <!-- テキスト -->
      <div class="about-text">
        <span class="sec-en">ABOUT</span>
        <span class="sec-ja">私たちについて</span>
        <h2 class="sec-title" style="margin-top:.75rem">
          小澤鶏卵は、茨城県の自然豊かな<br/>
          環境の中で、鶏の健康を第一に考え、<br/>
          こだわりの飼料ときれいな水で<br/>
          鶏を育てています。
        </h2>
        <p class="about-body">
          新鮮でおいしいたまごを、まごころ込めてお届けします。
        </p>
        <a href="/about" class="btn btn-green">詳しく見る　→</a>
      </div>
    </section>

    <!-- ===== NEWS ===== -->
    <section class="news-sec">
      <!-- 左: ラベル -->
      <div class="news-label">
        <span class="sec-en">NEWS</span>
        <span class="sec-ja">お知らせ</span>
      </div>

      <!-- 中: リスト -->
      <ul class="news-list">
        {news.map(n => (
          <li>
            <a href={n.href} class="news-row">
              <span class="news-date">{n.date}</span>
              <span class="news-title">{n.title}</span>
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" class="news-arr">
                <path d="M10 1l5 5-5 5M1 6h14" stroke="#F5B82E" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <!-- 右: 写真 -->
      <div class="news-img">
        <img src="/images/news_eggs.svg" alt="たまごイメージ" loading="lazy"/>
      </div>
    </section>

    <!-- ===== LINE UP ===== -->
    <section class="lineup-sec">
      <!-- 卵のドット背景 -->
      <div class="lineup-bg" aria-hidden="true"></div>
      <div class="lineup-in">
        <div class="lineup-head">
          <span class="sec-en">LINE UP</span>
          <span class="sec-ja">商品紹介</span>
        </div>
        <div class="lineup-grid">
          {products.map(p => (
            <a href={p.href} class="lineup-card card">
              <div class="lc-img">
                <img src={p.img} alt={p.name} loading="lazy"/>
                <span class="lc-badge">{p.badge}</span>
              </div>
              <div class="lc-body">
                <h3>{p.name}</h3>
                <p>{p.desc}</p>
                <span class="link-arrow">
                  詳しく見る
                  <svg width="16" height="12" viewBox="0 0 16 12" fill="none"><path d="M10 1l5 5-5 5M1 6h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FOR BUSINESS / FOR HOME ===== -->
    <section class="for-sec">
      <!-- FOR BUSINESS -->
      <a href="/business" class="for-card for-card--biz">
        <div class="for-card-text">
          <span class="for-label">FOR BUSINESS</span>
          <h2 class="for-title">法人のお客様へ</h2>
          <p>飲食店・給食施設・ホテルなど<br/>業務用たまごの安定供給はお任せください。</p>
          <span class="btn btn-outline-yellow">詳しく見る →</span>
        </div>
        <div class="for-card-img" aria-hidden="true">
          <svg viewBox="0 0 300 240" xmlns="http://www.w3.org/2000/svg">
            <!-- ケース -->
            <rect x="20" y="100" width="260" height="120" rx="8" fill="rgba(245,184,46,0.2)" stroke="rgba(245,184,46,0.5)" stroke-width="1.5"/>
            <rect x="20" y="100" width="260" height="38" rx="8" fill="rgba(245,184,46,0.3)"/>
            <!-- 仕切り -->
            <line x1="107" y1="100" x2="107" y2="220" stroke="rgba(245,184,46,0.4)" stroke-width="1"/>
            <line x1="193" y1="100" x2="193" y2="220" stroke="rgba(245,184,46,0.4)" stroke-width="1"/>
            <line x1="20" y1="160" x2="280" y2="160" stroke="rgba(245,184,46,0.4)" stroke-width="1"/>
            <!-- 卵 -->
            {[63,150,237,63,150,237].map((x,i) => (
              <ellipse cx={x} cy={i<3?140:192} rx="24" ry="30" fill="rgba(250,240,220,0.9)" stroke="rgba(212,168,32,0.6)" stroke-width="1"/>
            ))}
            <!-- 大きな卵 (上) -->
            <ellipse cx="150" cy="60" rx="55" ry="70" fill="rgba(250,240,220,0.85)" stroke="rgba(212,168,32,0.5)" stroke-width="1.5"/>
            <ellipse cx="150" cy="66" rx="28" ry="35" fill="rgba(245,184,46,0.35)"/>
            <ellipse cx="132" cy="42" rx="14" ry="9" fill="white" opacity="0.35" transform="rotate(-22,132,42)"/>
          </svg>
        </div>
      </a>

      <!-- FOR HOME -->
      <a href="/shop" class="for-card for-card--home">
        <div class="for-card-text">
          <span class="for-label">FOR HOME</span>
          <h2 class="for-title">個人のお客様へ</h2>
          <p>ご家庭用・ギフト・通販・定期購入など<br/>個人のお客様にも幅広くご対応します。</p>
          <span class="btn btn-outline">詳しく見る →</span>
        </div>
        <div class="for-card-img" aria-hidden="true">
          <svg viewBox="0 0 300 240" xmlns="http://www.w3.org/2000/svg">
            <!-- 食卓イメージ -->
            <ellipse cx="150" cy="200" rx="200" ry="50" fill="rgba(111,143,58,0.15)"/>
            <!-- 皿 -->
            <ellipse cx="150" cy="180" rx="130" ry="35" fill="rgba(255,255,255,0.5)" stroke="rgba(111,143,58,0.3)" stroke-width="1.5"/>
            <!-- 卵3個 -->
            <ellipse cx="90" cy="158" rx="45" ry="57" fill="rgba(250,240,220,0.9)" stroke="rgba(212,168,32,0.5)" stroke-width="1.5"/>
            <ellipse cx="150" cy="148" rx="50" ry="63" fill="rgba(250,240,220,0.9)" stroke="rgba(212,168,32,0.5)" stroke-width="1.5"/>
            <ellipse cx="210" cy="156" rx="45" ry="57" fill="rgba(250,240,220,0.9)" stroke="rgba(212,168,32,0.5)" stroke-width="1.5"/>
            <ellipse cx="90" cy="165" rx="22" ry="28" fill="rgba(111,143,58,0.3)"/>
            <ellipse cx="150" cy="155" rx="25" ry="32" fill="rgba(111,143,58,0.3)"/>
            <ellipse cx="210" cy="163" rx="22" ry="28" fill="rgba(111,143,58,0.3)"/>
            <ellipse cx="75" cy="140" rx="12" ry="7" fill="white" opacity="0.38" transform="rotate(-22,75,140)"/>
            <ellipse cx="133" cy="130" rx="14" ry="8" fill="white" opacity="0.38" transform="rotate(-22,133,130)"/>
          </svg>
        </div>
      </a>
    </section>

    <!-- ===== FEATURE ===== -->
    <section class="feature-sec">
      <div class="feature-in">
        <div class="feature-head">
          <span class="sec-en">FEATURE</span>
          <span class="sec-ja">こだわり</span>
        </div>
        <div class="feature-grid">
          {features.map(f => (
            <div class="feat-card card">
              <div class="feat-img">
                <img src={f.img} alt={f.title} loading="lazy"/>
              </div>
              <div class="feat-body">
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <div style="text-align:center;margin-top:2.5rem">
          <a href="/feature" class="btn btn-outline">こだわりをすべて見る →</a>
        </div>
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section class="contact-sec">
      <div class="contact-img">
        <img src="/images/contact_bg.svg" alt="" loading="lazy" aria-hidden="true"/>
        <div class="contact-overlay"></div>
      </div>
      <div class="contact-content">
        <span class="sec-en" style="color:white">CONTACT</span>
        <span class="sec-ja" style="color:rgba(255,255,255,.7)">お問い合わせ</span>
        <h2 class="contact-title">ご注文やご質問など、<br/>お気軽にお問い合わせください。</h2>
        <a href="/contact" class="btn btn-primary contact-btn">
          <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
            <rect x="1" y="1" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M1 3l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          お問い合わせフォームへ →
        </a>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>

<style>
/* ===== HERO ===== */
.hero {
  min-height: 100svh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  background-color: var(--bg);
  position: relative;
  overflow: hidden;
  padding-top: 70px;
}
.hero-img {
  position: relative;
  height: 100svh;
  min-height: 600px;
}
.hero-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
/* 左下に白い曲線でくり抜く */
.hero-img-deco {
  position: absolute;
  top: 0; left: -2px; bottom: 0;
  width: 80px;
  background: var(--bg);
  clip-path: ellipse(80px 100% at 0% 50%);
}
.hero-text {
  padding: 3rem 4rem 3rem 2rem;
  position: relative;
}
.hero-egg-deco {
  position: absolute;
  top: 2rem; right: 3rem;
  width: 55px; opacity: .7;
}
.hero-catch-small {
  font-size: .875rem;
  color: var(--muted);
  line-height: 1.9;
  margin-bottom: 1.5rem;
}
.hero-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700;
  color: var(--brown);
  line-height: 1.55;
  letter-spacing: .03em;
  margin-bottom: 1.25rem;
}
.hero-title-yellow { color: var(--yellow); }
.hero-sub {
  font-size: .9rem;
  color: var(--muted);
  line-height: 1.9;
  margin-bottom: 2rem;
}
.hero-btn { padding: .875rem 2.25rem; }
/* ドット装飾 */
.hero-dots-deco {
  position: absolute;
  bottom: 2rem; right: 2rem;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;
}
.hdot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(245,184,46,.35);
}
.hdot:nth-child(4n+1) { background: rgba(111,143,58,.25); }

/* ===== ABOUT ===== */
.about-sec {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 6rem;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 7rem 2rem;
}
.about-img-wrap { position: relative; display: flex; justify-content: center; }
.about-img-circle {
  width: min(380px, 100%);
  aspect-ratio: 1;
  border-radius: 50%;
  overflow: hidden;
  border: 4px solid rgba(245,184,46,.3);
  box-shadow: 0 8px 32px rgba(59,50,31,.12);
}
.about-img-circle img { width: 100%; height: 100%; object-fit: cover; }
.about-egg-lt {
  position: absolute; top: -20px; right: -10px;
  width: 70px; opacity: .7;
}
.about-egg-dk {
  position: absolute; bottom: 10px; left: -20px;
  width: 55px; opacity: .6;
}
.about-text .sec-en { font-size: 1rem; }
.about-body {
  font-size: .9rem; color: var(--muted); line-height: 1.8;
  margin: 1rem 0 1.75rem;
}

/* ===== NEWS ===== */
.news-sec {
  background: var(--bg2);
  display: grid;
  grid-template-columns: 200px 1fr 300px;
  gap: 3rem;
  align-items: start;
  padding: 5rem 4rem;
  max-width: 1200px;
  margin: 0 auto;
}
.news-label .sec-en { font-size: 1.1rem; }
.news-list { list-style: none; margin: 0; padding: 0; }
.news-row {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1rem .75rem;
  text-decoration: none;
  color: var(--brown);
  border-bottom: 1px solid rgba(245,184,46,.25);
  border-radius: 8px;
  transition: background .15s;
  flex-wrap: wrap;
}
.news-row:hover { background: rgba(245,184,46,.08); }
.news-date { font-family: 'Lato',sans-serif; font-size: .8rem; color: var(--muted); white-space: nowrap; }
.news-title { flex: 1; font-size: .875rem; font-weight: 500; }
.news-arr { flex-shrink: 0; }
.news-img { border-radius: 12px; overflow: hidden; }
.news-img img { width: 100%; height: 220px; object-fit: cover; display: block; }

/* ===== LINE UP ===== */
.lineup-sec {
  background: var(--bg);
  padding: 6rem 0;
  position: relative;
  overflow: hidden;
}
.lineup-bg {
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(245,184,46,.06) 1px, transparent 1px);
  background-size: 40px 40px;
}
.lineup-in { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; }
.lineup-head { margin-bottom: 2.5rem; }
.lineup-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
.lineup-card { text-decoration: none; color: inherit; display: block; }
.lc-img { position: relative; background: var(--bg2); }
.lc-img img { width: 100%; height: 200px; object-fit: cover; display: block; }
.lc-badge {
  position: absolute; top: 10px; left: 10px;
  background: var(--yellow); color: var(--brown);
  font-size: .7rem; font-weight: 700;
  padding: .2rem .65rem; border-radius: 999px;
  box-shadow: 0 2px 8px rgba(245,184,46,.4);
}
.lc-body { padding: 1.25rem; }
.lc-body h3 { font-family: 'Noto Serif JP',serif; font-size: .95rem; font-weight: 700; margin-bottom: .4rem; color: var(--brown); }
.lc-body p { font-size: .8rem; color: var(--muted); line-height: 1.7; margin-bottom: .875rem; }

/* ===== FOR BUSINESS / HOME ===== */
.for-sec {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.for-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rem;
  gap: 2rem;
  text-decoration: none;
  transition: filter .25s;
  overflow: hidden;
}
.for-card:hover { filter: brightness(.96); }
.for-card--biz { background: #2A4A20; }
.for-card--home { background: #4A7A28; }
.for-label {
  font-family: 'Lato',sans-serif; font-size: .68rem;
  font-weight: 700; letter-spacing: .2em; color: rgba(245,184,46,.8);
  display: block; margin-bottom: .5rem;
}
.for-title {
  font-family: 'Noto Serif JP',serif; font-size: clamp(1.4rem,2.5vw,2rem);
  font-weight: 700; color: white; margin-bottom: .75rem; line-height: 1.4;
}
.for-card-text p { font-size: .875rem; color: rgba(255,255,255,.7); line-height: 1.8; margin-bottom: 1.5rem; }
.for-card-img { flex-shrink: 0; width: 220px; opacity: .85; }
.for-card-img svg { width: 100%; height: auto; }

/* ===== FEATURE ===== */
.feature-sec {
  background: var(--bg2);
  padding: 6rem 0;
}
.feature-in { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
.feature-head { margin-bottom: 2.5rem; }
.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
.feat-card { text-decoration: none; color: inherit; }
.feat-img img { width: 100%; height: 190px; object-fit: cover; display: block; }
.feat-body { padding: 1.1rem 1.1rem 1.4rem; }
.feat-body h3 { font-family: 'Noto Serif JP',serif; font-size: .9rem; font-weight: 700; color: var(--brown); margin-bottom: .35rem; }
.feat-body p { font-size: .78rem; color: var(--muted); line-height: 1.7; margin: 0; }

/* ===== CONTACT ===== */
.contact-sec {
  position: relative;
  min-height: 360px;
  display: flex;
  align-items: center;
}
.contact-img {
  position: absolute; inset: 0;
}
.contact-img img { width: 100%; height: 100%; object-fit: cover; }
.contact-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, rgba(42,74,32,.92) 0%, rgba(42,74,32,.75) 60%, rgba(42,74,32,.4) 100%);
}
.contact-content {
  position: relative; z-index: 1;
  max-width: 1200px; margin: 0 auto; padding: 4rem 2rem;
}
.contact-title {
  font-family: 'Noto Serif JP',serif; font-size: clamp(1.2rem,2.2vw,1.75rem);
  font-weight: 700; color: white; line-height: 1.6;
  margin: .75rem 0 2rem;
}
.contact-btn { display: inline-flex; }

/* ===== RESPONSIVE ===== */
@media (max-width: 1100px) {
  .lineup-grid { grid-template-columns: repeat(2, 1fr); }
  .feature-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
