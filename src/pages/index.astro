---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="小澤鶏卵｜新鮮で安心なたまごを地域へ">
  <Header/>
  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg">
        <img src="/images/hero_main.svg" alt="" aria-hidden="true" loading="eager"/>
        <div class="hero-ov"></div>
      </div>
      <div class="hero-body">
        <div class="hero-content">
          <span class="hero-label">TOYAMA · EST. 1920s · EGG SUPPLIER</span>
          <h1 class="hero-title">幸せは、<br/><em>たまご</em>のある<br/>食卓にある。</h1>
          <p class="hero-sub">おひさまを浴びる幸せ。新鮮なものを食べる幸せ。<br/>安心できるものを選べる幸せ。</p>
          <div class="hero-btns">
            <a href="/business" class="btn btn-primary">法人取引のご相談</a>
            <a href="/products" class="btn btn-outline-w">商品を見る</a>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <div class="stats">
      <div class="stat"><span class="stat-n">100<small>年+</small></span><span class="stat-l">創業からの歴史</span></div>
      <div class="stat"><span class="stat-n">月水金</span><span class="stat-l">注文受付日</span></div>
      <div class="stat"><span class="stat-n">当日</span><span class="stat-l">夕方お届け対応</span></div>
    </div>

    <!-- FOR BUSINESS -->
    <section class="sec">
      <div class="container">
        <div class="two-col">
          <div class="two-col-img">
            <img src="/images/business_hero.svg" alt="業務用たまご" loading="lazy"/>
          </div>
          <div class="two-col-body">
            <span class="sec-label">FOR BUSINESS</span>
            <h2 class="sec-title">毎日使うたまごを、<br/>安定してお届けします。</h2>
            <p class="sec-lead">飲食店・ホテル・給食施設・スーパーなど、業務用たまごの安定供給はお任せください。大量注文・定期納品・催事対応など柔軟に対応します。</p>
            <div class="biz-tags">
              {['ラーメン店','洋菓子店','ホテル','スーパー','給食施設','催事・イベント'].map(t => <span class="biz-tag">{t}</span>)}
            </div>
            <a href="/business" class="btn btn-primary" style="margin-top:2rem">法人取引のご相談はこちら →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ORDER FLOW -->
    <section class="sec sec--amber">
      <div class="container">
        <div style="text-align:center;margin-bottom:2.5rem">
          <span class="sec-label">HOW TO ORDER</span>
          <h2 class="sec-title">注文方法</h2>
        </div>
        <div class="order-methods">
          {[
            { icon:'📞', name:'お電話', detail:'076-466-3815', sub:'月〜土 8:00〜17:00' },
            { icon:'💬', name:'LINE',   detail:'公式アカウントへ', sub:'お気軽にどうぞ' },
            { icon:'✉️', name:'メール', detail:'お問い合わせフォーム', sub:'24時間受付' },
          ].map(m => (
            <div class="method-card">
              <span class="method-icon">{m.icon}</span>
              <h3>{m.name}</h3>
              <p class="method-detail">{m.detail}</p>
              <p class="method-sub">{m.sub}</p>
            </div>
          ))}
        </div>
        <div class="order-note">
          <strong>月・水・金 9:30まで</strong>にご注文いただくと、当日夕方にお届けします。<br/>
          お祭り・学園祭などの催し物・まとめてのご注文もお気軽にご相談ください。
        </div>
      </div>
    </section>

    <!-- FOR HOME -->
    <section class="sec sec--pale">
      <div class="container">
        <div class="two-col two-col--rev">
          <div class="two-col-body">
            <span class="sec-label">FOR HOME</span>
            <h2 class="sec-title">毎日の食卓に、<br/>安心でおいしいたまごを。</h2>
            <p class="sec-lead">ご家庭用・ギフト・通販・定期購入など、個人のお客様にも幅広くご対応します。</p>
            <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem">
              <a href="/shop" class="btn btn-primary">個人のお客様はこちら →</a>
              <a href="/products" class="btn btn-outline">商品ラインナップ</a>
            </div>
          </div>
          <div class="two-col-img">
            <img src="/images/hero_main.svg" alt="ご家庭用たまご" loading="lazy"/>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="sec">
      <div class="container">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">
          <div>
            <span class="sec-label">ABOUT</span>
            <h2 class="sec-title" style="margin-bottom:1rem">私たちについて</h2>
            <p style="font-size:.9rem;color:#5F5E5A;line-height:1.9">小澤鶏卵は、自然豊かな環境の中で、鶏の健康を第一に考え、こだわりの飼料ときれいな水で鶏を育てています。創業100年以上、富山の食卓を支えてきました。</p>
            <a href="/about" class="link-arrow" style="margin-top:1.5rem;display:inline-flex">詳しく見る →</a>
          </div>
          <div style="border-radius:var(--radius-md);overflow:hidden;aspect-ratio:4/3;background:#FAEEDA">
            <img src="/images/about_chickens.svg" alt="小澤鶏卵について" loading="lazy" style="width:100%;height:100%;object-fit:cover"/>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURE -->
    <section class="sec sec--pale">
      <div class="container">
        <div style="text-align:center;margin-bottom:3rem">
          <span class="sec-label">FEATURE</span>
          <h2 class="sec-title">こだわり</h2>
        </div>
        <div class="feat-grid">
          {[
            { img:'/images/feature_feed.svg',   title:'こだわりの飼料',       body:'鶏の健康を考え、厳選した原料を使用した自家配合飼料を与えています。' },
            { img:'/images/feature_env.svg',    title:'快適な飼育環境',       body:'清潔で風通しの良い鶏舎で、のびのびと育った鶏から産まれています。' },
            { img:'/images/feature_water.svg',  title:'おいしい水',           body:'地下から汲み上げたきれいな水をたっぷり与えています。' },
            { img:'/images/feature_safety.svg', title:'安心・安全への取り組み', body:'徹底した衛生管理のもと、安心・安全なたまごをお届けします。' },
          ].map(f => (
            <div class="feat-card card">
              <div class="feat-img"><img src={f.img} alt={f.title} loading="lazy"/></div>
              <div class="feat-body"><h3>{f.title}</h3><p>{f.body}</p></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="sec">
      <div class="container">
        <div style="text-align:center;margin-bottom:3rem">
          <span class="sec-label">LINE UP</span>
          <h2 class="sec-title">商品紹介</h2>
        </div>
        <div class="prod-grid">
          {[
            { img:'/images/product_kodawari.svg', name:'こだわりのたまご', note:'コクと甘みが特徴の、当社自慢のたまごです。', href:'/products#kodawari' },
            { img:'/images/product_pink.svg',     name:'ピンクたまご',    note:'やさしいピンク色の殻が特徴のたまごです。',   href:'/products#pink' },
            { img:'/images/product_araucana.svg', name:'アローカナのたまご', note:'南米原産の鶏が産む、希少な青い殻のたまご。', href:'/products#araucana' },
            { img:'/images/product_gift.svg',     name:'ギフトセット',    note:'大切な方への贈り物に。各種ご用意しています。', href:'/products#gift' },
          ].map(p => (
            <a href={p.href} class="prod-card card">
              <div class="prod-img"><img src={p.img} alt={p.name} loading="lazy"/></div>
              <div class="prod-body">
                <h3>{p.name}</h3>
                <p>{p.note}</p>
                <span class="link-arrow">詳しく見る →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- NEWS -->
    <section class="sec sec--pale">
      <div class="container">
        <div class="news-head">
          <div><span class="sec-label">NEWS</span><h2 class="sec-title">お知らせ</h2></div>
          <a href="/news" class="link-arrow">すべて見る →</a>
        </div>
        <ul class="news-list">
          {[
            { date:'2024.05.01', tag:'お知らせ', title:'ゴールデンウィーク期間の営業について' },
            { date:'2024.04.10', tag:'重要',     title:'「こだわりのたまご」価格改定のお知らせ' },
            { date:'2024.03.15', tag:'お知らせ', title:'ホームページをリニューアルしました' },
          ].map(n => (
            <li class="news-item">
              <a href="/news">
                <span class="news-date">{n.date}</span>
                <span class={`news-tag ${n.tag === '重要' ? 'news-tag--imp' : ''}`}>{n.tag}</span>
                <span class="news-title">{n.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-sec">
      <div class="container" style="text-align:center">
        <span class="sec-label" style="justify-content:center;display:flex">CONTACT</span>
        <h2 class="sec-title" style="color:white;margin:.5rem 0 1rem">ご注文・ご相談はお気軽に</h2>
        <p style="color:rgba(255,255,255,0.7);font-size:.9rem;margin-bottom:2rem">まずはお電話かフォームにてお気軽にご連絡ください</p>
        <div style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap">
          <a href="/contact" class="btn btn-primary">お問い合わせフォーム →</a>
          <a href="tel:076-466-3815" class="btn btn-outline-w">📞 076-466-3815</a>
        </div>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>

<style>
/* HERO */
.hero { position:relative; min-height:100svh; display:flex; align-items:flex-end; }
.hero-bg { position:absolute; inset:0; }
.hero-bg img { width:100%; height:100%; object-fit:cover; }
.hero-ov { position:absolute; inset:0; background:linear-gradient(135deg,rgba(44,44,42,.85) 0%,rgba(44,44,42,.55) 60%,rgba(44,44,42,.2) 100%); }
.hero-body { position:relative; z-index:1; width:100%; padding-bottom:4rem; }
.hero-content { max-width:1100px; margin:0 auto; padding:2rem 2rem 0; padding-top:calc(72px + 3rem); }
.hero-label { font-family:'Lato',sans-serif; font-size:.62rem; letter-spacing:.2em; color:rgba(250,199,117,.8); display:block; margin-bottom:1.25rem; }
.hero-title { font-family:'Noto Serif JP',serif; font-size:clamp(2.2rem,6vw,4rem); font-weight:700; color:white; line-height:1.45; margin-bottom:1.25rem; }
.hero-title em { font-style:normal; color:#FAC775; }
.hero-sub { font-size:.95rem; color:rgba(255,255,255,.7); line-height:1.9; margin-bottom:2rem; }
.hero-btns { display:flex; gap:1rem; flex-wrap:wrap; }
.btn-outline-w { background:transparent; color:white; border:1.5px solid rgba(255,255,255,.5); border-radius:999px; padding:.875rem 2rem; font-size:.875rem; font-weight:700; text-decoration:none; transition:all .2s; display:inline-flex; align-items:center; }
.btn-outline-w:hover { background:rgba(255,255,255,.1); }

/* STATS */
.stats { display:grid; grid-template-columns:repeat(3,1fr); border-bottom:.5px solid rgba(44,44,42,.1); }
.stat { padding:1.75rem 0; text-align:center; border-right:.5px solid rgba(44,44,42,.1); }
.stat:last-child { border-right:none; }
.stat-n { display:block; font-family:'Lato',sans-serif; font-size:1.8rem; font-weight:300; color:#BA7517; line-height:1; margin-bottom:.3rem; }
.stat-n small { font-size:1rem; }
.stat-l { display:block; font-size:.75rem; color:#5F5E5A; letter-spacing:.04em; }

/* TWO COL */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
.two-col--rev { direction:rtl; }
.two-col--rev > * { direction:ltr; }
.two-col-img { border-radius:var(--radius-md); overflow:hidden; aspect-ratio:4/3; background:#FAEEDA; }
.two-col-img img { width:100%; height:100%; object-fit:cover; display:block; }
.biz-tags { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:1.5rem; }
.biz-tag { background:#F1EFE8; color:#5F5E5A; font-size:.75rem; padding:.3rem .85rem; border-radius:999px; border:.5px solid rgba(44,44,42,.1); }

/* ORDER */
.order-methods { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.75rem; }
.method-card { background:white; border-radius:var(--radius-sm); border:.5px solid rgba(44,44,42,.08); padding:2rem 1.5rem; text-align:center; }
.method-icon { font-size:1.75rem; display:block; margin-bottom:.75rem; }
.method-card h3 { font-family:'Noto Serif JP',serif; font-size:.95rem; font-weight:700; color:#2C2C2A; margin-bottom:.4rem; }
.method-detail { font-size:.85rem; color:#BA7517; font-weight:500; margin-bottom:.2rem; }
.method-sub { font-size:.75rem; color:#888780; }
.order-note { background:white; border-radius:var(--radius-sm); border:.5px solid rgba(186,117,23,.2); padding:1.25rem 1.5rem; font-size:.875rem; color:#5F5E5A; line-height:1.8; text-align:center; }
.order-note strong { color:#2C2C2A; font-weight:700; }

/* FEAT */
.feat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; }
.feat-card { display:flex; flex-direction:column; }
.feat-img { aspect-ratio:1; background:#FAEEDA; overflow:hidden; }
.feat-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s; }
.feat-card:hover .feat-img img { transform:scale(1.04); }
.feat-body { padding:1.25rem; }
.feat-body h3 { font-family:'Noto Serif JP',serif; font-size:.9rem; font-weight:700; color:#2C2C2A; margin-bottom:.4rem; }
.feat-body p { font-size:.78rem; color:#5F5E5A; line-height:1.7; margin:0; }

/* PRODUCTS */
.prod-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; }
.prod-card { text-decoration:none; color:inherit; display:flex; flex-direction:column; }
.prod-img { aspect-ratio:1; background:#FAEEDA; overflow:hidden; }
.prod-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s; }
.prod-card:hover .prod-img img { transform:scale(1.05); }
.prod-body { padding:1.25rem; }
.prod-body h3 { font-family:'Noto Serif JP',serif; font-size:.9rem; font-weight:700; color:#2C2C2A; margin-bottom:.3rem; }
.prod-body p { font-size:.78rem; color:#5F5E5A; line-height:1.6; margin-bottom:.75rem; }

/* NEWS */
.news-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem; }
.news-list { list-style:none; margin:0; padding:0; }
.news-item { border-bottom:.5px solid rgba(44,44,42,.08); }
.news-item a { display:flex; align-items:center; gap:1rem; padding:1rem 0; text-decoration:none; transition:background .15s; }
.news-item a:hover { padding-left:.5rem; }
.news-date { font-family:'Lato',sans-serif; font-size:.78rem; color:#888780; white-space:nowrap; }
.news-tag { font-size:.68rem; font-weight:700; padding:.2rem .65rem; border-radius:999px; background:#F1EFE8; color:#5F5E5A; white-space:nowrap; }
.news-tag--imp { background:#FAEEDA; color:#BA7517; }
.news-title { font-size:.875rem; color:#2C2C2A; }

/* CTA */
.cta-sec { background:#2C2C2A; padding:5rem 0; }

@media (max-width:900px) {
  .two-col { grid-template-columns:1fr; gap:2.5rem; }
  .two-col--rev { direction:ltr; }
  .feat-grid,.prod-grid { grid-template-columns:repeat(2,1fr); }
  .order-methods { grid-template-columns:repeat(3,1fr); }
}
@media (max-width:600px) {
  .feat-grid,.prod-grid { grid-template-columns:repeat(2,1fr); }
  .order-methods { grid-template-columns:1fr; }
  .stats { grid-template-columns:1fr; }
  .stat { border-right:none; border-bottom:.5px solid rgba(44,44,42,.1); }
}
</style>
