---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="小澤鶏卵｜新鮮で安心なたまごを地域へ" description="小澤鶏卵は地域の飲食店・施設・ご家庭へ、安全で高品質なたまごをお届けします。幸せは、たまごのある食卓にある。">
  <Header />
  <main>

    <!-- ============ HERO ============ -->
    <section class="hero">
      <!-- 左: テキスト -->
      <div class="hero-left">
        <!-- 卵の装飾（左上） -->
        <div class="hero-egg-tl" aria-hidden="true">
          <svg viewBox="0 0 70 88" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="35" cy="47" rx="30" ry="38" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1.5"/>
            <ellipse cx="35" cy="52" rx="15" ry="20" fill="#F5B82E" opacity="0.35"/>
          </svg>
        </div>

        <h1 class="hero-title">
          幸せは、<br/>
          <span class="hero-yellow">たまご</span>のある食卓にある。
        </h1>

        <p class="hero-catch">
          おひさまを浴びる幸せ。<br/>
          新鮮なものを食べる幸せ。<br/>
          安心できるものを選べる幸せ。
        </p>

        <p class="hero-body">
          小澤鶏卵は、地域の食卓に寄り添いながら、<br/>
          毎日新鮮で安心なたまごをお届けしています。
        </p>

        <a href="/about" class="hero-btn">私たちについて　→</a>

        <!-- ドット装飾（右下） -->
        <div class="hero-dots" aria-hidden="true">
          {Array.from({length:15}).map((_,i) => (
            <span class="hdot" style={`--n:${i}`}></span>
          ))}
        </div>
      </div>

      <!-- 右: 写真 -->
      <div class="hero-right">
        <div class="hero-photo-wrap">
          <!-- 白い有機曲線でくり抜くSVGマスク -->
          <div class="hero-photo-mask">
            <img src="/images/hero_main.svg" alt="農場と新鮮なたまご" loading="eager"/>
          </div>
          <!-- 左側の有機カーブ（白） -->
          <svg class="hero-curve" viewBox="0 0 160 700" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" aria-hidden="true">
            <path d="M160,0 L0,0 L0,700 L160,700 Q40,580 60,350 Q80,120 160,0 Z" fill="#FFFAF0"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- ============ ABOUT ============ -->
    <section class="about">
      <!-- 左: 丸い鶏写真 -->
      <div class="about-img-wrap">
        <div class="about-circle">
          <img src="/images/about_chickens.svg" alt="元気に育つ鶏たち" loading="lazy"/>
        </div>
        <!-- 緑の楕円装飾 -->
        <div class="about-deco-green" aria-hidden="true">
          <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="40" cy="53" rx="34" ry="44" fill="#EAF0DA" stroke="#6F8F3A" stroke-width="1"/>
          </svg>
        </div>
        <!-- 黄の楕円装飾 -->
        <div class="about-deco-yellow" aria-hidden="true">
          <svg viewBox="0 0 60 75" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="30" cy="40" rx="26" ry="32" fill="#FFF3C0" stroke="#F5B82E" stroke-width="1"/>
          </svg>
        </div>
      </div>

      <!-- 右: テキスト -->
      <div class="about-text">
        <span class="about-en">ABOUT</span>
        <span class="about-ja">私たちについて</span>
        <p class="about-body">
          小澤鶏卵は、茨城県の自然豊かな環境の中で、<br/>
          鶏の健康を第一に考え、こだわりの飼料と<br/>
          きれいな水で鶏を育てています。<br/>
          新鮮でおいしいたまごを、まごころ込めて<br/>
          お届けします。
        </p>
        <a href="/about" class="about-btn">詳しく見る　→</a>
      </div>
    </section>

    <!-- ============ NEWS ============ -->
    <section class="news">
      <!-- 左: ラベル -->
      <div class="news-label">
        <span class="news-en">NEWS</span>
        <span class="news-ja">お知らせ</span>
      </div>

      <!-- 中: リスト -->
      <ul class="news-list">
        {[
          { date:'2024.05.01', title:'ゴールデンウィーク期間の営業について' },
          { date:'2024.04.10', title:'「こだわりのたまご」価格改定のお知らせ' },
          { date:'2024.03.15', title:'ホームページをリニューアルしました' },
        ].map(n => (
          <li>
            <a href="/news" class="news-row">
              <span class="ndate">{n.date}</span>
              <span class="ntitle">{n.title}</span>
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" class="narr">
                <path d="M9 1l4 4-4 4M1 5h12" stroke="#6F8F3A" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <!-- 右: 丸い卵写真 -->
      <div class="news-img">
        <div class="news-circle">
          <img src="/images/news_eggs.svg" alt="たまごイメージ" loading="lazy"/>
        </div>
      </div>
    </section>

    <!-- ============ LINE UP ============ -->
    <section class="lineup">
      <!-- 黄色と緑の丸い装飾 -->
      <div class="lineup-deco-y" aria-hidden="true"></div>
      <div class="lineup-deco-g" aria-hidden="true"></div>

      <!-- 左: 縦書きラベル -->
      <div class="lineup-label">
        <span class="lineup-en">LINE UP</span>
        <span class="lineup-ja">商品紹介</span>
      </div>

      <!-- 右: カードグリッド -->
      <div class="lineup-cards">
        {[
          { img:'/images/product_kodawari.svg', name:'こだわりのたまご', desc:'コクと甘みが特徴の、当社自慢のたまごです。', href:'/products#kodawari' },
          { img:'/images/product_pink.svg',     name:'ピンクたまご',    desc:'やさしいピンク色の殻が特徴のたまごです。', href:'/products#pink' },
          { img:'/images/product_araucana.svg', name:'アローカナのたまご', desc:'南米原産の鶏が産む、希少な青い殻のたまごです。', href:'/products#araucana' },
          { img:'/images/product_gift.svg',     name:'ギフトセット',    desc:'大切な方への贈り物に。ギフトセットをご用意しています。', href:'/products#gift' },
        ].map(p => (
          <article class="lcard">
            <div class="lcard-img">
              <img src={p.img} alt={p.name} loading="lazy"/>
            </div>
            <div class="lcard-body">
              <h3 class="lcard-name">{p.name}</h3>
              <p class="lcard-desc">{p.desc}</p>
              <a href={p.href} class="lcard-link">
                詳しく見る　→
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ FEATURE ============ -->
    <section class="feature"><div class="feature-inner">
      <!-- 左: 縦書きラベル -->
      <div class="feature-label">
        <span class="feature-en">FEATURE</span>
        <span class="feature-ja">こだわり</span>
      </div>

      <!-- 右: カードグリッド -->
      <div class="feature-cards">
        {[
          { img:'/images/feature_feed.svg',   name:'こだわりの飼料',     desc:'鶏の健康を考え、厳選した原料を使用した自家配合飼料を与えています。' },
          { img:'/images/feature_env.svg',    name:'快適な飼育環境',     desc:'清潔で風通しの良い鶏舎で、のびのびと育った鶏から産まれています。' },
          { img:'/images/feature_water.svg',  name:'おいしい水',         desc:'地下から汲み上げたきれいな水をたっぷり与えています。' },
          { img:'/images/feature_safety.svg', name:'安心・安全への取り組み', desc:'徹底した衛生管理のもと、安心・安全なたまごをお届けします。' },
        ].map(f => (
          <article class="fcard">
            <div class="fcard-img">
              <img src={f.img} alt={f.name} loading="lazy"/>
            </div>
            <div class="fcard-body">
              <h3 class="fcard-name">{f.name}</h3>
              <p class="fcard-desc">{f.desc}</p>
            </div>
          </article>
        ))}
      </div>
      </div><!-- /feature-inner -->
    </section>

    <!-- ============ CONTACT ============ -->
    <section class="contact">
      <!-- 左: テキスト -->
      <div class="contact-left">
        <span class="contact-en">CONTACT</span>
        <span class="contact-ja">お問い合わせ</span>
        <p class="contact-body">
          ご注文やご質問など、<br/>
          お気軽にお問い合わせください。
        </p>
      </div>

      <!-- 中: ボタン -->
      <div class="contact-center">
        <a href="/contact" class="contact-btn">
          <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
            <rect x="1" y="1" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M1 3l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          お問い合わせフォームへ　→
        </a>
      </div>

      <!-- 右: 卵料理写真 -->
      <div class="contact-img" aria-hidden="true">
        <img src="/images/contact_bg.svg" alt=""/>
      </div>
    </section>

  </main>
  <Footer/>
</Layout>

<style>
/* ==============================
   HERO
============================== */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100svh - 70px);
  margin-top: 70px;
  background: var(--bg);
  overflow: hidden;
  position: relative;
}

/* 左 */
.hero-left {
  padding: 5rem 3rem 4rem 4rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.hero-egg-tl {
  position: absolute;
  top: 3rem;
  left: 2.5rem;
  width: 52px;
  opacity: .75;
}

.hero-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(2rem, 3.8vw, 3.2rem);
  font-weight: 700;
  color: var(--brown);
  line-height: 1.5;
  letter-spacing: .03em;
  margin-bottom: 1.5rem;
}

.hero-yellow { color: var(--yellow); }

.hero-catch {
  font-size: .9rem;
  color: var(--muted);
  line-height: 2;
  margin-bottom: 1.25rem;
}

.hero-body {
  font-size: .9rem;
  color: var(--brown);
  line-height: 1.9;
  margin-bottom: 2rem;
}

.hero-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .875rem 2.25rem;
  background: var(--yellow);
  color: var(--brown);
  font-size: .875rem;
  font-weight: 700;
  border-radius: 999px;
  text-decoration: none;
  width: fit-content;
  box-shadow: 0 4px 14px rgba(245,184,46,.4);
  transition: all .22s;
}
.hero-btn:hover { background: #E8A818; transform: translateY(-2px); }

.hero-dots {
  position: absolute;
  bottom: 2.5rem;
  right: 1.5rem;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 7px;
  opacity: .55;
}
.hdot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--yellow);
}
.hdot:nth-child(3n) { background: #D4E4B0; }

/* 右 */
.hero-right {
  position: relative;
  overflow: hidden;
}

.hero-photo-wrap {
  position: absolute;
  inset: 0;
}

.hero-photo-mask {
  position: absolute;
  inset: 0;
}
.hero-photo-mask img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

/* 白いカーブ（左側） */
.hero-curve {
  position: absolute;
  left: -1px; top: 0; bottom: 0;
  width: 140px;
  height: 100%;
  z-index: 1;
}

/* ==============================
   ABOUT
============================== */
.about {
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 5rem;
  align-items: center;
  max-width: 1100px;
  margin: 0 auto;
  padding: 6rem 2rem;
}

.about-img-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.about-circle {
  width: min(380px, 100%);
  aspect-ratio: 1;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  z-index: 1;
  box-shadow: 0 8px 32px rgba(59,50,31,.1);
}
.about-circle img {
  width: 100%; height: 100%;
  object-fit: cover;
}

.about-deco-green {
  position: absolute;
  bottom: -10px; right: 0px;
  width: 90px; opacity: .75; z-index: 0;
}
.about-deco-yellow {
  position: absolute;
  top: 10px; right: -14px;
  width: 65px; opacity: .7; z-index: 0;
}

.about-en {
  font-family: 'Lato', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: .2em;
  color: var(--green);
  display: block;
}
.about-ja {
  font-size: .75rem;
  color: var(--muted);
  letter-spacing: .1em;
  display: block;
  margin-top: 3px;
  margin-bottom: 1.25rem;
}
.about-body {
  font-size: .9rem;
  color: var(--muted);
  line-height: 2;
  margin-bottom: 1.75rem;
}
.about-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .8rem 2rem;
  background: var(--green);
  color: white;
  font-size: .875rem;
  font-weight: 700;
  border-radius: 999px;
  text-decoration: none;
  box-shadow: 0 4px 14px rgba(111,143,58,.3);
  transition: all .22s;
}
.about-btn:hover { background: var(--green-dk); transform: translateY(-2px); }

/* ==============================
   NEWS
============================== */
.news {
  background: var(--bg2);
  display: grid;
  grid-template-columns: 180px 1fr 220px;
  gap: 3rem;
  align-items: center;
  padding: 4rem;
  max-width: 1100px;
  margin: 0 auto;
  border-radius: 0;
}

.news-en {
  font-family: 'Lato', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: .2em;
  color: var(--green);
  display: block;
}
.news-ja {
  font-size: .75rem;
  color: var(--muted);
  letter-spacing: .1em;
  display: block;
  margin-top: 3px;
}

.news-list {
  list-style: none;
  margin: 0; padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.news-row {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1rem .5rem;
  border-bottom: 1px solid rgba(111,143,58,.15);
  text-decoration: none;
  color: var(--brown);
  border-radius: 6px;
  transition: background .15s;
}
.news-row:first-child { border-top: 1px solid rgba(111,143,58,.15); }
.news-row:hover { background: rgba(245,184,46,.08); }
.ndate {
  font-family: 'Lato', sans-serif;
  font-size: .8rem;
  color: var(--muted);
  white-space: nowrap;
  min-width: 5.5rem;
}
.ntitle { flex: 1; font-size: .875rem; font-weight: 500; }
.narr { flex-shrink: 0; }

.news-circle {
  width: 200px;
  aspect-ratio: 1;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto;
  box-shadow: 0 4px 20px rgba(59,50,31,.1);
}
.news-circle img { width: 100%; height: 100%; object-fit: cover; }

/* NEWSは全幅で背景色を出す */
.news-full {
  background: var(--bg2);
  padding: 0;
}
.news-full > .news {
  max-width: 1100px;
  margin: 0 auto;
}

/* ==============================
   LINE UP
============================== */
.lineup {
  padding: 5.5rem 4rem;
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 3rem;
  align-items: start;
  position: relative;
}

/* 丸い装飾 */
.lineup-deco-y {
  position: absolute;
  left: -60px; top: 4rem;
  width: 100px; height: 100px;
  border-radius: 50%;
  background: rgba(245,184,46,.18);
}
.lineup-deco-g {
  position: absolute;
  left: -30px; bottom: 3rem;
  width: 70px; height: 70px;
  border-radius: 50%;
  background: rgba(111,143,58,.12);
}

.lineup-label {
  display: flex;
  flex-direction: column;
  padding-top: .5rem;
}
.lineup-en {
  font-family: 'Lato', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: .2em;
  color: var(--green);
  display: block;
}
.lineup-ja {
  font-size: .75rem;
  color: var(--muted);
  letter-spacing: .1em;
  display: block;
  margin-top: 3px;
}

.lineup-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}

.lcard {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 16px rgba(59,50,31,.07);
  transition: transform .25s, box-shadow .25s;
}
.lcard:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(59,50,31,.13); }

.lcard-img {
  background: var(--bg2);
  overflow: hidden;
}
.lcard-img img {
  width: 100%; height: 170px;
  object-fit: cover; display: block;
  transition: transform .4s;
}
.lcard:hover .lcard-img img { transform: scale(1.04); }

.lcard-body { padding: 1rem 1rem 1.25rem; }
.lcard-name {
  font-family: 'Noto Serif JP', serif;
  font-size: .9rem; font-weight: 700;
  color: var(--brown); margin-bottom: .35rem;
}
.lcard-desc {
  font-size: .78rem; color: var(--muted);
  line-height: 1.65; margin-bottom: .75rem;
}
.lcard-link {
  font-size: .78rem; font-weight: 700;
  color: var(--yellow);
  text-decoration: none;
  display: inline-flex; align-items: center; gap: .3rem;
  transition: gap .2s;
}
.lcard-link:hover { gap: .55rem; }

/* ==============================
   FEATURE
============================== */
.feature {
  background: var(--bg2);
  padding: 5.5rem 4rem;
  /* 全幅に伸ばす */
}
.feature-inner-wrap {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 3rem;
  align-items: start;
}

/* featureはsectionの中にdivで包む */
.feature {
  display: block;
}
.feature-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 3rem;
  align-items: start;
}

.feature-label {
  display: flex;
  flex-direction: column;
  padding-top: .5rem;
}
.feature-en {
  font-family: 'Lato', sans-serif;
  font-size: 1.1rem; font-weight: 700;
  letter-spacing: .2em; color: var(--green);
  display: block;
}
.feature-ja {
  font-size: .75rem; color: var(--muted);
  letter-spacing: .1em; display: block; margin-top: 3px;
}

.feature-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}

.fcard {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 16px rgba(59,50,31,.07);
  transition: transform .25s, box-shadow .25s;
}
.fcard:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(59,50,31,.13); }

.fcard-img img {
  width: 100%; height: 150px;
  object-fit: cover; display: block;
}
.fcard-body { padding: .875rem .875rem 1.1rem; }
.fcard-name {
  font-family: 'Noto Serif JP', serif;
  font-size: .875rem; font-weight: 700;
  color: var(--brown); margin-bottom: .3rem;
}
.fcard-desc {
  font-size: .75rem; color: var(--muted);
  line-height: 1.65; margin: 0;
}

/* ==============================
   CONTACT
============================== */
.contact {
  background: #5A7A2E;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  min-height: 240px;
  position: relative;
  overflow: hidden;
}

.contact-left {
  padding: 3.5rem 2rem 3.5rem 5rem;
}
.contact-en {
  font-family: 'Lato', sans-serif;
  font-size: 1.3rem; font-weight: 700;
  letter-spacing: .22em; color: white;
  display: block; line-height: 1;
}
.contact-ja {
  font-size: .75rem; letter-spacing: .1em;
  color: rgba(255,255,255,.65); display: block; margin-top: 4px;
  margin-bottom: 1rem;
}
.contact-body {
  font-size: .875rem; color: rgba(255,255,255,.8);
  line-height: 1.85; margin: 0;
}

.contact-center {
  padding: 3rem 3rem;
  display: flex;
  justify-content: center;
}
.contact-btn {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  padding: 1rem 2.25rem;
  background: white;
  color: var(--brown);
  font-size: .875rem; font-weight: 700;
  border-radius: 999px;
  text-decoration: none;
  box-shadow: 0 4px 16px rgba(0,0,0,.15);
  transition: all .22s;
  white-space: nowrap;
}
.contact-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.2); }

.contact-img {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 35%;
  overflow: hidden;
}
.contact-img::before {
  content: '';
