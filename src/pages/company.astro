---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="会社概要｜小澤鶏卵"
  description="小澤鶏卵の会社概要ページです。所在地・代表者・設立・事業内容などをご確認いただけます。"
>
  <Header />
  <main>

    <!-- Page Hero -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="section-label">Company</span>
        <h1 class="page-title">会社概要</h1>
        <p class="page-subtitle">小澤鶏卵について</p>
      </div>
    </section>

    <!-- Company Info -->
    <section class="company-section">
      <div class="container">
        <div class="company-grid">

          <div class="company-table-wrap">
            <table class="company-table">
              <tbody>
                <tr>
                  <th>会社名</th>
                  <td>小澤鶏卵</td>
                </tr>
                <tr>
                  <th>代表者</th>
                  <td>小澤 ○○</td>
                </tr>
                <tr>
                  <th>設立</th>
                  <td>1965年（昭和40年）</td>
                </tr>
                <tr>
                  <th>所在地</th>
                  <td>〒000-0000<br />○○県○○市○○町 0-0-0</td>
                </tr>
                <tr>
                  <th>電話番号</th>
                  <td><a href="tel:0000-00-0000">0000-00-0000</a></td>
                </tr>
                <tr>
                  <th>メール</th>
                  <td><a href="mailto:info@kozawa-keiran.com">info@kozawa-keiran.com</a></td>
                </tr>
                <tr>
                  <th>営業時間</th>
                  <td>月曜〜土曜 8:00〜17:00<br /><span class="note">日曜・祝日は休業</span></td>
                </tr>
                <tr>
                  <th>事業内容</th>
                  <td>
                    鶏卵の販売・卸売<br />
                    業務用鶏卵の定期納品<br />
                    温泉卵・加工品の製造販売
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="company-message">
            <span class="section-label">Message</span>
            <h2 class="section-title">地域の食卓を支えて<br />60年</h2>
            <div class="divider"></div>
            <p>
              小澤鶏卵は1965年の創業以来、地域の飲食店・給食施設・ご家庭に新鮮なたまごをお届けしてきました。
            </p>
            <p>
              私たちが大切にしてきたのは、ただ卵を届けることではなく、安心・安全・新鮮を毎日継続することです。生産者との信頼関係を礎に、鮮度管理・衛生管理を徹底し、地域の食インフラとしての役割を果たし続けています。
            </p>
            <p>
              これからも皆様の食卓に寄り添いながら、品質と信頼を守り続けてまいります。
            </p>
            <p class="message-sign">代表　小澤 ○○</p>
          </div>

        </div>
      </div>
    </section>

    <!-- Access -->
    <section class="access-section">
      <div class="container">
        <span class="section-label">Access</span>
        <h2 class="section-title">アクセス</h2>
        <div class="divider"></div>

        <div class="access-grid">
          <div class="access-info">
            <div class="access-detail">
              <p class="access-address">〒000-0000<br />○○県○○市○○町 0-0-0</p>
              <ul class="access-list">
                <li>
                  <span class="access-icon">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="9" cy="7" r="2.5" stroke="#4A7C59" stroke-width="1.3"/>
                      <path d="M9 2C6.2 2 4 4.2 4 7c0 4 5 9 5 9s5-5 5-9c0-2.8-2.2-5-5-5z" stroke="#4A7C59" stroke-width="1.3" fill="none"/>
                    </svg>
                  </span>
                  ○○駅より徒歩約10分
                </li>
                <li>
                  <span class="access-icon">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="2" y="6" width="14" height="8" rx="2" stroke="#4A7C59" stroke-width="1.3"/>
                      <path d="M5 6V4.5C5 3.7 5.7 3 6.5 3h5c.8 0 1.5.7 1.5 1.5V6" stroke="#4A7C59" stroke-width="1.3"/>
                      <circle cx="5.5" cy="12" r="1" fill="#4A7C59"/>
                      <circle cx="12.5" cy="12" r="1" fill="#4A7C59"/>
                    </svg>
                  </span>
                  お車でお越しの場合：○○ICより約15分<br />駐車場あり（5台）
                </li>
              </ul>
            </div>
          </div>

          <div class="map-area">
            <!-- Google Map placeholder — replace src with actual embed URL -->
            <div class="map-placeholder">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="24" cy="20" r="7" stroke="#7A6355" stroke-width="1.5"/>
                <path d="M24 6C16.3 6 10 12.3 10 20c0 11 14 22 14 22s14-11 14-22c0-7.7-6.3-14-14-14z" stroke="#7A6355" stroke-width="1.5" fill="none"/>
              </svg>
              <p>Googleマップを埋め込む予定のエリアです</p>
              <p class="map-hint">実装時にGoogle Maps Embed URLを設定してください</p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    background-color: var(--color-cream);
    padding: 9rem 0 5rem;
    border-bottom: 1px solid rgba(61, 43, 31, 0.07);
  }

  .page-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--color-dark-brown);
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .company-section {
    padding: 7rem 0;
    background-color: var(--color-ivory);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .company-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .company-table {
    width: 100%;
    border-collapse: collapse;
  }

  .company-table tr {
    border-bottom: 1px solid rgba(61, 43, 31, 0.07);
  }

  .company-table th {
    padding: 1.1rem 1rem 1.1rem 0;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-dark-brown);
    text-align: left;
    white-space: nowrap;
    vertical-align: top;
    width: 9rem;
    letter-spacing: 0.03em;
  }

  .company-table td {
    padding: 1.1rem 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    vertical-align: top;
  }

  .company-table td a {
    color: var(--color-natural-green);
    text-decoration: none;
  }

  .company-table td a:hover {
    text-decoration: underline;
  }

  .note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .company-message p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }

  .message-sign {
    font-size: 0.875rem !important;
    color: var(--color-dark-brown) !important;
    font-weight: 500;
    margin-top: 2rem !important;
    text-align: right;
  }

  .access-section {
    padding: 7rem 0;
    background-color: var(--color-cream);
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    margin-top: 3rem;
    align-items: start;
  }

  .access-address {
    font-size: 1rem;
    color: var(--color-dark-brown);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .access-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .access-list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .access-icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .map-area {
    min-height: 380px;
  }

  .map-placeholder {
    width: 100%;
    height: 380px;
    background-color: var(--color-ivory);
    border: 1px solid rgba(61, 43, 31, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-text-muted);
  }

  .map-placeholder p {
    font-size: 0.875rem;
    margin: 0;
  }

  .map-hint {
    font-size: 0.75rem !important;
    opacity: 0.6;
  }

  @media (max-width: 900px) {
    .company-grid,
    .access-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
