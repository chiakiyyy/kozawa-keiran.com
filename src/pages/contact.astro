---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const faqs = [
  { q:'営業時間を教えてください', a:'月曜〜土曜 8:00〜17:00です。日曜・祝日は休業しています。' },
  { q:'業務用の最小発注量は？', a:'1ケース（約10kg）から承ります。お気軽にご相談ください。' },
  { q:'配送エリアはどこですか？', a:'富山市内に対応しています。市外はお気軽にご相談ください。' },
  { q:'ギフト包装はできますか？', a:'はい、化粧箱入りのギフトセットをご用意しています。詳しくはお問い合わせください。' },
];
---
<Layout title="お問い合わせ｜小澤鶏卵" description="小澤鶏卵へのご注文・ご相談はお気軽にどうぞ。法人取引・個人向け・ギフトなどあらゆるお問い合わせに対応します。">
  <Header/>
  <main>
    <!-- Hero -->
    <section class="contact-hero">
      <div class="contact-hero-bg">
        <img src="/images/contact_bg.svg" alt="" aria-hidden="true" loading="eager"/>
        <div class="ch-ov"></div>
      </div>
      <div class="ch-content">
        <span class="ch-en">CONTACT</span>
        <h1 class="ch-title">お問い合わせ</h1>
        <p class="ch-sub">ご注文・ご質問など、お気軽にお問い合わせください。</p>
      </div>
    </section>

    <!-- 連絡先 -->
    <section class="sec">
      <div class="container">
        <div class="contact-methods">
          <div class="method-card">
            <div class="method-icon">
              <svg width="26" height="26" viewBox="0 0 20 20" fill="none" stroke="#BA7517" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3.5C3 3.5 4.5 2 6 2c.5 0 1 .3 1.3.8l1.4 2.4c.3.5.2 1.1-.2 1.5L7.2 8c.8 1.5 2 2.8 3.5 3.6l1.3-1.3c.4-.4 1-.5 1.5-.2l2.4 1.4c.5.3.8.8.8 1.3 0 1.5-1.5 3-1.5 3C6 18 2 10 3 3.5z"/>
              </svg>
            </div>
            <h2>お電話</h2>
            <a href="tel:076-466-3815" class="method-tel">076-466-3815</a>
            <p>月〜土 8:00〜17:00</p>
            <a href="tel:076-466-3815" class="method-btn">電話をかける</a>
          </div>
          <div class="method-card method-card--line">
            <div class="method-icon method-icon--line">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="white">
                <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.070 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
              </svg>
            </div>
            <h2>LINE</h2>
            <p class="method-line-id">@215bpskd</p>
            <p>お気軽にメッセージください</p>
            <a href="https://line.me/ti/p/@215bpskd" target="_blank" rel="noopener" class="method-btn method-btn--line">LINEで相談する</a>
          </div>
          <div class="method-card">
            <div class="method-icon">
              <svg width="26" height="26" viewBox="0 0 20 20" fill="none" stroke="#BA7517" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="16" height="12" rx="2"/>
                <path d="M2 7l8 5 8-5"/>
              </svg>
            </div>
            <h2>お問い合わせフォーム</h2>
            <p class="method-email">info@kozawa-keiran.com</p>
            <p>24時間受付・翌営業日返信</p>
            <a href="#form" class="method-btn">フォームを開く</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="sec sec--cream">
      <div class="container faq-wrap">
        <div class="center-head">
          <span class="sec-en">FAQ</span>
          <h2 class="sec-title mt">よくある質問</h2>
        </div>
        <div class="faq-list">
          {faqs.map(f => (
            <details class="faq-item">
              <summary class="faq-q">
                <span class="fq-icon">Q</span>{f.q}
              </summary>
              <div class="faq-a">
                <span class="fq-icon fq-icon--a">A</span>
                <p>{f.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- フォーム -->
    <section class="sec" id="form">
      <div class="container form-wrap">
        <div class="center-head">
          <span class="sec-en">Form</span>
          <h2 class="sec-title mt">お問い合わせフォーム</h2>
          <p class="form-note"><span class="req">*</span> は必須項目です。</p>
        </div>

        <!-- TODO: Cloudflare Workers + Turnstileで送信処理を実装予定 -->
        <form class="form" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="company">会社名・店舗名</label>
              <input type="text" id="company" name="company" placeholder="株式会社〇〇" autocomplete="organization"/>
            </div>
            <div class="form-group">
              <label for="name">お名前 <span class="req">*</span></label>
              <input type="text" id="name" name="name" placeholder="山田 太郎" required autocomplete="name"/>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">メールアドレス <span class="req">*</span></label>
              <input type="email" id="email" name="email" placeholder="example@email.com" required autocomplete="email"/>
            </div>
            <div class="form-group">
              <label for="tel">電話番号</label>
              <input type="tel" id="tel" name="tel" placeholder="00-0000-0000" autocomplete="tel"/>
            </div>
          </div>
          <div class="form-group">
            <label for="type">お問い合わせ種別 <span class="req">*</span></label>
            <div class="select-wrap">
              <select id="type" name="type" required>
                <option value="" disabled selected>選択してください</option>
                <option value="business">法人取引について</option>
                <option value="product">商品について</option>
                <option value="shop">通販・ギフトについて</option>
                <option value="event">催事・イベント注文</option>
                <option value="subscription">定期購入について</option>
                <option value="other">その他</option>
              </select>
              <svg class="sel-arrow" width="14" height="8" viewBox="0 0 14 8" fill="none"><path d="M1 1l6 6 6-6" stroke="#3B321F" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
          </div>
          <div class="form-group">
            <label for="message">お問い合わせ内容 <span class="req">*</span></label>
            <textarea id="message" name="message" rows="7" placeholder="ご質問・ご要望をご記入ください。&#10;（例：週3回、20kg程度の業務用たまごを定期納品してほしい）" required></textarea>
          </div>
          <div class="form-privacy">
            <label class="check-label">
              <input type="checkbox" name="privacy" required/>
              <span class="check-box"></span>
              <span><a href="/about" class="privacy-link">プライバシーポリシー</a>に同意する <span class="req">*</span></span>
            </label>
          </div>
          <div class="form-submit">
            <button type="submit" class="btn btn-primary submit-btn">送信する</button>
            <p class="submit-note">※現在フォーム送信機能は準備中です。お急ぎの場合はお電話またはメールでご連絡ください。</p>
          </div>
        </form>
      </div>
    </section>
  </main>
  <Footer/>
</Layout>
<style>
.container { max-width:1000px; margin:0 auto; padding:0 2rem; }
.sec { padding:5.5rem 0; background:var(--bg); }
.sec--cream { background:var(--bg2); }
.mt { margin-top:.6rem; }
.center-head { text-align:center; margin-bottom:2.5rem; }
/* Hero */
.contact-hero { position:relative; height:360px; display:flex; align-items:center; margin-top:76px; }
.contact-hero-bg { position:absolute; inset:0; }
.contact-hero-bg img { width:100%; height:100%; object-fit:cover; }
.ch-ov { position:absolute; inset:0; background:linear-gradient(to right,rgba(42,74,32,.88),rgba(42,74,32,.55) 60%,rgba(42,74,32,.2)); }
.ch-content { position:relative; z-index:1; max-width:1000px; margin:0 auto; padding:0 2rem; }
.ch-en { font-family:'Lato',sans-serif; font-size:.7rem; letter-spacing:.25em; color:rgba(245,184,46,.8); text-transform:uppercase; display:block; margin-bottom:.5rem; }
.ch-title { font-family:'Noto Serif JP',serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; color:white; margin-bottom:.5rem; }
.ch-sub { font-size:.9rem; color:rgba(255,255,255,.75); margin:0; }
/* Methods */
.contact-methods { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; max-width:980px; margin:0 auto; }
.method-card { background:white; border-radius:16px; padding:2.5rem 1.75rem; text-align:center; box-shadow:0 4px 20px rgba(59,50,31,.08); border-top:3px solid #BA7517; display:flex; flex-direction:column; align-items:center; }
.method-card--line { border-top-color:#06C755; }
.method-icon { width:60px; height:60px; background:#FDF6E9; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; }
.method-icon--line { background:#06C755; }
.method-card h2 { font-family:'Zen Kaku Gothic New',sans-serif; font-size:1rem; font-weight:700; color:#2C2A24; margin-bottom:.625rem; }
.method-tel { display:block; font-family:Manrope,sans-serif; font-size:1.6rem; font-weight:700; color:#2C2A24; text-decoration:none; letter-spacing:.04em; margin-bottom:.35rem; }
.method-line-id { font-family:Manrope,sans-serif; font-size:1.3rem; font-weight:700; color:#06C755; margin:0 0 .35rem; }
.method-email { display:block; font-size:.85rem; color:#BA7517; text-decoration:none; margin-bottom:.35rem; word-break:break-all; }
.method-card p { font-size:.78rem; color:#6B6860; margin:0 0 1.25rem; }
.method-btn {
  display:inline-flex; align-items:center; justify-content:center; width:100%;
  padding:.75rem 1rem; border-radius:8px; text-decoration:none;
  font-size:.85rem; font-weight:700; letter-spacing:.02em;
  background:#BA7517; color:white; margin-top:auto; transition:opacity .15s;
}
.method-btn:hover { opacity:.85; }
.method-btn--line { background:#06C755; }
/* FAQ */
.faq-wrap { max-width:720px; }
.faq-list { display:flex; flex-direction:column; gap:.75rem; }
.faq-item { background:white; border-radius:12px; border:1px solid rgba(245,184,46,.2); overflow:hidden; }
.faq-q { display:flex; align-items:center; gap:1rem; padding:1.1rem 1.5rem; cursor:pointer; font-size:.9rem; font-weight:700; color:var(--brown); list-style:none; transition:background .15s; }
.faq-q:hover { background:rgba(245,184,46,.06); }
.faq-q::-webkit-details-marker { display:none; }
.fq-icon { width:28px; height:28px; border-radius:50%; background:var(--yellow); color:var(--brown); font-size:.78rem; font-weight:700; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; }
.fq-icon--a { background:var(--green); color:white; }
.faq-a { display:flex; align-items:flex-start; gap:1rem; padding:0 1.5rem 1.1rem; }
.faq-a p { font-size:.875rem; color:var(--muted); line-height:1.8; margin:0; padding-top:.2rem; }
/* Form */
.form-wrap { max-width:720px; }
.form-note { font-size:.8rem; color:var(--muted); margin-top:.5rem; }
.req { color:#C02828; font-size:.85em; }
.form { display:flex; flex-direction:column; gap:1.5rem; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
.form-group { display:flex; flex-direction:column; gap:.45rem; }
.form-group label { font-size:.85rem; font-weight:700; color:var(--brown); }
.form-group input,.form-group select,.form-group textarea {
  padding:.8rem 1rem; background:white; border:1.5px solid rgba(59,50,31,.15);
  border-radius:10px; color:var(--brown); font-family:inherit; font-size:.9rem;
  transition:border-color .2s; width:100%; appearance:none;
}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus {
  outline:none; border-color:var(--yellow);
}
.form-group textarea { resize:vertical; min-height:160px; line-height:1.7; }
.select-wrap { position:relative; }
.sel-arrow { position:absolute; right:1rem; top:50%; transform:translateY(-50%); pointer-events:none; }
.form-privacy { padding:1rem 0; border-top:1px solid rgba(245,184,46,.2); border-bottom:1px solid rgba(245,184,46,.2); }
.check-label { display:flex; align-items:center; gap:.875rem; cursor:pointer; font-size:.875rem; color:var(--muted); }
.check-label input { position:absolute; opacity:0; width:0; height:0; }
.check-box { width:18px; height:18px; border:1.5px solid rgba(59,50,31,.25); border-radius:4px; background:white; flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:all .15s; }
.check-label input:checked + .check-box { background:var(--green); border-color:var(--green); }
.check-label input:checked + .check-box::after { content:''; width:10px; height:6px; border-left:1.5px solid white; border-bottom:1.5px solid white; transform:rotate(-45deg) translateY(-1px); }
.privacy-link { color:var(--green); }
.form-submit { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; }
.submit-btn { padding:1rem 3.5rem; font-size:.95rem; }
.submit-note { font-size:.78rem; color:var(--muted); }
@media (max-width:900px) {
  .contact-methods { grid-template-columns:1fr; max-width:420px; }
}
@media (max-width:640px) {
  .form-row { grid-template-columns:1fr; }
}
</style>
